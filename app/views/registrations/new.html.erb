<%= content_for :title, t('auth.signup') %>

<div class="min-h-screen flex items-center justify-center bg-gray-50 dark:bg-gray-900 py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-4xl w-full animate-entrance-stagger">

    <%# ═══════════════════════════════════════════════════════════════════
         TWO-COLUMN LAYOUT: Plans (left) + Form (right)
         On mobile: stacked vertically, plans first
         ═══════════════════════════════════════════════════════════════════ %>
    <div class="text-center mb-8">
      <h2 class="text-3xl font-extrabold text-gray-900 dark:text-white">
        <%= t('auth.signup') %>
      </h2>
      <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">
        <%= t('auth.have_account') %>
        <%= link_to t('auth.login'), login_path, class: "font-medium text-(--accent-600) hover:text-(--accent-500)" %>
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-8 items-start">

      <%# ── LEFT: Plan comparison ── %>
      <div class="space-y-4 order-2 lg:order-1">
        <h3 class="text-lg font-bold text-gray-900 dark:text-white text-center lg:text-left">
          <%= case I18n.locale
              when :fr then 'Choisissez votre formule'
              when :de then 'Wählen Sie Ihren Plan'
              when :en then 'Choose your plan'
              else 'Kies uw formule'
              end %>
        </h3>

        <%# ── FREE PLAN ── %>
        <div id="plan-free-card"
             class="bg-white dark:bg-gray-800 rounded-xl border-2 border-green-300 dark:border-green-700 p-5 shadow-sm cursor-pointer transition-all duration-200 hover:shadow-md">
          <div class="flex items-center justify-between mb-3">
            <div>
              <h4 class="font-bold text-gray-900 dark:text-white text-lg">
                <%= case I18n.locale when :fr then 'Gratuit' when :de then 'Kostenlos' when :en then 'Free' else 'Gratis' end %>
              </h4>
              <p class="text-2xl font-bold text-green-600 dark:text-green-400">€0
                <span class="text-sm font-normal text-gray-500 dark:text-gray-400">/<%= case I18n.locale when :fr then 'toujours' when :de then 'immer' when :en then 'forever' else 'altijd' end %></span>
              </p>
            </div>
            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold bg-green-100 text-green-800 dark:bg-green-900/40 dark:text-green-300">
              <%= case I18n.locale when :fr then 'PAR DÉFAUT' when :de then 'STANDARD' when :en then 'DEFAULT' else 'STANDAARD' end %>
            </span>
          </div>
          <ul class="text-sm text-gray-600 dark:text-gray-400 space-y-2">
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 text-green-500 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              <span><strong>3 credits/<%= case I18n.locale when :fr then 'semaine' when :de then 'Woche' when :en then 'week' else 'week' end %></strong></span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 text-green-500 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              <span>🎁 + <%= RegistrationsController::STARTER_CREDITS %> bonus <%= case I18n.locale when :fr then 'crédits de bienvenue' when :de then 'Willkommenscredits' when :en then 'starter credits' else 'startcredits' end %></span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 text-green-500 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              <span>⚡ <%= case I18n.locale when :fr then 'Intelligent' when :de then 'Klug' when :en then 'Smart' else 'Slim' end %> (1 cr)</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 text-green-500 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              <span>⭐ <%= case I18n.locale when :fr then 'Génial' when :de then 'Genial' when :en then 'Genius' else 'Geniaal' end %> — <%= case I18n.locale when :fr then 'avec crédits bonus' when :de then 'mit Bonuscredits' when :en then 'with bonus credits' else 'met bonuscredits' end %></span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 text-green-500 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              <span><%= case I18n.locale when :fr then 'Législation + documents parlementaires' when :de then 'Gesetzgebung + parlamentarische Dokumente' when :en then 'Legislation + parliamentary documents' else 'Wetgeving + parlementaire stukken' end %></span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 text-gray-300 dark:text-gray-600 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
              <span class="text-gray-400 dark:text-gray-500"><%= case I18n.locale when :fr then 'Pas de Génial / Maître' when :de then 'Kein Genial / Meisterhirn' when :en then 'No Genius / Mastermind' else 'Geen Geniaal / Meesterbrein' end %></span>
            </li>

          </ul>
        </div>

        <%# ── PRO PLAN ── %>
        <div id="plan-pro-card"
             class="bg-white dark:bg-gray-800 rounded-xl border-2 border-(--accent-500) p-5 shadow-lg relative cursor-pointer transition-all duration-200 hover:shadow-xl">
          <div class="absolute -top-3 left-4">
            <span class="inline-block bg-(--accent-600-solid) text-white text-[10px] font-bold px-3 py-1 rounded-full capitalize tracking-wider">
              <%= case I18n.locale when :fr then 'Recommandé' when :de then 'Empfohlen' when :en then 'Recommended' else 'Aanbevolen' end %>
            </span>
          </div>
          <div class="flex items-center justify-between mb-3 mt-1">
            <div>
              <h4 class="font-bold text-gray-900 dark:text-white text-lg">WetWijzer Pro</h4>
              <p class="text-2xl font-bold text-(--accent-600)">€2,99
                <span class="text-sm font-normal text-gray-500 dark:text-gray-400">/<%= case I18n.locale when :fr then 'mois' when :de then 'Monat' when :en then 'month' else 'maand' end %></span>
              </p>
            </div>
            <%# Selection indicator %>
            <div id="plan-pro-check" class="hidden w-8 h-8 rounded-full bg-(--accent-600-solid) flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
            </div>
          </div>
          <ul class="text-sm text-gray-600 dark:text-gray-400 space-y-2">
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 text-green-500 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              <span><strong>30 credits/<%= case I18n.locale when :fr then 'mois' when :de then 'Monat' when :en then 'month' else 'maand' end %></strong> <%= case I18n.locale when :fr then 'inclus' when :de then 'inklusive' when :en then 'included' else 'inbegrepen' end %></span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 text-green-500 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              <span><strong><%= case I18n.locale when :fr then 'Tous les niveaux AI' when :de then 'Alle AI-Stufen' when :en then 'All AI tiers' else 'Alle AI-niveaus' end %></strong> — <%= case I18n.locale when :fr then 'y compris Génial et Maître' when :de then 'inkl. Genial und Meisterhirn' when :en then 'including Genius and Mastermind' else 'inclusief Geniaal en Meesterbrein' end %></span>
            </li>

            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 text-green-500 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              <span><strong><%= case I18n.locale when :fr then '~25% réduction' when :de then '~25% Rabatt' when :en then '~25% discount' else '~25% korting' end %></strong> — <%= case I18n.locale when :fr then 'sur les packs supplémentaires' when :de then 'auf zusätzliche Credit-Pakete' when :en then 'on extra credit packs' else 'op extra creditpakketten' end %></span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 text-red-400 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"/></svg>
              <span><%= case I18n.locale when :fr then 'Soutenez un projet indépendant' when :de then 'Unterstützen Sie ein unabhängiges Projekt' when :en then 'Support an independent project' else 'Steun een onafhankelijk project' end %></span>
            </li>
          </ul>
          <p id="plan-pro-hint" class="mt-3 text-xs text-gray-400 dark:text-gray-500 text-center">
            <%= case I18n.locale
                when :fr then 'Cliquez pour sélectionner — paiement après confirmation par e-mail'
                when :de then 'Klicken zum Auswählen — Zahlung nach E-Mail-Bestätigung'
                when :en then 'Click to select — payment after email confirmation'
                else 'Klik om te selecteren — betaling na e-mailbevestiging'
                end %>
          </p>
          <p id="plan-pro-selected" class="hidden mt-3 text-xs text-center font-semibold" style="color: var(--accent-600);">
            ✓ <%= case I18n.locale
                  when :fr then 'Pro sélectionné — vous serez redirigé vers le paiement après inscription'
                  when :de then 'Pro ausgewählt — Sie werden nach der Registrierung zur Zahlung weitergeleitet'
                  when :en then 'Pro selected — you\'ll be redirected to payment after registration'
                  else 'Pro geselecteerd — u wordt na registratie doorgestuurd naar betaling'
                  end %>
          </p>
        </div>

        <%# ── CREDIT PACKS HINT ── %>
        <div class="text-center text-xs text-gray-500 dark:text-gray-400 py-2">
          <svg class="w-4 h-4 inline-block mr-1 -mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <%= case I18n.locale
              when :fr then 'Vous pouvez aussi acheter des packs de crédits ponctuels.'
              when :de then 'Sie können auch einmalige Creditpakete kaufen.'
              when :en then 'You can also buy one-time credit packs.'
              else 'U kunt ook eenmalige creditpakketten kopen.'
              end %>
          <a href="<%= defined?(pricing_path) ? pricing_path : '/pricing' %>" class="underline text-(--accent-600) hover:text-(--accent-500) font-medium">
            <%= case I18n.locale when :fr then 'Voir les prix' when :de then 'Preise ansehen' when :en then 'View pricing' else 'Bekijk prijzen' end %> →
          </a>
        </div>
      </div>

      <%# ── RIGHT: Registration form ── %>
      <div class="order-1 lg:order-2">
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg p-6 sm:p-8 border border-gray-200 dark:border-gray-700">

          <% if @user.errors.any? %>
            <div class="mb-4 bg-red-50 dark:bg-red-900/50 border border-red-200 dark:border-red-800 text-red-700 dark:text-red-300 px-4 py-3 rounded-lg">
              <ul class="list-disc list-inside text-sm">
                <% @user.errors.full_messages.each do |message| %>
                  <li><%= sanitize message, tags: %w[a span strong], attributes: %w[href class] %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <%= form_with model: @user, url: signup_path, method: :post, class: "space-y-5" do |f| %>
            <!-- Honeypot field: hidden from real users, bots will fill it -->
            <div style="position: absolute; left: -9999px;" aria-hidden="true">
              <label for="website">Leave this empty</label>
              <input type="text" name="website" id="website" tabindex="-1" autocomplete="off" />
            </div>

            <%# Hidden plan selection field (free or pro) %>
            <input type="hidden" name="plan" id="plan_field" value="free" />

            <div>
              <label for="user_name" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
                <%= t('auth.name') %> <span class="text-gray-400">(<%= t('auth.optional') %>)</span>
              </label>
              <%= f.text_field :name, 
                  class: "appearance-none relative block w-full px-3 py-3 border border-gray-300 dark:border-gray-600 placeholder-gray-500 dark:placeholder-gray-400 text-gray-900 dark:text-white bg-white dark:bg-gray-800 rounded-md focus:outline-hidden focus:ring-(--accent-500) focus:border-(--accent-500) sm:text-sm",
                  placeholder: t('auth.name') %>
            </div>
            
            <div>
              <label for="user_email" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
                <%= t('auth.email') %> <span class="text-red-500">*</span>
              </label>
              <%= f.email_field :email, 
                  required: true,
                  autocomplete: "email",
                  class: "appearance-none relative block w-full px-3 py-3 border border-gray-300 dark:border-gray-600 placeholder-gray-500 dark:placeholder-gray-400 text-gray-900 dark:text-white bg-white dark:bg-gray-800 rounded-md focus:outline-hidden focus:ring-(--accent-500) focus:border-(--accent-500) sm:text-sm",
                  placeholder: t('auth.email') %>
            </div>

            <div data-controller="password-strength password-visibility">
              <label for="user_password" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
                <%= t('auth.password') %> <span class="text-red-500">*</span>
              </label>
              <div class="relative">
                <%= f.password_field :password, 
                    required: true,
                    autocomplete: "new-password",
                    data: { password_strength_target: "input", password_visibility_target: "input", action: "input->password-strength#check" },
                    class: "appearance-none relative block w-full px-3 py-3 pr-10 border border-gray-300 dark:border-gray-600 placeholder-gray-500 dark:placeholder-gray-400 text-gray-900 dark:text-white bg-white dark:bg-gray-800 rounded-md focus:outline-hidden focus:ring-(--accent-500) focus:border-(--accent-500) sm:text-sm",
                    placeholder: t('auth.password') %>
                <%= render 'shared/password_toggle' %>
              </div>
              <div class="mt-2">
                <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-full h-2">
                  <div data-password-strength-target="meter" class="h-2 rounded-full transition-all duration-300" style="width: 0%"></div>
                </div>
                <div data-password-strength-target="text" class="text-xs mt-1"></div>
                <div data-password-strength-target="requirements" class="mt-2 flex flex-wrap"></div>
              </div>
            </div>

            <div data-controller="password-visibility">
              <label for="user_password_confirmation" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
                <%= t('auth.password_confirmation') %> <span class="text-red-500">*</span>
              </label>
              <div class="relative">
                <%= f.password_field :password_confirmation, 
                    required: true,
                    autocomplete: "new-password",
                    data: { password_visibility_target: "input" },
                    class: "appearance-none relative block w-full px-3 py-3 pr-10 border border-gray-300 dark:border-gray-600 placeholder-gray-500 dark:placeholder-gray-400 text-gray-900 dark:text-white bg-white dark:bg-gray-800 rounded-md focus:outline-hidden focus:ring-(--accent-500) focus:border-(--accent-500) sm:text-sm",
                    placeholder: t('auth.password_confirmation') %>
                <%= render 'shared/password_toggle' %>
              </div>
            </div>

            <div class="flex items-start">
              <%= f.check_box :terms_accepted, 
                  required: true,
                  class: "h-4 w-4 mt-1 text-(--accent-600) border-gray-300 rounded focus:ring-(--accent-500)" %>
              <label for="user_terms_accepted" class="ml-2 text-sm text-gray-600 dark:text-gray-400">
                <%= t('auth.terms_html', 
                    privacy_link: link_to(t('auth.privacy_policy'), privacy_policy_path, class: 'text-(--accent-600) hover:underline'),
                    terms_link: link_to(t('auth.terms_of_service'), terms_of_service_path, class: 'text-(--accent-600) hover:underline')
                ).html_safe %>
                <span class="text-red-500">*</span>
              </label>
            </div>

            <button type="submit"
                    class="group relative w-full flex justify-center py-3 px-4 border border-transparent text-sm font-medium rounded-md text-white bg-(--accent-600-solid) hover:bg-(--accent-700-solid) focus:outline-hidden focus:ring-2 focus:ring-offset-2 focus:ring-(--accent-500) transition">
              <%= t('auth.signup') %>
            </button>
          <% end %>

          <div class="mt-4 text-center">
            <%= link_to root_path, class: "text-sm text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white" do %>
              ← <%= case I18n.locale when :fr then 'Retour à' when :de then 'Zurück zu' when :en then 'Back to' else 'Terug naar' end %> <%= t('app_title') %>
            <% end %>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

<script nonce="<%= content_security_policy_nonce %>">
  function updatePlanSelection() {
    var isPro = document.getElementById('plan_field').value === 'pro';
    var proCard = document.getElementById('plan-pro-card');
    var proCheck = document.getElementById('plan-pro-check');
    var proHint = document.getElementById('plan-pro-hint');
    var proSelected = document.getElementById('plan-pro-selected');
    var freeCard = document.getElementById('plan-free-card');

    if (isPro) {
      proCard.classList.add('ring-2', 'ring-(--accent-500)', 'shadow-xl');
      proCard.classList.remove('shadow-lg');
      proCheck.classList.remove('hidden');
      proCheck.classList.add('flex');
      proHint.classList.add('hidden');
      proSelected.classList.remove('hidden');
      if (freeCard) {
        freeCard.classList.remove('border-green-300', 'dark:border-green-700');
        freeCard.classList.add('border-gray-200', 'dark:border-gray-700', 'opacity-60');
      }
    } else {
      proCard.classList.remove('ring-2', 'ring-(--accent-500)', 'shadow-xl');
      proCard.classList.add('shadow-lg');
      proCheck.classList.add('hidden');
      proCheck.classList.remove('flex');
      proHint.classList.remove('hidden');
      proSelected.classList.add('hidden');
      if (freeCard) {
        freeCard.classList.add('border-green-300', 'dark:border-green-700');
        freeCard.classList.remove('border-gray-200', 'dark:border-gray-700', 'opacity-60');
      }
    }
  }

  // Attach click handlers via addEventListener (CSP blocks inline onclick)
  document.addEventListener('DOMContentLoaded', function() {
    var freeCard = document.getElementById('plan-free-card');
    var proCard = document.getElementById('plan-pro-card');
    var planField = document.getElementById('plan_field');

    if (freeCard && planField) {
      freeCard.addEventListener('click', function() {
        planField.value = 'free';
        updatePlanSelection();
      });
    }
    if (proCard && planField) {
      proCard.addEventListener('click', function() {
        planField.value = planField.value === 'pro' ? 'free' : 'pro';
        updatePlanSelection();
      });
    }
  });
</script>
