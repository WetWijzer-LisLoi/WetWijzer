<%= content_for :title, t('account.billing_info') %>

<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-8 px-4 sm:px-6 lg:px-8">
  <div class="max-w-6xl mx-auto flex flex-col lg:flex-row gap-8">
    <%= render 'layouts/account_sidebar' %>

    <main class="flex-1 min-w-0">
    <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">
      🧾 <%= t('account.billing_info') %>
    </h2>

    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg p-6 mb-6">
      <%= form_with url: update_billing_info_path, method: :patch, class: "space-y-4", data: { controller: "billing-type" } do |f| %>
        <!-- B2B / B2C Toggle -->
        <div class="mb-6">
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-3">
            <%= t('account.customer_type') %>
          </label>
          <div class="flex gap-4">
            <label class="flex items-center cursor-pointer">
              <input type="radio" name="customer_type" value="consumer" 
                     <%= 'checked' if @subscription&.customer_type != 'business' %>
                     class="w-4 h-4 text-(--accent-600) border-gray-300 focus:ring-(--accent-500)"
                     data-action="change->billing-type#toggle"
                     data-billing-type-target="consumerRadio">
              <span class="ml-2 text-gray-700 dark:text-gray-300">🧑 <%= t('account.customer_consumer') %></span>
            </label>
            <label class="flex items-center cursor-pointer">
              <input type="radio" name="customer_type" value="business"
                     <%= 'checked' if @subscription&.customer_type == 'business' %>
                     class="w-4 h-4 text-(--accent-600) border-gray-300 focus:ring-(--accent-500)"
                     data-action="change->billing-type#toggle"
                     data-billing-type-target="businessRadio">
              <span class="ml-2 text-gray-700 dark:text-gray-300">🏢 <%= t('account.customer_business') %></span>
            </label>
          </div>
        </div>

        <!-- PEPPOL Info (B2B only) -->
        <div id="peppol-info" class="bg-(--accent-50,#eff6ff) dark:bg-(--accent-900,#1e3a5f)/30 border border-(--accent-200) dark:border-(--accent-800) rounded-lg p-4 mb-6 <%= 'hidden' if @subscription&.customer_type != 'business' %>"
             data-billing-type-target="businessFields">
          <h2 class="font-bold text-(--accent-700) dark:text-(--accent-400) mb-2">
            🇪🇺 <%= t('account.peppol_info_title') %>
          </h2>
          <p class="text-sm text-(--accent-700) dark:text-(--accent-400)">
            <%= t('account.peppol_info_desc') %>
          </p>
        </div>

        <!-- Company fields (B2B only) -->
        <div id="company-fields" class="space-y-4 <%= 'hidden' if @subscription&.customer_type != 'business' %>"
             data-billing-type-target="businessFields">
          <div>
            <label for="company_name" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
              <%= t('account.company_name') %>
            </label>
            <input type="text" name="company_name" id="company_name" 
                   value="<%= @subscription&.company_name %>"
                   autocomplete="organization"
                   class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-(--accent-500) focus:border-(--accent-500)"
                   placeholder="Acme NV">
          </div>

          <div>
            <label for="vat_number" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
              <%= t('account.enterprise_number') %> <span class="text-gray-400">(0123.456.789)</span>
            </label>
            <input type="text" name="vat_number" id="vat_number" 
                   value="<%= @subscription&.vat_number %>"
                   autocomplete="one-time-code"
                   class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-(--accent-500) focus:border-(--accent-500)"
                   placeholder="0123.456.789">
            <p class="text-xs text-gray-500 mt-1"><%= t('account.enterprise_number_hint') %></p>
          </div>
        </div>

        <hr class="border-gray-200 dark:border-gray-700 my-4">

        <h3 class="font-medium text-gray-900 dark:text-white mb-3"><%= t('account.billing_address') %></h3>

        <div>
          <label for="billing_address_line1" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
            <%= t('account.address_line1') %>
          </label>
          <input type="text" name="billing_address_line1" id="billing_address_line1" 
                 value="<%= @subscription&.billing_address_line1 %>"
                 autocomplete="street-address"
                 class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-(--accent-500) focus:border-(--accent-500)"
                 placeholder="Wetstraat 1">
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label for="billing_postal_code" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
              <%= t('account.postal_code') %>
            </label>
            <input type="text" name="billing_postal_code" id="billing_postal_code" 
                   value="<%= @subscription&.billing_postal_code %>"
                   autocomplete="postal-code"
                   class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-(--accent-500) focus:border-(--accent-500)"
                   placeholder="1000">
          </div>
          <div>
            <label for="billing_city" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
              <%= t('account.city') %>
            </label>
            <input type="text" name="billing_city" id="billing_city" 
                   value="<%= @subscription&.billing_city %>"
                   autocomplete="address-level2"
                   class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-(--accent-500) focus:border-(--accent-500)"
                   placeholder="Brussel">
          </div>
        </div>

        <div>
          <label for="billing_country" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
            <%= t('account.country') %>
          </label>
          <select name="billing_country" id="billing_country" 
                  class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-(--accent-500) focus:border-(--accent-500)">
            <option value="BE" <%= 'selected' if @subscription&.billing_country == 'BE' || @subscription&.billing_country.nil? %>>🇧🇪 België / Belgique</option>
            <option value="NL" <%= 'selected' if @subscription&.billing_country == 'NL' %>>🇳🇱 Nederland</option>
            <option value="LU" <%= 'selected' if @subscription&.billing_country == 'LU' %>>🇱🇺 Luxembourg</option>
            <option value="FR" <%= 'selected' if @subscription&.billing_country == 'FR' %>>🇫🇷 France</option>
            <option value="DE" <%= 'selected' if @subscription&.billing_country == 'DE' %>>🇩🇪 Deutschland</option>
          </select>
        </div>

        <div class="pt-4">
          <button type="submit" class="w-full py-3 px-4 bg-(--accent-600-solid) text-white rounded-lg hover:bg-(--accent-700-solid) transition font-medium">
            <%= t('common.save') %>
          </button>
        </div>
      <% end %>
    </div>

    <div class="p-4 bg-gray-100 dark:bg-gray-800 rounded-lg">
      <h3 class="font-medium text-gray-900 dark:text-white mb-2"><%= t('account.peppol_status') %></h3>
      <% if @subscription&.vat_number.present? %>
        <div class="flex items-center text-green-600">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          <%= t('account.peppol_ready') %>
        </div>
      <% else %>
        <div class="flex items-center text-amber-600">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
          <%= t('account.peppol_not_ready') %>
        </div>
      <% end %>
    </div>
    </main>
  </div>
</div>
