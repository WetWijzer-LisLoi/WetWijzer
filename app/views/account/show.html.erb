<%= content_for :title, t('account.title') %>

<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-8 px-4 sm:px-6 lg:px-8">
  <div class="max-w-6xl mx-auto flex flex-col lg:flex-row gap-8">
    <%= render 'layouts/account_sidebar' %>
    
    <main class="flex-1 min-w-0">

    <!-- Tier Branding -->
    <% if @user.pro? %>
      <div class="mb-6 p-4 rounded-lg shadow-lg flex items-center justify-between text-white" style="background: var(--accent-600-solid);">
        <div class="flex items-center gap-3">
          <span class="flex items-center justify-center w-9 h-9 rounded-full shadow-[0_2px_6px_rgba(217,119,6,0.4)] ring-2 ring-white/30" style="background: linear-gradient(135deg, #fbbf24, #f59e0b, #d97706);">
            <svg class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="currentColor"><path d="M5 16L3 5l5.5 5L12 4l3.5 6L21 5l-2 11H5zm0 2h14v1a1 1 0 01-1 1H6a1 1 0 01-1-1v-1z"/></svg>
          </span>
          <div>
            <h2 class="text-lg font-bold text-white"><%= site_name %> Pro</h2>
            <p class="text-sm text-white/80"><%= @user.name.present? ? @user.name : @user.email %></p>
          </div>
        </div>
        <span class="px-3 py-1 text-xs font-bold capitalize tracking-wider rounded-full bg-white/20 text-white border border-white/30">
          Pro
        </span>
      </div>
      <!-- Pro Thank You -->
      <div class="mb-6 p-4 rounded-lg bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-700/40 flex items-center gap-3">
        <svg class="w-8 h-8 text-amber-500 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M5 16L3 5l5.5 5L12 4l3.5 6L21 5l-2 11H5zm0 2h14v1a1 1 0 01-1 1H6a1 1 0 01-1-1v-1z"/></svg>
        <div>
          <p class="font-semibold text-amber-900 dark:text-amber-200 text-sm">
            <%= case I18n.locale
                when :fr then 'Merci de soutenir notre projet !'
                when :de then 'Danke für Ihre Unterstützung unseres Projekts!'
                when :en then 'Thank you for supporting our project!'
                else 'Bedankt dat u ons project steunt!'
                end %>
          </p>
          <p class="text-xs text-amber-700 dark:text-amber-300/70 mt-0.5">
            <%= case I18n.locale
                when :fr then "Votre abonnement #{site_name} Pro nous aide \u00e0 maintenir #{site_name} gratuit et accessible pour tous."
                when :de then "Ihr #{site_name} Pro-Abonnement hilft uns, #{site_name} kostenlos und zug\u00e4nglich f\u00fcr alle zu halten."
                when :en then "Your #{site_name} Pro subscription helps us keep #{site_name} free and accessible for everyone."
                else "Uw #{site_name} Pro-abonnement helpt ons #{site_name} gratis en toegankelijk te houden voor iedereen."
                end %>
          </p>
        </div>
      </div>
    <% else %>
      <div class="mb-6 p-4 rounded-lg bg-gray-100 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <span class="text-2xl">👤</span>
          <div>
            <h2 class="text-lg font-semibold text-gray-900 dark:text-white"><%= @user.name.present? ? @user.name : @user.email %></h2>
            <p class="text-sm text-gray-500 dark:text-gray-400"><%= t('account.tier_free', default: 'Free') %></p>
          </div>
        </div>
        <% if Rails.application.config.chatbot_enabled %>
          <%= link_to pricing_path, class: "px-3 py-1.5 text-xs font-semibold rounded-full hover:opacity-80 transition text-white", style: "background: var(--accent-600-solid);" do %>
            <svg class="w-4 h-4 text-amber-400 inline" viewBox="0 0 24 24" fill="currentColor"><path d="M5 16L3 5l5.5 5L12 4l3.5 6L21 5l-2 11H5zm0 2h14v1a1 1 0 01-1 1H6a1 1 0 01-1-1v-1z"/></svg>
            <%= case I18n.locale
                when :fr then "Passez à #{site_name} Pro"
                when :en then "Upgrade to #{site_name} Pro"
                else "Upgrade naar #{site_name} Pro"
            end %>
          <% end %>
        <% end %>
      </div>
    <% end %>

    <!-- Account Info -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg p-6 mb-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-xl font-semibold text-gray-900 dark:text-white">
          <%= t('account.info') %>
        </h2>
        <%= link_to edit_account_path, class: "text-(--accent-600) hover:text-(--accent-700) text-sm" do %>
          <svg class="w-4 h-4 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
          <%= t('account.edit_profile') %>
        <% end %>
      </div>
      <dl class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <dt class="text-sm text-gray-500 dark:text-gray-400"><%= t('auth.email') %></dt>
          <dd class="text-gray-900 dark:text-white"><%= @user.email %></dd>
        </div>
        <div>
          <dt class="text-sm text-gray-500 dark:text-gray-400"><%= t('auth.name') %></dt>
          <dd class="text-gray-900 dark:text-white"><%= @user.name || '-' %></dd>
        </div>
        <div>
          <dt class="text-sm text-gray-500 dark:text-gray-400"><%= t('account.member_since') %></dt>
          <dd class="text-gray-900 dark:text-white"><%= @user.created_at.strftime('%d %B %Y') %></dd>
        </div>
        <% if Rails.application.config.chatbot_enabled %>
        <div>
          <dt class="text-sm text-gray-500 dark:text-gray-400"><%= t('account.total_queries') %></dt>
          <dd class="text-gray-900 dark:text-white"><%= @usage_stats[:total_queries] %></dd>
        </div>
        <div>
          <dt class="text-sm text-gray-500 dark:text-gray-400"><%= t('account.invoice_language', default: 'Factuurtaal') %></dt>
          <dd class="text-gray-900 dark:text-white">
            <% locale_labels = { 'nl' => '🇧🇪 Nederlands', 'fr' => '🇧🇪 Français', 'de' => '🇩🇪 Deutsch', 'en' => '🇬🇧 English' } %>
            <%= @user.invoice_locale.present? ? locale_labels[@user.invoice_locale] : "🔄 #{t('account.invoice_language_auto', default: 'Automatisch')}" %>
          </dd>
        </div>
        <% end %>
      </dl>
    </div>

    <% if Rails.application.config.chatbot_enabled %>
    <!-- Subscription -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg p-6 mb-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-xl font-semibold text-gray-900 dark:text-white">
          <%= t('subscriptions.your_subscription') %>
        </h2>
        <% sub_status = if @subscription&.pro? && @subscription.status == 'active'
                            'active'
                          elsif @subscription&.status == 'past_due'
                            'past_due'
                          elsif @subscription&.status == 'incomplete'
                            'incomplete'
                          elsif @subscription&.canceled_at.present? || @subscription&.status == 'canceled'
                            'canceled'
                          else
                            'free'
                          end
        %>
        <span class="px-2 py-1 text-xs font-medium rounded-full <%= case sub_status
          when 'active' then 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200'
          when 'past_due' then 'bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200'
          when 'incomplete' then 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200'
          when 'canceled' then 'bg-amber-100 text-amber-800 dark:bg-amber-900 dark:text-amber-200'
          else 'bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300'
          end %>">
            <%= case sub_status
              when 'active' then 'Active'
              when 'past_due' then (case I18n.locale when :fr then 'Paiement en retard' when :de then 'Zahlung überfällig' when :en then 'Past Due' else 'Betaling achterstallig' end)
              when 'incomplete' then (case I18n.locale when :fr then 'En attente' when :de then 'Ausstehend' when :en then 'Pending' else 'In behandeling' end)
              when 'canceled' then (case I18n.locale when :fr then 'Annulé' when :de then 'Gekündigt' when :en then 'Cancelled' else 'Opgezegd' end)
              else 'Free'
              end %>
          </span>
      </div>
      
      <div class="space-y-3">
        <!-- PEPPOL Billing Info -->
        <%= link_to billing_info_path, class: "flex items-center justify-between p-3 bg-gray-50 dark:bg-gray-700 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-600 transition" do %>
          <div class="flex items-center">
            <svg class="w-5 h-5 text-gray-500 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            <div>
              <span class="text-gray-700 dark:text-gray-300"><%= t('account.billing_info') %></span>
              <% if @subscription&.try(:vat_number).present? %>
                <span class="ml-2 px-2 py-0.5 text-xs bg-green-100 text-green-800 rounded-full">PEPPOL <svg class="w-3 h-3 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg></span>
              <% end %>
            </div>
          </div>
          <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <% end %>

        <% if @subscription&.try(:stripe_customer_id).present? %>
          <%= link_to billing_portal_path, class: "flex items-center justify-between p-3 bg-gray-50 dark:bg-gray-700 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-600 transition" do %>
            <div class="flex items-center">
              <svg class="w-5 h-5 text-gray-500 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
              <span class="text-gray-700 dark:text-gray-300"><%= t('subscriptions.manage_billing') %></span>
            </div>
            <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          <% end %>
        <% end %>
        
        <%= link_to subscription_path, class: "flex items-center justify-between p-3 bg-gray-50 dark:bg-gray-700 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-600 transition" do %>
          <div class="flex items-center">
            <svg class="w-5 h-5 text-gray-500 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span class="text-gray-700 dark:text-gray-300"><%= t('account.manage_subscription') %></span>
          </div>
          <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <% end %>
      </div>
    </div>

    <!-- Usage Dashboard -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg p-6 mb-6">
      <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">
        📊 <%= t('account.usage_dashboard') %>
      </h2>
      
      <% user_credits = @user.credits %>
      
      <div class="space-y-4">



        <!-- Credits -->

        <!-- Credits -->
        <% if user_credits > 0 %>
        <div class="flex items-center justify-between p-3 bg-gray-50 dark:bg-gray-700 rounded-lg">
          <span class="text-gray-600 dark:text-gray-400"><%= t('account.credits', default: 'Credits') %></span>
          <span class="font-bold text-lg text-(--accent-600)"><%= user_credits %></span>
        </div>
        <% end %>
        
        <!-- Monthly Stats -->
        <div class="pt-4 grid grid-cols-2 gap-4">
          <div class="text-center p-3 bg-gray-50 dark:bg-gray-700 rounded-lg">
            <div class="text-2xl font-bold text-(--accent-600)"><%= @usage_stats[:this_month] %></div>
            <div class="text-xs text-gray-500 dark:text-gray-400"><%= t('account.this_month') %></div>
          </div>
          <div class="text-center p-3 bg-gray-50 dark:bg-gray-700 rounded-lg">
            <div class="text-2xl font-bold text-gray-700 dark:text-gray-300"><%= @usage_stats[:total_queries] %></div>
            <div class="text-xs text-gray-500 dark:text-gray-400"><%= t('account.total_queries') %></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Security Settings -->
    <% end %>
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg p-6 mb-6">
      <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">
        🔒 <%= t('account.security') %>
      </h2>
      
      <div class="space-y-3">
        <!-- 2FA -->
        <div class="flex items-center justify-between p-3 bg-gray-50 dark:bg-gray-700 rounded-lg">
          <div class="flex items-center">
            <svg class="w-5 h-5 text-gray-500 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
            <div>
              <span class="text-gray-700 dark:text-gray-300"><%= t('account.two_factor') %></span>
              <% if @user.otp_enabled? %>
                <span class="ml-2 px-2 py-0.5 text-xs bg-green-100 text-green-800 rounded-full"><%= t('account.enabled') %></span>
              <% end %>
            </div>
          </div>
          <% if @user.otp_enabled? %>
            <%= link_to t('account.disable'), disable_2fa_path, method: :delete, data: { confirm: t('account.disable_2fa_confirm') }, class: "text-red-600 hover:text-red-700 text-sm" %>
          <% else %>
            <%= link_to t('account.enable'), setup_2fa_path, class: "text-(--accent-600) hover:text-(--accent-700) text-sm" %>
          <% end %>
        </div>

        <!-- Activity Log -->
        <%= link_to activity_log_path, class: "flex items-center justify-between p-3 bg-gray-50 dark:bg-gray-700 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-600 transition" do %>
          <div class="flex items-center">
            <svg class="w-5 h-5 text-gray-500 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            <span class="text-gray-700 dark:text-gray-300"><%= t('account.activity_log') %></span>
          </div>
          <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <% end %>
      </div>
    </div>

    <% if Rails.application.config.chatbot_enabled %>
    <!-- Praxis Cross-Sell Banner - colors matched to praxislegal.be light/dark theme -->
    <a href="https://praxislegal.be" target="_blank" rel="noopener" class="block relative overflow-hidden rounded-lg shadow-lg mb-6 bg-gradient-to-r from-[#faf8f3] via-[#f3efe6] to-[#faf8f3] border border-[#8c7328]/20 dark:from-[#0c1322] dark:via-[#111b2e] dark:to-[#0c1322] dark:border-[#c9a962]/25 cursor-pointer transition-shadow hover:shadow-xl group no-underline">
      <!-- Decorative glow -->
      <div class="absolute -top-12 -right-12 w-40 h-40 bg-[#c9a962]/8 dark:bg-[#c9a962]/10 rounded-full blur-3xl"></div>
      <div class="absolute -bottom-8 -left-8 w-32 h-32 bg-[#c9a962]/8 dark:bg-[#c9a962]/10 rounded-full blur-2xl"></div>
      
      <div class="relative p-6">
        <div class="flex items-start gap-5">
          <!-- Praxis Logo (horizontal) -->
          <div class="shrink-0 flex items-center justify-center">
            <img src="/images/logo-praxis-light.png" alt="Praxis" class="h-10 w-auto object-contain dark:hidden" loading="lazy">
            <img src="/images/logo-praxis-horizontal.png" alt="Praxis" class="h-10 w-auto object-contain hidden dark:block" loading="lazy">
          </div>
          
          <!-- Content -->
          <div class="flex-1 min-w-0">
            <h3 class="text-lg font-semibold text-[#1c1710] dark:text-white mb-1">
              <%= t('praxis_banner.title', default: 'Looking for management software for your law practice?') %>
            </h3>
            <p class="text-sm text-[#4a4030] dark:text-gray-300 leading-relaxed mb-3">
              <%= t('praxis_banner.description', site_name: site_name, default: "Document management, client management, invoicing, AI assistant - all in one desktop app. Support %{site_name} and buy Praxis!") %>
            </p>
            <div class="flex flex-wrap items-center gap-3">
              <span class="inline-flex items-center gap-2 px-4 py-2 bg-[#0c1322] group-hover:bg-[#1a2a44] dark:bg-gradient-to-r dark:from-[#c9a962] dark:to-[#b8943a] dark:group-hover:from-[#b8943a] dark:group-hover:to-[#a7832f] text-[#c9a962] dark:text-gray-900 font-semibold rounded-lg text-sm transition-all group-hover:shadow-lg group-hover:shadow-[#c9a962]/25 group-hover:-translate-y-0.5">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                </svg>
                <%= t('praxis_banner.cta', default: 'Discover Praxis') %>
              </span>
              <span class="text-xs text-[#6b5f4d] dark:text-gray-400">
                <%= t('praxis_banner.tagline', default: 'From €14/month - by the makers of %{site_name}', site_name: site_name) %>
              </span>
            </div>
          </div>
        </div>
      </div>
    </a>
    <% end %>

    <!-- GDPR Actions -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg p-6 mb-6">
      <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">
        <%= t('account.your_data') %>
      </h2>
      
      <div class="space-y-4">
        <!-- Export Data -->
        <div class="flex items-center justify-between">
          <div>
            <p class="font-medium text-gray-900 dark:text-white"><%= t('account.export_data') %></p>
            <p class="text-sm text-gray-500 dark:text-gray-400"><%= t('account.export_data_desc') %></p>
          </div>
          <%= link_to export_data_path, class: "px-4 py-2 bg-(--accent-600-solid) text-white rounded-lg hover:bg-(--accent-700-solid) transition" do %>
            <%= t('account.download') %>
          <% end %>
        </div>

        <!-- Delete Account -->
        <div class="flex items-center justify-between pt-4">
          <div>
            <p class="font-medium text-red-600"><%= t('account.delete_account') %></p>
            <p class="text-sm text-gray-500 dark:text-gray-400"><%= t('account.delete_account_desc') %></p>
          </div>
          <%= button_to delete_account_path, 
              method: :delete,
              form: { data: { turbo_confirm: t('account.delete_confirm') } },
              class: "px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition" do %>
            <%= t('account.delete') %>
          <% end %>
        </div>
      </div>
    </div>

    </main>
  </div>
</div>
