<%= t('mailer.deletion_scheduled.title', default: 'Account Deletion Scheduled') %>

<%= t('mailer.deletion_scheduled.greeting', name: @user.name || @user.email, default: "Hello #{@user.name || @user.email}") %>

<%= t('mailer.deletion_scheduled.body', date: @deletion_date&.strftime('%d/%m/%Y'), default: "Your account is scheduled for deletion on #{@deletion_date&.strftime('%d/%m/%Y')}.") %>

<%= t('mailer.deletion_scheduled.cancel_prompt', default: 'To cancel, click the link below:') %>
<%= @cancel_url %>

<%= t('mailer.deletion_scheduled.reactivation_link', default: 'Or reactivate without logging in:') %>
<%= @reactivation_url %>
