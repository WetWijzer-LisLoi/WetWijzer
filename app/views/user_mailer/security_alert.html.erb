<h2 style="color: #dc2626;">🔒 <%= t("mailer.security_alert.#{@event_type}.title") %></h2>

<p><%= t('mailer.security_alert.greeting', name: @user.name || @user.email) %></p>

<div class="danger-box">
  <p style="margin: 0; color: #991b1b;"><strong><%= t("mailer.security_alert.#{@event_type}.message") %></strong></p>
</div>

<div style="margin: 24px 0; background: #f8fafc; border-radius: 10px; padding: 4px 0; overflow: hidden;">
  <table style="width: 100%; border-collapse: collapse;">
    <tr style="border-bottom: 1px solid #e5e7eb;">
      <td style="padding: 12px 16px; font-weight: 600; color: #6b7280; width: 120px; font-size: 13px;"><%= t('mailer.security_alert.time') %></td>
      <td style="padding: 12px 16px; font-size: 14px;"><%= Time.current.strftime('%d/%m/%Y %H:%M %Z') %></td>
    </tr>
    <% if @ip_address %>
    <tr style="border-bottom: 1px solid #e5e7eb;">
      <td style="padding: 12px 16px; font-weight: 600; color: #6b7280; font-size: 13px;"><%= t('mailer.security_alert.ip_address') %></td>
      <td style="padding: 12px 16px; font-size: 14px; font-family: 'SF Mono', 'Fira Code', monospace;"><%= @ip_address %></td>
    </tr>
    <% end %>
    <% if @user_agent %>
    <tr>
      <td style="padding: 12px 16px; font-weight: 600; color: #6b7280; font-size: 13px;"><%= t('mailer.security_alert.device') %></td>
      <td style="padding: 12px 16px; font-size: 13px; color: #6b7280;"><%= @user_agent.truncate(60) %></td>
    </tr>
    <% end %>
  </table>
</div>

<p><%= t('mailer.security_alert.not_you') %></p>

<div class="button-wrapper">
  <a href="<%= account_url %>" class="button" style="display: inline-block; background: linear-gradient(135deg, #dc2626 0%, #b91c1c 100%); background-color: #dc2626; color: #ffffff !important; text-decoration: none; padding: 15px 40px; border-radius: 10px; font-weight: 700; font-size: 15px; letter-spacing: 0.3px; box-shadow: 0 4px 14px rgba(220, 38, 38, 0.35);"><%= t('mailer.security_alert.review_button') %></a>
</div>
