<h2><%= t('mailer.password_reset.title') %></h2>

<p><%= t('mailer.password_reset.greeting', name: @user.name || @user.email) %></p>

<p><%= t('mailer.password_reset.body') %></p>

<div class="button-wrapper">
  <a href="<%= @reset_url %>" class="button" style="display: inline-block; background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%); background-color: #2563eb; color: #ffffff !important; text-decoration: none; padding: 15px 40px; border-radius: 10px; font-weight: 700; font-size: 15px; letter-spacing: 0.3px; box-shadow: 0 4px 14px rgba(37, 99, 235, 0.35);"><%= t('mailer.password_reset.button') %></a>
</div>

<div class="warning-box">
  ⚠️ <%= t('mailer.password_reset.expires') %>
</div>

<p style="font-size: 13px; color: #6b7280;"><%= t('mailer.password_reset.ignore') %></p>

<div class="divider"></div>

<div class="info-box">
  <p style="margin: 0; font-size: 12px;">
    <%= t('mailer.password_reset.link_fallback') %>
  </p>
  <p style="margin: 6px 0 0; font-size: 11px; word-break: break-all; opacity: 0.8;"><%= @reset_url %></p>
</div>
