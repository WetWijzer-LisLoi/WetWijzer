<h2><%= t('mailer.deletion_scheduled.greeting', name: @user.name || @user.email) %></h2>

<p><%= t('mailer.deletion_scheduled.body') %></p>

<div class="warning-box">
  <strong><%= t('mailer.deletion_scheduled.date_label') %>:</strong>
  <%= I18n.l(@deletion_date, format: :long) rescue @deletion_date&.strftime('%d/%m/%Y') %>
</div>

<p><%= t('mailer.deletion_scheduled.undo_info') %></p>

<p style="text-align: center;">
  <a href="<%= @reactivation_url %>" class="button" style="display: inline-block; background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%); background-color: #2563eb; color: #ffffff !important; text-decoration: none; padding: 14px 32px; border-radius: 8px; font-weight: 600; font-size: 16px; box-shadow: 0 2px 4px rgba(37, 99, 235, 0.3);"><%= t('mailer.deletion_scheduled.cancel_button', default: t('account.cancel_deletion')) %></a>
</p>

<div class="info-box">
  <p style="margin: 0; font-size: 13px;">
    <%= t('mailer.deletion_scheduled.link_text', default: 'Or copy this link to your browser:') %>
  </p>
  <p style="margin: 4px 0 0; font-size: 12px; word-break: break-all;"><%= @reactivation_url %></p>
</div>
