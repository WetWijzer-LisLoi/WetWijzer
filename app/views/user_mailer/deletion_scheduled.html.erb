<h2><%= t('mailer.deletion_scheduled.greeting', name: @user.name || @user.email) %></h2>

<p><%= t('mailer.deletion_scheduled.body') %></p>

<div class="warning-box">
  <strong><%= t('mailer.deletion_scheduled.date_label') %>:</strong>
  <span style="font-size: 16px; font-weight: 700;"><%= I18n.l(@deletion_date, format: :long) rescue @deletion_date&.strftime('%d/%m/%Y') %></span>
</div>

<p><%= t('mailer.deletion_scheduled.undo_info') %></p>

<div class="button-wrapper">
  <a href="<%= @reactivation_url %>" class="button" style="display: inline-block; background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%); background-color: #2563eb; color: #ffffff !important; text-decoration: none; padding: 15px 40px; border-radius: 10px; font-weight: 700; font-size: 15px; letter-spacing: 0.3px; box-shadow: 0 4px 14px rgba(37, 99, 235, 0.35);"><%= t('mailer.deletion_scheduled.cancel_button', default: t('account.cancel_deletion')) %></a>
</div>

<div class="divider"></div>

<div class="info-box">
  <p style="margin: 0; font-size: 12px;">
    <%= t('mailer.deletion_scheduled.link_text', default: 'Or copy this link to your browser:') %>
  </p>
  <p style="margin: 6px 0 0; font-size: 11px; word-break: break-all; opacity: 0.8;"><%= @reactivation_url %></p>
</div>
