<h2><%= t('mailer.password_reset.greeting', name: @user.name || @user.email) %></h2>

<p><%= t('mailer.password_reset.body') %></p>

<p style="text-align: center; margin: 30px 0;">
  <a href="<%= @reset_url %>" class="button" style="display: inline-block; background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%); background-color: #2563eb; color: #ffffff !important; text-decoration: none; padding: 14px 32px; border-radius: 8px; font-weight: 600; font-size: 16px; box-shadow: 0 2px 4px rgba(37, 99, 235, 0.3);"><%= t('mailer.password_reset.button') %></a>
</p>

<div class="warning-box">
  ⚠️ <%= t('mailer.password_reset.expires') %>
</div>

<p><%= t('mailer.password_reset.ignore') %></p>

<div class="info-box">
  <p style="margin: 0; font-size: 13px;">
    <%= t('mailer.password_reset.link_fallback', default: t('mailer.password_reset.link_text', default: 'Or copy this link to your browser:')) %>
  </p>
  <p style="margin: 4px 0 0; font-size: 12px; word-break: break-all;"><%= @reset_url %></p>
</div>
