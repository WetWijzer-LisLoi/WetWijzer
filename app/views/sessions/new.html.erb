<% admin_login = request.subdomain == 'admin' %>
<%= content_for :title, admin_login ? 'Admin Login' : t('auth.login') %>

<div class="min-h-screen flex items-center justify-center bg-gray-50 dark:bg-gray-900 py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-md w-full space-y-8 animate-entrance-stagger">
    <div>
      <% if admin_login %>
        <div class="flex justify-center mb-4">
          <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-semibold tracking-wide capitalize bg-gray-900 dark:bg-gray-700 text-white">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            Admin
          </span>
        </div>
      <% end %>
      <h2 class="mt-2 text-center text-3xl font-extrabold text-gray-900 dark:text-white">
        <%= admin_login ? 'Admin Login' : t('auth.login') %>
      </h2>
      <% unless admin_login %>
        <p class="mt-2 text-center text-sm text-gray-600 dark:text-gray-400">
          <%= t('auth.no_account') %>
          <%= link_to t('auth.signup'), signup_path, class: "font-medium text-(--accent-600) hover:text-(--accent-500)" %>
        </p>
      <% end %>
    </div>

    <% if flash[:notice] %>
      <div class="bg-green-50 dark:bg-green-900/50 border border-green-200 dark:border-green-800 text-green-700 dark:text-green-300 px-4 py-3 rounded-lg">
        <%= flash[:notice] %>
      </div>
    <% end %>

    <% unless admin_login %>
      <% if @unconfirmed_email %>
        <div class="bg-amber-50 dark:bg-amber-900/30 border border-amber-200 dark:border-amber-800 rounded-lg p-4">
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-amber-600 dark:text-amber-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            <div class="flex-1">
              <p class="text-sm font-medium text-amber-800 dark:text-amber-200">
                <%= t('auth.not_confirmed') %>
              </p>
              <p class="text-sm text-amber-700 dark:text-amber-300 mt-1">
                <%= t('auth.confirmation_email_sent') %>
              </p>
              <div class="mt-3">
                <%= form_with url: resend_confirmation_path, method: :post, class: "inline" do %>
                  <input type="hidden" name="email" value="<%= @unconfirmed_email %>">
                  <button type="submit" class="inline-flex items-center gap-1.5 text-sm font-medium text-amber-700 dark:text-amber-300 hover:text-amber-900 dark:hover:text-amber-100 underline underline-offset-2 transition">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                    </svg>
                    <%= t('auth.resend_confirmation') %>
                  </button>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    <% end %>

    <% if flash[:alert] %>
      <div class="bg-red-50 dark:bg-red-900/50 border border-red-200 dark:border-red-800 text-red-700 dark:text-red-300 px-4 py-3 rounded-lg">
        <%= flash[:alert] %>
      </div>
    <% end %>

    <% if @deactivated_email %>
      <div class="bg-amber-50 dark:bg-amber-900/30 border border-amber-200 dark:border-amber-800 rounded-lg p-4">
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-amber-600 dark:text-amber-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
          </svg>
          <div class="flex-1">
            <p class="text-sm font-medium text-amber-800 dark:text-amber-200">
              <%= t('auth.account_disabled_explanation', default: 'Your account is scheduled for deletion.') %>
            </p>
            <div class="mt-3">
              <%= form_with url: reactivate_account_path, method: :post, class: "inline" do %>
                <input type="hidden" name="email" value="<%= @deactivated_email %>">
                <button type="submit" class="inline-flex items-center gap-1.5 text-sm font-medium text-amber-700 dark:text-amber-300 hover:text-amber-900 dark:hover:text-amber-100 underline underline-offset-2 transition">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                  </svg>
                  <%= t('auth.send_reactivation_email', default: 'Send reactivation email') %>
                </button>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <%= form_with url: login_path, method: :post, data: { turbo: false }, class: "mt-8 space-y-6" do |f| %>
      <div class="rounded-md shadow-sm -space-y-px">
        <div>
          <label for="email" class="sr-only"><%= t('auth.email') %></label>
          <input id="email" name="email" type="email" autocomplete="email" required
                 class="appearance-none rounded-none relative block w-full px-3 py-3 border border-gray-300 dark:border-gray-600 placeholder-gray-500 dark:placeholder-gray-400 text-gray-900 dark:text-white bg-white dark:bg-gray-800 rounded-t-md focus:outline-hidden focus:ring-(--accent-500) focus:border-(--accent-500) focus:z-10 sm:text-sm"
                 placeholder="<%= t('auth.email') %>">
        </div>
        <div data-controller="password-visibility" class="relative">
          <label for="password" class="sr-only"><%= t('auth.password') %></label>
          <input id="password" name="password" type="password" autocomplete="current-password" required
                 data-password-visibility-target="input"
                 class="appearance-none rounded-none relative block w-full px-3 py-3 pr-10 border border-gray-300 dark:border-gray-600 placeholder-gray-500 dark:placeholder-gray-400 text-gray-900 dark:text-white bg-white dark:bg-gray-800 rounded-b-md focus:outline-hidden focus:ring-(--accent-500) focus:border-(--accent-500) focus:z-10 sm:text-sm"
                 placeholder="<%= t('auth.password') %>">
          <%= render 'shared/password_toggle' %>
        </div>
      </div>

      <div class="flex items-center justify-between">
        <div class="flex items-center">
          <input id="remember_me" name="remember_me" type="checkbox" value="1"
                 class="h-4 w-4">
          <label for="remember_me" class="ml-2 block text-sm text-gray-700 dark:text-gray-300">
            <%= t('auth.remember_me') %>
          </label>
        </div>
        <%= link_to t('auth.forgot_password'), new_password_reset_path, class: "text-sm text-(--accent-600) hover:text-(--accent-500)" %>
      </div>

      <div>
        <button type="submit"
                class="group relative w-full flex justify-center py-3 px-4 border border-transparent text-sm font-medium rounded-md text-white bg-(--accent-600-solid) hover:bg-(--accent-700-solid) focus:outline-hidden focus:ring-2 focus:ring-offset-2 focus:ring-(--accent-500) transition">
          <span class="absolute left-0 inset-y-0 flex items-center pl-3">
            <svg class="h-5 w-5 text-(--accent-400) group-hover:text-(--accent-400)" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd" />
            </svg>
          </span>
          <%= t('auth.login') %>
        </button>
      </div>
    <% end %>

    <div class="text-center">
      <% if admin_login %>
        <%= link_to 'https://wetwijzer.be', class: "text-sm text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white" do %>
          ← wetwijzer.be
        <% end %>
      <% else %>
        <%= link_to root_path, class: "text-sm text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white" do %>
          ← <%= case I18n.locale when :fr then 'Retour à' when :de then 'Zurück zu' when :en then 'Back to' else 'Terug naar' end %> <%= t('app_title') %>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
