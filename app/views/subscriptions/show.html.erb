<%= content_for :title, t('subscriptions.your_subscription') %>

<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-8 px-4 sm:px-6 lg:px-8">
  <div class="max-w-6xl mx-auto flex flex-col lg:flex-row gap-8">
    <%= render 'layouts/account_sidebar' %>

    <main class="flex-1 min-w-0">

    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg p-6 mb-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-xl font-semibold text-gray-900 dark:text-white">
          <%= t('subscriptions.your_subscription') %>
        </h2>
        <span class="px-3 py-1 text-sm font-medium rounded-full <%= @subscription.pro? ? 'bg-purple-100 text-purple-800 dark:bg-purple-900 dark:text-purple-200' : @subscription.canceled_at ? 'bg-amber-100 text-amber-800 dark:bg-amber-900 dark:text-amber-200' : 'bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300' %>">
          <%= @subscription.pro? ? 'WetWijzer Pro' : @subscription.canceled_at ? (case I18n.locale when :fr then 'Annulé' when :de then 'Gekündigt' when :en then 'Cancelled' else 'Opgezegd' end) : (case I18n.locale when :fr then 'Gratuit' when :de then 'Kostenlos' when :en then 'Free' else 'Gratis' end) %>
        </span>
      </div>

      <dl class="grid grid-cols-2 gap-4">
        <div>
          <dt class="text-sm text-gray-500 dark:text-gray-400"><%= t('subscriptions.current_tier') %></dt>
          <dd class="text-lg font-semibold text-gray-900 dark:text-white capitalize">
            <%= @subscription.pro? ? 'Pro' : (case I18n.locale when :fr then 'Gratuit' when :de then 'Kostenlos' when :en then 'Free' else 'Gratis' end) %>
          </dd>
        </div>
        
        <div>
          <dt class="text-sm text-gray-500 dark:text-gray-400"><%= t('subscriptions.status') %></dt>
          <dd class="text-lg font-semibold">
            <% if @subscription.canceled_at %>
              <%# Cancelled (tier already downgraded to free) %>
              <span class="text-amber-600 dark:text-amber-400">
                <%= case I18n.locale when :fr then 'Annulé' when :de then 'Gekündigt' when :en then 'Cancelled' else 'Opgezegd' end %>
              </span>
            <% elsif @subscription.active? %>
              <span class="text-green-600"><%= case I18n.locale when :fr then 'Actif' when :de then 'Aktiv' when :en then 'Active' else 'Actief' end %></span>
            <% else %>
              <span class="text-red-600"><%= case I18n.locale when :fr then 'Inactif' when :de then 'Inaktiv' when :en then 'Inactive' else 'Inactief' end %></span>
            <% end %>
          </dd>
        </div>

        <% if @subscription.pro? && @subscription.current_period_end %>
          <% days_remaining = (@subscription.current_period_end.to_date - Date.current).to_i %>
          <div class="col-span-2">
            <% if @subscription.canceled_at %>
              <%# ── CANCELLED: show end date prominently ── %>
              <div class="p-3 rounded-lg bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800">
                <dt class="text-sm font-medium text-amber-700 dark:text-amber-300 mb-1">
                  📅 <%= case I18n.locale
                        when :fr then 'Actif jusqu\'au'
                        when :de then 'Aktiv bis'
                        when :en then 'Active until'
                        else 'Actief tot'
                        end %>
                </dt>
                <dd class="text-xl font-bold text-amber-800 dark:text-amber-200">
                  <%= l(@subscription.current_period_end.to_date, format: :long) rescue @subscription.current_period_end.strftime('%d %B %Y') %>
                </dd>
                <p class="text-sm text-amber-600 dark:text-amber-400 mt-1">
                  <% if days_remaining > 1 %>
                    ⏳ <%= case I18n.locale
                          when :fr then "Encore #{days_remaining} jours d'accès Pro"
                          when :de then "Noch #{days_remaining} Tage Pro-Zugang"
                          when :en then "#{days_remaining} days of Pro access remaining"
                          else "Nog #{days_remaining} dagen Pro-toegang"
                          end %>
                  <% elsif days_remaining == 1 %>
                    ⏳ <%= case I18n.locale
                          when :fr then 'Dernier jour d\'accès Pro'
                          when :de then 'Letzter Tag Pro-Zugang'
                          when :en then 'Last day of Pro access'
                          else 'Laatste dag Pro-toegang'
                          end %>
                  <% else %>
                    <%= case I18n.locale
                        when :fr then 'L\'accès Pro expire aujourd\'hui'
                        when :de then 'Pro-Zugang läuft heute ab'
                        when :en then 'Pro access expires today'
                        else 'Pro-toegang verloopt vandaag'
                        end %>
                  <% end %>
                </p>
              </div>
            <% else %>
              <%# ── ACTIVE: show next billing date ── %>
              <dt class="text-sm text-gray-500 dark:text-gray-400">
                <%= case I18n.locale
                    when :fr then 'Prochaine facturation'
                    when :de then 'Nächste Abrechnung'
                    when :en then 'Next billing date'
                    else 'Volgende factuurdatum'
                    end %>
              </dt>
              <dd class="text-lg font-semibold text-gray-900 dark:text-white">
                <%= l(@subscription.current_period_end.to_date, format: :long) rescue @subscription.current_period_end.strftime('%d %B %Y') %>
                <span class="text-sm font-normal text-gray-400 dark:text-gray-500 ml-1">
                  (<%= case I18n.locale
                      when :fr then "dans #{days_remaining} jours"
                      when :de then "in #{days_remaining} Tagen"
                      when :en then "in #{days_remaining} days"
                      else "over #{days_remaining} dagen"
                      end %>)
                </span>
              </dd>
            <% end %>
          </div>
        <% end %>

        <% if Rails.application.config.chatbot_enabled %>
          <div>
            <dt class="text-sm text-gray-500 dark:text-gray-400"><%= t('subscriptions.queries_this_month', default: case I18n.locale when :fr then 'Questions ce mois' when :de then 'Anfragen diesen Monat' when :en then 'Queries this month' else 'Vragen deze maand' end) %></dt>
            <dd class="text-lg font-semibold text-gray-900 dark:text-white"><%= @usage_this_month %></dd>
          </div>
        <% end %>
      </dl>
    </div>

    <% if @subscription.pro? %>
      <!-- Pro Features -->
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg p-6 mb-6">
        <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">
          <svg class="w-5 h-5 text-amber-500 inline" viewBox="0 0 24 24" fill="currentColor"><path d="M5 16L3 5l5.5 5L12 4l3.5 6L21 5l-2 11H5zm0 2h14v1a1 1 0 01-1 1H6a1 1 0 01-1-1v-1z"/></svg>
          Pro <%= case I18n.locale when :fr then 'avantages' when :de then 'Vorteile' when :en then 'benefits' else 'voordelen' end %>
        </h2>
        <ul class="space-y-2 text-sm text-gray-700 dark:text-gray-300">
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-green-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <%= case I18n.locale when :fr then '30 crédits/mois' when :de then '30 Credits/Monat' when :en then '30 credits/month' else '30 credits/maand' end %>
          </li>

          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-green-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <%= case I18n.locale when :fr then 'Modèles AI avancés' when :de then 'Erweiterte KI-Modelle' when :en then 'Advanced AI models' else 'Geavanceerde AI-modellen' end %>
          </li>
        </ul>

        <% if @subscription.active? && !@subscription.canceled_at %>
          <div class="mt-4 pt-4 border-t border-gray-200 dark:border-gray-700">
            <div id="cancel-section">
              <button type="button" id="cancel-show-btn"
                class="text-sm text-red-600 dark:text-red-400 hover:text-red-700 dark:hover:text-red-300 transition-colors cursor-pointer">
                <%= t('subscriptions.cancel_subscription') %>
              </button>

              <div id="cancel-form" style="display: none;" class="mt-3">
                <%= form_with url: cancel_subscription_path, method: :post, local: true, class: "space-y-3" do |f| %>
                  <div>
                    <label for="cancellation_reason" class="block text-sm text-gray-600 dark:text-gray-400 mb-1">
                      <%= t('subscriptions.cancellation_reason_label') %>
                    </label>
                    <textarea name="cancellation_reason" id="cancellation_reason" rows="3"
                      placeholder="<%= t('subscriptions.cancellation_reason_placeholder') %>"
                      class="w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-red-500 focus:border-transparent resize-none"></textarea>
                  </div>
                  <div class="flex items-center gap-3">
                    <button type="submit"
                      data-confirm="<%= case I18n.locale
                        when :fr then "Êtes-vous sûr de vouloir annuler votre abonnement Pro?"
                        when :en then "Are you sure you want to cancel your Pro subscription?"
                        when :de then "Sind Sie sicher, dass Sie Ihr Pro-Abonnement kündigen möchten?"
                        else "Weet u zeker dat u uw Pro-abonnement wilt opzeggen?"
                      end %>"
                      class="px-4 py-2 text-sm bg-red-600 text-white rounded-lg hover:bg-red-700 transition font-medium">
                      <%= t('subscriptions.cancel_subscription') %>
                    </button>
                    <button type="button" id="cancel-dismiss-btn"
                      class="text-sm text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300 transition-colors">
                      <%= t('common.cancel') %>
                    </button>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        <% elsif @subscription.canceled_at %>
          <div class="mt-4 pt-4 border-t border-gray-200 dark:border-gray-700">
            <div class="flex items-center justify-between">
              <p class="text-sm text-gray-600 dark:text-gray-400">
                <%= case I18n.locale
                    when :fr then 'Revenir à Pro ?'
                    when :de then 'Doch Pro bleiben?'
                    when :en then 'Stay Pro?'
                    else 'Toch Pro blijven?'
                    end %>
              </p>
              <%= button_to reactivate_subscription_path, method: :post,
                  class: "px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition text-sm font-medium" do %>
                ✓ <%= t('subscriptions.reactivate') %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <% if @subscription.canceled_at %>
        <!-- Cancelled subscription notice -->
        <div class="bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-lg p-4 mb-4">
          <div class="flex items-center justify-between">
            <p class="text-sm text-amber-700 dark:text-amber-300">
              <%= case I18n.locale
                  when :fr then "Abonnement Pro annulé le #{l(@subscription.canceled_at.to_date, format: :long) rescue @subscription.canceled_at.strftime('%d/%m/%Y')}"
                  when :de then "Pro-Abonnement gekündigt am #{l(@subscription.canceled_at.to_date, format: :long) rescue @subscription.canceled_at.strftime('%d.%m.%Y')}"
                  when :en then "Pro subscription cancelled on #{l(@subscription.canceled_at.to_date, format: :long) rescue @subscription.canceled_at.strftime('%Y-%m-%d')}"
                  else "Pro-abonnement opgezegd op #{l(@subscription.canceled_at.to_date, format: :long) rescue @subscription.canceled_at.strftime('%d/%m/%Y')}"
                  end %>
            </p>
            <p class="text-sm font-medium text-amber-800 dark:text-amber-200">
              <%= case I18n.locale
                  when :fr then 'Revenir à Pro ?'
                  when :de then 'Doch Pro bleiben?'
                  when :en then 'Stay Pro?'
                  else 'Toch Pro blijven?'
                  end %> ↓
            </p>
          </div>
        </div>
      <% end %>
      <!-- Upgrade CTA -->
      <div class="rounded-lg shadow-lg p-6 mb-6 text-white" style="background: var(--accent-600-solid);">
        <h2 class="text-xl font-semibold mb-2 text-white">
          <svg class="w-5 h-5 text-amber-300 inline" viewBox="0 0 24 24" fill="currentColor"><path d="M5 16L3 5l5.5 5L12 4l3.5 6L21 5l-2 11H5zm0 2h14v1a1 1 0 01-1 1H6a1 1 0 01-1-1v-1z"/></svg>
          <%= case I18n.locale when :fr then 'Passez à WetWijzer Pro' when :de then 'Upgrade auf WetWijzer Pro' when :en then 'Upgrade to WetWijzer Pro' else 'Upgrade naar WetWijzer Pro' end %>
        </h2>
        <p class="text-sm mb-4 text-white/80">
          <%= case I18n.locale
            when :fr then '30 crédits/mois et modèles AI avancés.'
            when :de then '30 Credits/Monat und erweiterte KI-Modelle.'
            when :en then '30 credits/month and advanced AI models.'
            else '30 credits/maand en geavanceerde AI-modellen.'
          end %>
        </p>
        <div class="flex items-center gap-4">
          <%= link_to checkout_path('pro'), class: "px-5 py-2.5 bg-white text-blue-800 font-semibold rounded-lg hover:bg-gray-100 transition text-sm shadow-sm" do %>
            <%= case I18n.locale
                when :fr then 'Devenir Pro'
                when :de then 'Pro werden'
                when :en then 'Go Pro'
                else 'Word Pro'
                end %> — €2,99/<%= case I18n.locale when :fr then 'mois' when :de then 'Monat' when :en then 'month' else 'maand' end %>
          <% end %>
        </div>
      </div>
    <% end %>

    </main>
  </div>
</div>

<script nonce="<%= content_security_policy_nonce %>">
  document.addEventListener('DOMContentLoaded', function() {
    var showBtn = document.getElementById('cancel-show-btn');
    var dismissBtn = document.getElementById('cancel-dismiss-btn');
    var cancelForm = document.getElementById('cancel-form');

    if (showBtn && cancelForm) {
      showBtn.addEventListener('click', function() {
        cancelForm.style.display = 'block';
        showBtn.style.display = 'none';
      });
    }
    if (dismissBtn && cancelForm && showBtn) {
      dismissBtn.addEventListener('click', function() {
        cancelForm.style.display = 'none';
        showBtn.style.display = 'inline';
      });
    }
  });
</script>
