<%= content_for :title, t('pricing.title') %>

<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-5xl mx-auto">
    <% if flash[:alert] || flash[:error] %>
      <div class="mb-8 p-4 rounded-lg bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-800 text-red-800 dark:text-red-200 flex items-center gap-3">
        <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" /></svg>
        <span class="text-sm font-medium"><%= flash[:alert] || flash[:error] %></span>
      </div>
    <% end %>
    <% if flash[:notice] %>
      <div class="mb-8 p-4 rounded-lg bg-green-50 dark:bg-green-900/30 border border-green-200 dark:border-green-800 text-green-800 dark:text-green-200 flex items-center gap-3">
        <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        <span class="text-sm font-medium"><%= flash[:notice] %></span>
      </div>
    <% end %>
    <div class="text-center mb-12">
      <h1 class="text-4xl font-bold text-gray-900 dark:text-white mb-4">
        <%= t('pricing.title') %>
      </h1>
      <p class="text-xl text-gray-600 dark:text-gray-400">
        <%= case I18n.locale
            when :fr then 'Commencez gratuitement. Achetez des credits ou abonnez-vous pour plus.'
            when :de then 'Starten Sie kostenlos. Kaufen Sie Credits oder abonnieren Sie fur mehr.'
            when :en then 'Start free. Buy credits or subscribe for more.'
            else 'Start gratis. Koop credits of neem een abonnement voor meer.'
            end %>
      </p>
    </div>

    <!-- Free Weekly Credits Banner -->
    <div class="bg-green-50 dark:bg-green-900/30 border border-green-200 dark:border-green-800 rounded-2xl p-6 mb-12 text-center">
      <div class="flex items-center justify-center gap-3 mb-2">
        <svg class="w-8 h-8 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7"/></svg>
        <h2 class="text-2xl font-bold text-green-800 dark:text-green-200">
          <%= case I18n.locale
              when :fr then '3 credits gratuits par semaine'
              when :de then '3 kostenlose Credits pro Woche'
              when :en then '3 free credits per week'
              else '3 gratis credits per week'
              end %>
        </h2>
      </div>
      <p class="text-green-700 dark:text-green-300">
        <%= case I18n.locale
             when :fr then 'Chaque semaine 3 crédits gratuits pour le chatbot Intelligent. Inscrivez-vous et commencez !'
             when :de then 'Jede Woche 3 kostenlose Credits für Klug KI. Registrieren und loslegen!'
             when :en then 'Every week 3 free credits for Smart AI. Register and start!'
             else 'Elke week 3 gratis credits voor Slim AI. Registreer en begin!'
            end %>
      </p>
      <% unless logged_in? %>
        <%= link_to signup_path, class: "inline-block mt-4 px-6 py-3 bg-green-600 text-white font-semibold rounded-lg hover:bg-green-700 transition" do %>
          <%= case I18n.locale
              when :fr then 'Inscription gratuite'
              when :de then 'Kostenlos registrieren'
              when :en then 'Register free'
              else 'Gratis registreren'
              end %> &rarr;
        <% end %>
      <% end %>
    </div>

    <!-- Two-column: Credit Packs + Pro Subscription -->
    <div class="grid lg:grid-cols-2 gap-8 mb-16">
      
      <!-- LEFT: Credit Packs -->
      <div>
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-2">
          <%= case I18n.locale
              when :fr then 'Packs de credits'
              when :de then 'Credit-Pakete'
              when :en then 'Credit packs'
              else 'Creditpakketten'
              end %>
        </h2>
        <p class="text-gray-600 dark:text-gray-400 mb-6 text-sm">
          <%= case I18n.locale
              when :fr then 'Achetez des credits et utilisez-les quand vous voulez.'
              when :de then 'Kaufen Sie Credits und nutzen Sie sie wann Sie wollen.'
              when :en then 'Buy credits and use them whenever you want.'
              else 'Koop credits en gebruik wanneer u wilt.'
              end %>
        </p>
        
        <div class="space-y-4">
          <% CreditPurchase::PACKAGES.each do |key, info| %>
            <div class="bg-white dark:bg-gray-800 rounded-xl shadow p-5 border border-gray-200 dark:border-gray-700 flex items-center justify-between hover:shadow-lg transition">
              <div>
                <h3 class="font-bold text-gray-900 dark:text-white">
                  <%= t("credits.packages.#{key}.name") %>
                </h3>
                <p class="text-sm text-gray-500 dark:text-gray-400">
                  <%= info[:credits] %> credits
                  <span class="text-xs text-gray-400 dark:text-gray-500">
                    (&euro;<%= format('%.2f', info[:price_cents].to_f / info[:credits] / 100) %>/cr)
                  </span>
                </p>
              </div>
              <div class="text-right">
                <div class="text-2xl font-bold text-(--accent-600) mb-1">
                  &euro;<%= info[:price_cents] >= 100 ? format('%.2f', info[:price_cents] / 100.0) : format('%.2f', info[:price_cents] / 100.0) %>
                </div>
                <% if logged_in? %>
                  <div class="flex flex-col gap-1">
                    <%= button_to credits_purchase_path(package: key), method: :post, data: { turbo: false }, class: "inline-block px-4 py-2 text-sm rounded-lg bg-(--accent-600-solid) text-white font-semibold hover:bg-(--accent-700-solid) transition" do %>
                      <%= case I18n.locale when :fr then 'Acheter' when :de then 'Kaufen' when :en then 'Buy' else 'Kopen' end %>
                    <% end %>
                    <% if ENV['COINGATE_API_TOKEN'].present? %>
                      <%= button_to credits_crypto_purchase_path(package: key), method: :post, data: { turbo: false }, class: "inline-flex items-center justify-center gap-1 px-4 py-1.5 text-xs rounded-lg bg-amber-500 text-white font-semibold hover:bg-amber-600 transition" do %>
                        ₿ Crypto
                      <% end %>
                    <% end %>
                  </div>
                <% else %>
                  <%= link_to signup_path, class: "inline-block px-4 py-2 text-sm rounded-lg bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 font-semibold hover:bg-gray-300 dark:hover:bg-gray-600 transition" do %>
                    <%= case I18n.locale when :fr then "S'inscrire" when :de then 'Registrieren' when :en then 'Sign up' else 'Registreren' end %>
                  <% end %>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>

        </div>

      <!-- RIGHT: Pro Subscription -->
      <div>
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-2">
          WetWijzer Pro
        </h2>
        <p class="text-gray-600 dark:text-gray-400 mb-6 text-sm">
          <%= case I18n.locale
              when :fr then 'Soutenez le projet et profitez d\'avantages exclusifs.'
              when :de then 'Unterstützen Sie das Projekt und genießen Sie exklusive Vorteile.'
              when :en then 'Support the project and enjoy exclusive benefits.'
              else 'Steun het project en geniet van extra voordelen.'
              end %>
        </p>

        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg p-6 border-2 border-(--accent-500)">
          <div class="mb-4">
            <span class="inline-block bg-(--accent-600-solid) text-white text-xs font-bold px-3 py-1 rounded-full mb-3">
              <%= case I18n.locale when :fr then 'Recommandé' when :de then 'Empfohlen' when :en then 'Recommended' else 'Aanbevolen' end %>
            </span>
            <div class="flex items-baseline gap-1">
              <span class="text-4xl font-bold text-(--accent-600)">&euro;2,99</span>
              <span class="text-gray-500 dark:text-gray-400">/<%= case I18n.locale when :fr then 'mois' when :de then 'Monat' when :en then 'month' else 'maand' end %></span>
            </div>
          </div>

          <ul class="text-sm text-gray-600 dark:text-gray-400 space-y-3 mb-6">
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-green-500 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              <span><strong>30 credits/<%= case I18n.locale when :fr then 'mois' when :de then 'Monat' when :en then 'month' else 'maand' end %></strong> <%= case I18n.locale when :fr then 'inclus' when :de then 'inklusive' when :en then 'included' else 'inbegrepen' end %></span>
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-green-500 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              <span><strong><%= case I18n.locale when :fr then 'Tous les modèles AI' when :de then 'Alle AI-Modelle' when :en then 'All AI models' else 'Alle AI-modellen' end %></strong> — <%= case I18n.locale when :fr then 'chaque niveau de raisonnement' when :de then 'jede Denkstufe' when :en then 'every reasoning level' else 'elk redeneerniveau' end %></span>
            </li>

            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-green-500 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              <span><strong><%= case I18n.locale when :fr then 'Réduction ~25%' when :de then '~25% Rabatt' when :en then '~25% discount' else '~25% korting' end %></strong> — <%= case I18n.locale when :fr then 'sur les packs de crédits supplémentaires' when :de then 'auf zusätzliche Credit-Pakete' when :en then 'on extra credit packs' else 'op extra creditpakketten' end %></span>
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-red-400 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"/></svg>
              <span><strong><%= case I18n.locale when :fr then 'Soutenez WetWijzer' when :de then 'Unterstützen Sie WetWijzer' when :en then 'Support WetWijzer' else 'Steun WetWijzer' end %></strong> — <%= case I18n.locale when :fr then 'aidez-nous à rester indépendant et gratuit' when :de then 'helfen Sie uns unabhängig und kostenlos zu bleiben' when :en then 'help us stay independent and free' else 'help ons onafhankelijk en gratis te blijven' end %></span>
            </li>
          </ul>

          <% if logged_in? && current_user.pro? %>
            <div class="block w-full py-3 px-4 text-center rounded-lg bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-300 font-semibold">
              <%= case I18n.locale when :fr then 'Abonnement actif' when :de then 'Abonnement aktiv' when :en then 'Active subscription' else 'Abonnement actief' end %>
              <p class="text-xs font-normal mt-1 text-green-600 dark:text-green-400">
                <%= case I18n.locale
                    when :fr then 'Merci de soutenir notre projet !'
                    when :de then 'Danke für Ihre Unterstützung!'
                    when :en then 'Thank you for supporting our project!'
                    else 'Bedankt voor uw steun!'
                    end %>
              </p>
            </div>
          <% elsif logged_in? %>
            <%= link_to checkout_path(tier: 'pro'), data: { turbo: false }, class: "block w-full py-3 px-4 text-center rounded-lg bg-(--accent-600-solid) text-white font-semibold hover:bg-(--accent-700-solid) transition" do %>
              <%= case I18n.locale when :fr then "S'abonner" when :de then 'Abonnieren' when :en then 'Subscribe' else 'Abonneren' end %>
            <% end %>
            <% if ENV['COINGATE_API_TOKEN'].present? %>
              <%= link_to crypto_checkout_path(tier: 'pro'), data: { turbo: false }, class: "block w-full mt-2 py-2.5 px-4 text-center rounded-lg bg-amber-500 text-white font-semibold hover:bg-amber-600 transition text-sm" do %>
                ₿ <%= case I18n.locale when :fr then 'Payer avec Crypto' when :de then 'Mit Krypto bezahlen' when :en then 'Pay with Crypto' else 'Betaal met Crypto' end %>
              <% end %>
            <% end %>
          <% else %>
            <%= link_to signup_path, class: "block w-full py-3 px-4 text-center rounded-lg bg-(--accent-600-solid) text-white font-semibold hover:bg-(--accent-700-solid) transition" do %>
              <%= case I18n.locale when :fr then 'Inscription gratuite' when :de then 'Kostenlos registrieren' when :en then 'Register free' else 'Gratis registreren' end %>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>

    <!-- AI Models & Tiers — Comprehensive Overview -->
    <div class="mb-16">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-2 text-center">
        <%= case I18n.locale when :fr then 'Modèles AI par niveau' when :de then 'AI-Modelle pro Stufe' when :en then 'AI models per tier' else 'AI-modellen per niveau' end %>
      </h2>
      <p class="text-center text-sm text-gray-500 dark:text-gray-400 mb-8">
        <%= case I18n.locale
            when :fr then '10 modèles, 3 fournisseurs, 100% traitement dans l\'UE'
            when :de then '10 Modelle, 3 Anbieter, 100% EU-Verarbeitung'
            when :en then '10 models, 3 providers, 100% EU processing'
            else '10 modellen, 3 providers, 100% EU-verwerking'
            end %>
      </p>

      <div class="grid md:grid-cols-2 gap-6">
        <%# ── SMART TIER ── %>
        <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-lg border border-gray-200 dark:border-gray-700 overflow-hidden">
          <div class="px-6 py-4 bg-gradient-to-r from-emerald-50 to-teal-50 dark:from-emerald-900/20 dark:to-teal-900/20 border-b border-gray-200 dark:border-gray-700">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-3">
                <span class="text-2xl">⚡</span>
                <div>
                  <h3 class="font-bold text-gray-900 dark:text-white text-lg">
                    <%= case I18n.locale when :fr then 'Intelligent' when :de then 'Klug' when :en then 'Smart' else 'Slim' end %>
                  </h3>
                  <p class="text-xs text-gray-500 dark:text-gray-400">
                    <%= case I18n.locale when :fr then 'Rapide & fiable' when :de then 'Schnell & zuverlässig' when :en then 'Fast & reliable' else 'Snel & betrouwbaar' end %>
                  </p>
                </div>
              </div>
              <div class="text-right">
                <div class="text-sm font-bold text-emerald-700 dark:text-emerald-300">1 credit</div>
                <div class="text-xs text-gray-500 dark:text-gray-400">4.1/5</div>
              </div>
            </div>
          </div>
          <div class="px-6 py-4 space-y-3">
            <%# Mistral Small — FREE %>
            <div class="flex items-center justify-between py-2">
              <div class="flex items-center gap-3">
                <span class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-emerald-100 dark:bg-emerald-900/40 text-sm font-bold text-emerald-700 dark:text-emerald-300">M</span>
                <div>
                  <div class="font-semibold text-sm text-gray-900 dark:text-white">Mistral Small</div>
                  <div class="text-xs text-gray-500 dark:text-gray-400 flex items-center gap-1">
                    <span class="inline-block w-3 h-2 rounded-sm bg-blue-600"></span> EU
                  </div>
                </div>
              </div>
              <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-[10px] font-bold bg-emerald-100 text-emerald-700 dark:bg-emerald-900/40 dark:text-emerald-300">
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                <%= case I18n.locale when :fr then 'Gratuit' when :de then 'Kostenlos' when :en then 'Free' else 'Gratis' end %>
              </span>
            </div>
            <%# Mistral Large 3 — Free (2cr) %>
            <div class="flex items-center justify-between py-2 border-t border-gray-100 dark:border-gray-700/50">
              <div class="flex items-center gap-3">
                <span class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-teal-100 dark:bg-teal-900/40 text-sm font-bold text-teal-700 dark:text-teal-300">M</span>
                <div>
                  <div class="font-semibold text-sm text-gray-900 dark:text-white">Mistral Large 3</div>
                  <div class="text-xs text-gray-500 dark:text-gray-400 flex items-center gap-1">
                    <span class="inline-block w-3 h-2 rounded-sm bg-blue-600"></span> EU
                  </div>
                </div>
              </div>
              <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-[10px] font-bold bg-teal-100 text-teal-700 dark:bg-teal-900/40 dark:text-teal-300">
                2 credits
              </span>
            </div>
            <%# GPT-5 Mini — Credits %>
            <div class="flex items-center justify-between py-2 border-t border-gray-100 dark:border-gray-700/50">
              <div class="flex items-center gap-3">
                <span class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-blue-100 dark:bg-blue-900/40 text-sm font-bold text-blue-700 dark:text-blue-300">G</span>
                <div>
                  <div class="font-semibold text-sm text-gray-900 dark:text-white">GPT-5 Mini</div>
                  <div class="text-xs text-gray-500 dark:text-gray-400 flex items-center gap-1">
                    <span class="inline-block w-3 h-2 rounded-sm bg-blue-600"></span> Azure EU
                  </div>
                </div>
              </div>
              <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-[10px] font-bold bg-blue-100 text-blue-700 dark:bg-blue-900/40 dark:text-blue-300">
                <%= case I18n.locale when :fr then 'Crédits' when :de then 'Credits' when :en then 'Credits' else 'Credits' end %>
              </span>
            </div>
          </div>
        </div>

        <%# ── GENIUS TIER ── %>
        <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-lg border-2 border-(--accent-500) overflow-hidden relative">
          <div class="absolute top-3 right-3">
            <span class="inline-block bg-(--accent-600-solid) text-white text-[10px] font-bold px-2 py-0.5 rounded-full">
              <%= case I18n.locale when :fr then 'Recommandé' when :de then 'Empfohlen' when :en then 'Recommended' else 'Aanbevolen' end %>
            </span>
          </div>
          <div class="px-6 py-4 bg-gradient-to-r from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 border-b border-gray-200 dark:border-gray-700">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-3">
                <span class="text-2xl">⭐</span>
                <div>
                  <h3 class="font-bold text-gray-900 dark:text-white text-lg">
                    <%= case I18n.locale when :fr then 'Génial' when :de then 'Genial' when :en then 'Genius' else 'Geniaal' end %>
                  </h3>
                  <p class="text-xs text-gray-500 dark:text-gray-400">
                    <%= case I18n.locale when :fr then 'Analyse approfondie' when :de then 'Tiefgehende Analyse' when :en then 'Deep analysis' else 'Diepgaande analyse' end %>
                  </p>
                </div>
              </div>
              <div class="text-right">
                <div class="text-sm font-bold text-(--accent-600)">3 credits</div>
                <div class="text-xs text-gray-500 dark:text-gray-400">4.3/5</div>
              </div>
            </div>
          </div>
          <div class="px-6 py-4 space-y-3">
            <%# o4-mini %>
            <div class="flex items-center justify-between py-2">
              <div class="flex items-center gap-3">
                <span class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-violet-100 dark:bg-violet-900/40 text-sm font-bold text-violet-700 dark:text-violet-300">O</span>
                <div>
                  <div class="font-semibold text-sm text-gray-900 dark:text-white">o4-mini <span class="text-[10px] text-gray-400 dark:text-gray-500">(Reasoning)</span></div>
                  <div class="text-xs text-gray-500 dark:text-gray-400 flex items-center gap-1">
                    <span class="inline-block w-3 h-2 rounded-sm bg-blue-600"></span> Azure EU
                  </div>
                </div>
              </div>
              <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-[10px] font-bold bg-blue-100 text-blue-700 dark:bg-blue-900/40 dark:text-blue-300">
                <%= case I18n.locale when :fr then 'Crédits' when :de then 'Credits' when :en then 'Credits' else 'Credits' end %>
              </span>
            </div>
            <%# Claude 4.5 Haiku %>
            <div class="flex items-center justify-between py-2 border-t border-gray-100 dark:border-gray-700/50">
              <div class="flex items-center gap-3">
                <span class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-orange-100 dark:bg-orange-900/40 text-sm font-bold text-orange-700 dark:text-orange-300">C</span>
                <div>
                  <div class="font-semibold text-sm text-gray-900 dark:text-white">Claude 4.5 Haiku</div>
                  <div class="text-xs text-gray-500 dark:text-gray-400 flex items-center gap-1">
                    <span class="inline-block w-3 h-2 rounded-sm bg-blue-600"></span> AWS EU
                  </div>
                </div>
              </div>
              <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-[10px] font-bold bg-blue-100 text-blue-700 dark:bg-blue-900/40 dark:text-blue-300">
                <%= case I18n.locale when :fr then 'Crédits' when :de then 'Credits' when :en then 'Credits' else 'Credits' end %>
              </span>
            </div>
          </div>
        </div>

