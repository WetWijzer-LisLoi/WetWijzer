<% if classic_host? %>
<%= render 'laws/classic_show' %>
<% else %>
<% if @law.present? %>
<script type="application/ld+json">
<%= raw({
  "@context": "https://schema.org",
  "@type": "Legislation",
  "name": strip_tags(@law.title.to_s).truncate(500),
  "legislationIdentifier": @law.numac,
  "inLanguage": @language_id == 1 ? "nl" : "fr",
  "legislationDate": @law.date.presence,
  "url": request.original_url.split('?').first,
  "publisher": {
    "@type": "GovernmentOrganization",
    "name": "Belgisch Staatsblad / Moniteur Belge",
    "url": "https://www.ejustice.just.fgov.be"
  },
  "isPartOf": {
    "@type": "WebSite",
    "name": site_name,
    "url": root_url
  }
}.compact.to_json) %>
</script>
<% end %>

<% if @law.present? %>
  <meta name="chatbot-context" data-context-type="law" data-law-title="<%= strip_tags(@law.title.to_s).truncate(200) %>" data-law-numac="<%= @law.numac %>" data-law-url="<%= law_path(@law) %>">
<% end %>
<% if @is_fisconet %>
  <%= render 'laws/fisconet_show' %>
<% else %>
<!-- Page Header -->
<div class="mb-0" data-controller="articles-loading" data-articles-loading-frame-value="law_articles">
  <div class="bg-linear-to-r from-(--accent-500)/5 to-(--accent-500)/10 dark:from-(--accent-500)/10 dark:to-(--accent-500)/20 rounded-xl px-4 py-2 md:px-6 md:py-3">
    <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between md:gap-4">
      <div class="flex items-center gap-3">
        <h1 class="text-xl md:text-2xl font-extrabold tracking-tight text-gray-900 dark:text-(--accent-500)">
          <%= t(:details).capitalize() %>
        </h1>
        <%# Loading indicator - shown while articles turbo frame is loading %>
        <div data-articles-loading-target="indicator" class="inline-flex items-center gap-2 px-2 py-1 md:px-3 md:py-1.5 text-xs md:text-sm font-medium rounded-lg bg-(--accent-500)/10 text-(--accent-700) dark:text-(--accent-300) border border-(--accent-500)/20">
          <svg class="animate-spin h-3 w-3 md:h-4 md:w-4 no-print" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          <span class="hidden sm:inline no-print"><%= t('articles.loading_articles', default: 'Artikelen laden...') %></span>
          <%# Print warning - only visible in print when articles still loading %>
          <span class="print-loading-warning"><%= case I18n.locale when :fr then "ATTENTION: Les articles sont encore en cours de chargement. Veuillez attendre que tous les articles soient chargés avant d'imprimer." when :de then 'ACHTUNG: Artikel werden noch geladen. Bitte warten Sie, bis alle Artikel geladen sind, bevor Sie drucken.' when :en then 'WARNING: Articles are still loading. Please wait until all articles are loaded before printing.' else 'LET OP: Artikelen worden nog geladen. Wacht tot alle artikelen geladen zijn voordat u afdrukt.' end %></span>
        </div>
      </div>
      <div class="flex flex-wrap items-center gap-2 no-print">
        <%# Language switch link %>
        <% other_language_id = @language_id == 1 ? 2 : 1 %>
        <%= link_to law_path(@law, language_id: other_language_id),
                    class: "inline-flex items-center gap-1.5 px-2 py-1.5 md:px-3 text-xs md:text-sm font-medium rounded-lg text-(--accent-700) dark:text-(--accent-300) hover:bg-(--accent-500)/10 border border-(--accent-500)/20 transition-colors duration-150",
                    title: case I18n.locale when :fr then (@language_id == 1 ? "Voir la version française" : "Voir la version néerlandaise") when :de then (@language_id == 1 ? "Französische Version anzeigen" : "Niederländische Version anzeigen") when :en then (@language_id == 1 ? "View French version" : "View Dutch version") else (@language_id == 1 ? "Bekijk de Franstalige versie" : "Bekijk de Nederlandstalige versie") end do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129" />
          </svg>
          <span class="hidden sm:inline"><%= @language_id == 1 ? 'FR' : 'NL' %></span>
        <% end %>
        <%# Side by side comparison link %>
        <%= link_to compare_law_path(@law),
                    class: "inline-flex items-center gap-1.5 px-2 py-1.5 md:px-3 text-xs md:text-sm font-medium rounded-lg text-(--accent-700) dark:text-(--accent-300) hover:bg-(--accent-500)/10 border border-(--accent-500)/20 transition-colors duration-150",
                    title: case I18n.locale when :fr then "Comparer NL et FR côte à côte" when :de then "NL und FR nebeneinander vergleichen" when :en then "Compare NL and FR side by side" else "NL en FR naast elkaar vergelijken" end do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2" />
          </svg>
          <span class="hidden sm:inline"><%= case I18n.locale when :fr then 'Comparer' when :de then 'Vergleichen' when :en then 'Compare' else 'Vergelijk' end %></span>
        <% end %>
        <%# Print button %>
        <button type="button"
                id="print-law-btn"
                class="inline-flex items-center gap-1.5 px-2 py-1.5 md:px-3 text-xs md:text-sm font-medium rounded-lg text-(--accent-700) dark:text-(--accent-300) hover:bg-(--accent-500)/10 border border-(--accent-500)/20 transition-colors duration-150"
                title="<%= case I18n.locale when :fr then 'Imprimer' when :de then 'Drucken' when :en then 'Print' else 'Afdrukken' end %>">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M5 4v3H4a2 2 0 00-2 2v3a2 2 0 002 2h1v2a2 2 0 002 2h6a2 2 0 002-2v-2h1a2 2 0 002-2V9a2 2 0 00-2-2h-1V4a2 2 0 00-2-2H7a2 2 0 00-2 2zm8 0H7v3h6V4zm0 8H7v4h6v-4z" clip-rule="evenodd"/>
          </svg>
        </button>
        <%# Bookmark button %>
        <button type="button"
                class="bookmark-btn inline-flex items-center gap-1.5 px-2 py-1.5 md:px-3 text-xs md:text-sm font-medium rounded-lg text-(--accent-700) dark:text-(--accent-300) hover:bg-(--accent-500)/10 border border-(--accent-500)/20 transition-colors duration-150"
                data-controller="bookmark"
                data-bookmark-numac-value="<%= @law.numac %>"
                data-bookmark-title-value="<%= escape_once(@law.title.to_s.truncate(200)) %>"
                data-action="click->bookmark#toggle"
                title="<%= t('bookmarks.add') %>">
          <svg data-bookmark-target="icon" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z" />
          </svg>
        </button>
        <%# Copy reference dropdown %>
        <div class="relative" 
             data-controller="copy-reference"
             data-copy-reference-numac-value="<%= @law.numac %>"
             data-copy-reference-title-value="<%= escape_once(@law.title.to_s) %>"
             data-copy-reference-date-value="<%= @law.content&.publication_date %>">
          <button type="button"
                  class="inline-flex items-center gap-1.5 px-2 py-1.5 md:px-3 text-xs md:text-sm font-medium rounded-lg text-(--accent-700) dark:text-(--accent-300) hover:bg-(--accent-500)/10 border border-(--accent-500)/20 transition-colors duration-150"
                  data-copy-reference-target="button"
                  data-action="click->copy-reference#toggle"
                  aria-haspopup="true"
                  aria-expanded="false"
                  title="<%= t('copy_reference.title') %>">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
            </svg>
          </button>
          <div data-copy-reference-target="menu"
               class="hidden absolute right-0 mt-1 w-48 rounded-md shadow-sm bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 z-50">
            <div class="py-1">
              <button type="button" class="w-full text-left px-4 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-(--accent-active-bg)" data-action="click->copy-reference#copyFull"><%= t('copy_reference.full') %></button>
              <button type="button" class="w-full text-left px-4 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-(--accent-active-bg)" data-action="click->copy-reference#copyNumac"><%= t('copy_reference.numac') %></button>
              <button type="button" class="w-full text-left px-4 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-(--accent-active-bg)" data-action="click->copy-reference#copyUrl"><%= t('copy_reference.url') %></button>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</div>

<!-- Main Content Layout -->
<div data-controller="sidebar-toggle toc-anchor" class="w-full pb-24 md:pb-0">
  <!-- Shelf handle is used for all sizes; mobile floating buttons are available -->
  <!-- Mobile backdrop for sidebar -->
  <div data-sidebar-toggle-target="backdrop" class="hidden fixed inset-0 bg-black/30 z-30 md:hidden"></div>
  
  <!-- Mobile-only fixed bottom bar with 3 equal buttons [Go to, Inhoud, Chat] -->
  <div class="md:hidden fixed bottom-0 inset-x-0 z-50 no-print" id="mobile-bottom-bar">
    <div class="flex items-stretch bg-white/95 dark:bg-gray-900/95 backdrop-blur border-t border-gray-200 dark:border-gray-700 shadow-[0_-2px_10px_rgba(0,0,0,0.08)]">
      <!-- Go to… jump menu (opens upward) -->
      <div id="mobile-jump" data-controller="jump-select" data-jump-select-fallback-value="true" class="relative flex-1 overflow-visible">
        <button type="button"
                class="w-full flex flex-col items-center justify-center gap-1 py-2.5 text-gray-600 dark:text-gray-400 hover:text-(--accent-600) dark:hover:text-(--accent-400) transition-colors duration-150"
                data-action="jump-select#toggle"
                data-jump-select-target="button"
                aria-haspopup="true" aria-expanded="false"
                aria-label="<%= t(:go_to, default: 'Ga naar…') %>">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5">
            <path fill-rule="evenodd" d="M10 3a1 1 0 01.894.553l2 4A1 1 0 0112 9H8a1 1 0 01-.894-1.447l2-4A1 1 0 0110 3zm-3 8a1 1 0 000 2h6a1 1 0 100-2H7zm-2 4a1 1 0 000 2h10a1 1 0 100-2H5z" clip-rule="evenodd" />
          </svg>
          <span class="text-[10px] font-medium leading-none"><%= t(:go_to, default: 'Ga naar') %></span>
        </button>
        <div data-jump-select-target="menu"
             class="hidden absolute bottom-full left-0 mb-2 z-999 w-56 rounded-md shadow-sm ring-1 ring-black/10 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 focus:outline-hidden"
             role="menu" aria-orientation="vertical">
          <div class="py-1">
            <button type="button" role="menuitem" class="w-full text-left px-4 py-2 text-sm text-gray-700 dark:text-gray-300 transition-colors duration-150 ease-out motion-reduce:transition-none hover:bg-(--accent-active-bg)" data-action="jump-select#go" data-target="#external-links-card"><%= t(:external_links).capitalize %></button>
            <button type="button" role="menuitem" class="w-full text-left px-4 py-2 text-sm text-gray-700 dark:text-gray-300 transition-colors duration-150 ease-out motion-reduce:transition-none hover:bg-(--accent-active-bg)" data-action="jump-select#go" data-target="#document-info-card"><%= t(:document_info) %></button>
            <button type="button" role="menuitem" class="w-full text-left px-4 py-2 text-sm text-gray-700 dark:text-gray-300 transition-colors duration-150 ease-out motion-reduce:transition-none hover:bg-(--accent-active-bg)" data-action="jump-select#go" data-target="#title-card"><%= t(:title_details).capitalize %></button>
            <button type="button" role="menuitem" class="w-full text-left px-4 py-2 text-sm text-gray-700 dark:text-gray-300 transition-colors duration-150 ease-out motion-reduce:transition-none hover:bg-(--accent-active-bg)" data-action="jump-select#go" data-target="#main-toc-card"><%= t(:toc).capitalize %></button>
            <% if @updated_laws.present? %>
              <button type="button" role="menuitem" class="w-full text-left px-4 py-2 text-sm text-gray-700 dark:text-gray-300 transition-colors duration-150 ease-out motion-reduce:transition-none hover:bg-(--accent-active-bg)" data-action="jump-select#go" data-target="#updated-laws-card"><%= t(:updates) %></button>
            <% end %>
            <% if @exdecs.present? %>
              <button type="button" role="menuitem" class="w-full text-left px-4 py-2 text-sm text-gray-700 dark:text-gray-300 transition-colors duration-150 ease-out motion-reduce:transition-none hover:bg-(--accent-active-bg)" data-action="jump-select#go" data-target="#exdecs-card"><%= t(:exdecs_title) %></button>
            <% end %>
            <button type="button" role="menuitem" class="w-full text-left px-4 py-2 text-sm text-gray-700 dark:text-gray-300 transition-colors duration-150 ease-out motion-reduce:transition-none hover:bg-(--accent-active-bg)" data-action="jump-select#go" data-target="#tekst"><%= t(:articles_text).capitalize %></button>
          </div>
        </div>
      </div>

      <!-- TOC / Inhoud toggle -->
      <% if @content.present? && @content.toc.present? %>
        <button type="button"
                class="flex-1 flex flex-col items-center justify-center gap-1 py-2.5 text-gray-600 dark:text-gray-400 hover:text-(--accent-600) dark:hover:text-(--accent-400) border-x border-gray-200 dark:border-gray-700 transition-colors duration-150"
                data-sidebar-toggle-target="button"
                data-sidebar-toggle-floating
                data-action="sidebar-toggle#toggle"
                aria-controls="toc-sidebar-panel"
                aria-label="<%= t('aria.open_sidebar') %>">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
            <path fill-rule="evenodd" d="M3.75 6.75a.75.75 0 01.75-.75h15a.75.75 0 010 1.5H4.5a.75.75 0 01-.75-.75zm0 5.25a.75.75 0 01.75-.75h15a.75.75 0 010 1.5H4.5a.75.75 0 01-.75-.75z" clip-rule="evenodd" />
          </svg>
          <span class="text-[10px] font-medium leading-none"><%= t(:toc, default: 'Inhoud') %></span>
        </button>
      <% end %>

      <!-- Chatbot trigger (replaces the floating FAB on mobile) -->
      <% if Rails.application.config.chatbot_enabled %>
        <button type="button" id="mobile-chat-btn"
                class="flex-1 flex flex-col items-center justify-center gap-1 py-2.5 text-(--accent-600) dark:text-(--accent-400) hover:text-(--accent-700) dark:hover:text-(--accent-300) transition-colors duration-150"
                data-chatbot-toggle
                aria-label="<%= case I18n.locale when :fr then 'Ouvrir le chatbot' when :de then 'Chatbot öffnen' else 'Chatbot openen' end %>">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/>
          </svg>
          <span class="text-[10px] font-medium leading-none">Chat</span>
        </button>
      <% end %>
    </div>
  </div>
  
  <div class="flex flex-col md:flex-row gap-8 w-full">
  <!-- Sidebar with TOC (left) -->
  <% if @content.present? && @content.toc.present? %>
    <div id="toc-sidebar-panel" data-sidebar-toggle-target="panel" class="hidden fixed inset-y-0 left-0 z-40 w-80 max-w-[85vw] transform -translate-x-full transition-transform duration-300 ease-in-out motion-reduce:transition-none p-2 md:p-0 order-2 md:order-1 md:static md:inset-auto md:z-auto md:w-80 md:min-w-80 md:max-w-80 md:shrink-0 md:sticky md:top-0 md:self-start pr-2 md:pr-0 space-y-6">

      <!-- Table of Contents -->
      <div id="toc-card-sidebar" class="relative bg-white dark:bg-gray-800 rounded-xl shadow-sm" data-controller="sidebar-auto-open">
        <!-- Sidebar handle: full-height clickable area on the right edge -->
        <button type="button"
                class="hidden md:flex items-center justify-center absolute top-0 right-0 z-1002 w-8 h-full rounded-none rounded-r-xl border-0 shadow-none bg-transparent text-gray-500 hover:text-gray-700 dark:text-(--accent-500)/60 dark:hover:text-(--accent-500) transition-colors duration-200 ease-out motion-reduce:transition-none hover:bg-transparent active:bg-transparent cursor-pointer"
                data-sidebar-toggle-target="button"
                data-action="sidebar-toggle#toggle"
                aria-controls="toc-sidebar-panel"
                aria-label="<%= t('aria.toggle_sidebar') %>">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 transition-transform duration-300 ease-in-out motion-reduce:transition-none" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" data-sidebar-toggle-arrow>
            <rect x="9" y="6" width="2" height="12" rx="1"></rect>
            <rect x="13" y="6" width="2" height="12" rx="1"></rect>
          </svg>
        </button>
        <%= render 'toc', content: @content, articles: @articles, hide_header: false, scrollable: true, track: true %>
      </div>
    </div>
  <% end %>

  <!-- Main Content Area -->
  <div class="flex-1 min-w-0 space-y-6 order-1 md:order-2">
    <!-- Print-only consultation date header -->
    <div class="print-only-header hidden print:block text-sm text-gray-600 mb-4">
      <%= case I18n.locale when :fr then 'Consulté le' when :de then 'Abgerufen am' when :en then 'Accessed on' else 'Geraadpleegd op' end %>: <%= Date.today.strftime('%d-%m-%Y') %>
    </div>

    <!-- External Links -->
    <div id="external-links-card" class="no-print bg-white dark:bg-gray-800 rounded-xl shadow-sm scroll-mt-24">
      <%= render 'external_links', law: @law %>
    </div>

    <!-- Related Sources (Parliamentary Work, Jurisprudence) - lazy-loaded on button click -->
    <div id="related-sources-card" class="no-print bg-white dark:bg-gray-800 rounded-xl shadow-sm scroll-mt-24">
      <div class="p-4 md:p-6">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-(--accent-500) mb-3">
          <%= case I18n.locale when :fr then 'Sources connexes' when :de then 'Verwandte Quellen' when :en then 'Related sources' else 'Gerelateerde bronnen' end %>
        </h2>
        <div class="flex flex-wrap gap-2">
          <!-- Parliamentary Work Button -->
          <button type="button" id="btn-load-parliamentary"
                  data-source-type="parliamentary"
                  class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium rounded-lg border border-purple-300 dark:border-purple-600 text-purple-700 dark:text-purple-300 bg-purple-50 dark:bg-purple-900/20 hover:bg-purple-100 dark:hover:bg-purple-900/40 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
            </svg>
            <%= case I18n.locale when :fr then 'Travaux préparatoires' when :de then 'Parlamentarische Vorarbeiten' else 'Parlementaire voorbereidingen' end %>
          </button>
          <%# Jurisprudence button (public since June 2026) %>
          <button type="button" id="btn-load-jurisprudence"
                  data-source-type="jurisprudence"
                  class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium rounded-lg border border-amber-300 dark:border-amber-600 text-amber-700 dark:text-amber-300 bg-amber-50 dark:bg-amber-900/20 hover:bg-amber-100 dark:hover:bg-amber-900/40 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"/>
            </svg>
            <%= case I18n.locale when :fr then 'Jurisprudence' when :de then 'Rechtsprechung' else 'Rechtspraak' end %>
          </button>
        </div>
      </div>
      <div id="parliamentary-content" class="hidden"></div>
      <div id="jurisprudence-content" class="hidden"></div>
    </div>

    <script nonce="<%= content_security_policy_nonce %>">
      function loadRelatedSource(type, btn) {
        var container = document.getElementById(type + '-content');
        if (!container) return;

        // If already loaded, just toggle visibility
        if (container.dataset.loaded === 'true') {
          container.classList.toggle('hidden');
          return;
        }

        // Show loading state
        btn.disabled = true;
        var origHTML = btn.innerHTML;
        btn.innerHTML = '<svg class="animate-spin h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> <%= case I18n.locale when :fr then 'Chargement…' when :de then 'Laden…' when :en then 'Loading…' else 'Laden…' end %>';

        fetch('<%= related_sources_law_path(@law.numac, language_id: @language_id) %>&type=' + type, {
          headers: { 'Accept': 'text/html' }
        })
        .then(function(r) { if (!r.ok) throw new Error('HTTP ' + r.status); return r.text(); })
        .then(function(html) {
          container.innerHTML = html;
          container.dataset.loaded = 'true';
          container.classList.remove('hidden');
          btn.innerHTML = origHTML;
          btn.disabled = false;
        })
        .catch(function() {
          container.innerHTML = '<div class="px-4 pb-4 text-sm text-red-600 dark:text-red-400"><%= case I18n.locale when :fr then "Échec du chargement" when :de then "Laden fehlgeschlagen" when :en then "Loading failed" else "Laden mislukt" end %></div>';
          container.classList.remove('hidden');
          btn.innerHTML = origHTML;
          btn.disabled = false;
        });
      }

      // Bind buttons via event listeners (CSP-compliant, no inline onclick)
      // Print button (CSP-compliant)
      var printBtn = document.getElementById('print-law-btn');
      if (printBtn) printBtn.addEventListener('click', function() { window.print(); });

      document.querySelectorAll('[data-source-type]').forEach(function(btn) {
        btn.addEventListener('click', function() {
          loadRelatedSource(this.dataset.sourceType, this);
        });
      });
    </script>

    <!-- Document Metadata -->
    <div id="document-info-card" class="bg-white dark:bg-gray-800 rounded-xl shadow-sm scroll-mt-24">
      <%= render 'document_metadata', law: @law, content: @content %>
    </div>

    <!-- Document Title -->
    <div id="title-card" class="bg-white dark:bg-gray-800 rounded-xl shadow-sm scroll-mt-24">
      <%= render 'title', law: @law %>
    </div>
 
    <!-- Static TOC section under Title (always visible, collapsible) -->
    <% if @content.present? && @content.toc.present? %>
    <div id="main-toc-card" class="bg-white dark:bg-gray-800 rounded-xl shadow-sm scroll-mt-24">
      <%= render 'toc', content: @content, articles: @articles, hide_header: false, scrollable: false, track: false, variant: :main %>
    </div>
    <% end %>
    
    <!-- Updated Laws -->
    <% if @updated_laws.present? %>
      <div id="updated-laws-card" class="bg-white dark:bg-gray-800 rounded-xl shadow-sm scroll-mt-24">
        <%= render 'updated_laws', updated_laws: @updated_laws %>
      </div>
    <% end %>
    
    <!-- Executive Decisions -->
    <% if @exdecs.present? %>
      <div id="exdecs-card" class="bg-white dark:bg-gray-800 rounded-xl shadow-sm scroll-mt-24">
        <%= render 'exdecs', exdecs: @exdecs %>
      </div>
    <% end %>
    
    <!-- Articles (Eager-loaded) -->
    <div id="tekst" class="scroll-mt-24" data-sidebar-toggle-target="trigger" 
         data-controller="article-preferences"
         data-article-preferences-show-colors-value="true"
         data-article-preferences-show-exdecs-value="true">
      <%= turbo_frame_tag "law_articles",
            src: articles_law_path(@law, language_id: @language_id, show_article_exdecs: params[:show_article_exdecs]),
            loading: :eager,
            data: { toc_anchor_target: "frame" } do %>
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm">
          <div class="p-6">
            <div class="flex flex-col items-start gap-3 p-4 rounded-lg border bg-(--accent-500)/10 border-(--accent-500)/20 text-(--accent-800) dark:bg-(--accent-500)/10 dark:border-(--accent-500)/40 dark:text-gray-300" role="status" aria-live="polite">
              <div class="flex items-center gap-3 w-full">
                <svg aria-hidden="true" class="w-5 h-5 shrink-0 text-(--accent-600) animate-pulse" viewBox="0 0 20 20" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                  <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-8-3a1 1 0 100-2 1 1 0 000 2zm1 2a1 1 0 10-2 0v6a1 1 0 102 0V9z" clip-rule="evenodd"/>
                </svg>
                <div class="flex-1 min-w-0">
                  <div class="text-sm leading-5 font-medium">
                    <%= t('articles.loading_message', default: 'Please wait, loading articles...') %>
                    <span id="skeleton-stopwatch" class="ml-2 font-mono text-xs tabular-nums opacity-70">0.0s</span>
                    <% if @estimated_load_seconds %>
                      <span class="ml-1 text-xs opacity-50">/ ~<%= @estimated_load_seconds %>s</span>
                    <% end %>
                  </div>
                  <% if @article_count && @article_count > 0 %>
                    <div class="text-xs opacity-60 mt-0.5">
                      <%= @article_count %> <%= case I18n.locale when :fr then (@article_count == 1 ? 'article' : 'articles') when :de then 'Artikel' when :en then (@article_count == 1 ? 'article' : 'articles') else (@article_count == 1 ? 'artikel' : 'artikelen') end %>
                    </div>
                  <% end %>
                </div>
              </div>
              <% if @estimated_load_seconds %>
                <%# Animated progress bar that fills over the estimated duration %>
                <div class="w-full h-1.5 rounded-full bg-(--accent-500)/10 dark:bg-(--accent-500)/20 overflow-hidden">
                  <div id="skeleton-progress-bar"
                       class="h-full rounded-full bg-(--accent-500) dark:bg-(--accent-400) transition-none"
                       style="width: 0%; transition: width <%= @estimated_load_seconds %>s cubic-bezier(0.4, 0, 0.2, 1);"></div>
                </div>
              <% end %>
              <script nonce="<%= content_security_policy_nonce %>">
                (function(){
                  var t0 = performance.now(), el = document.getElementById('skeleton-stopwatch');
                  if (!el) return;
                  var bar = document.getElementById('skeleton-progress-bar');
                  // Kick off progress bar animation on next frame
                  if (bar) requestAnimationFrame(function(){ bar.style.width = '95%'; });
                  var iv = setInterval(function(){
                    if (!document.contains(el)) { clearInterval(iv); return; }
                    el.textContent = ((performance.now() - t0) / 1000).toFixed(1) + 's';
                  }, 100);
                })();
              </script>

            </div>
          </div>
          <%= loading_skeleton_tag(kind: :article) %>
        </div>
      <% end %>
    </div>
  </div>
</div>
<% end %>

<%# Shared copy dropdown for articles - placed at DOM root to avoid inheriting
    malformed <b> tags from article text rendering (font-weight:900 pollution) %>
<div id="shared-copy-menu" class="hidden fixed w-40 bg-white dark:bg-gray-800 rounded-md shadow-md border border-gray-200 dark:border-gray-700 py-0.5 z-9999">
  <button type="button" data-copy-action="link"
          class="w-full px-2.5 py-1.5 text-left text-xs font-normal text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 flex items-center gap-1.5 transition-colors">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5 shrink-0 opacity-60">
      <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244" />
    </svg>
    <%= t(:copy_article_link) %>
  </button>
  <button type="button" data-copy-action="text"
          class="w-full px-2.5 py-1.5 text-left text-xs font-normal text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 flex items-center gap-1.5 transition-colors">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5 shrink-0 opacity-60">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6M9.5 4.5A1.5 1.5 0 0111 3h2a1.5 1.5 0 011.5 1.5V6H17a2 2 0 012 2v9a2 2 0 01-2 2H7a2 2 0 01-2-2V8a2 2 0 012-2h2.5V4.5z" />
    </svg>
    <%= t(:copy_article_text) %>
  </button>
  <button type="button" data-copy-action="clean"
          class="w-full px-2.5 py-1.5 text-left text-xs font-normal text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 flex items-center gap-1.5 transition-colors">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 shrink-0 opacity-60" viewBox="0 0 20 20" fill="currentColor">
      <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4zm2 6a1 1 0 011-1h6a1 1 0 110 2H7a1 1 0 01-1-1zm1 3a1 1 0 100 2h6a1 1 0 100-2H7z" clip-rule="evenodd"/>
    </svg>
    <%= t(:copy_clean_text) %>
  </button>
</div>

<script nonce="<%= content_security_policy_nonce %>">
(function() {
  var menu = document.getElementById('shared-copy-menu');
  if (!menu) return;
  var currentPermalink = null;
  var currentSource = null;

  // Full citation cleaning: DOM manipulation + regex cleanup
  // Mirrors clipboard_controller.js copyCleanText logic
  function cleanForCitation(sourceEl) {
    if (!sourceEl) return '';

    var clone = sourceEl.cloneNode(true);

    // Remove references section
    var refsSection = clone.querySelector('.references-section');
    if (refsSection) refsSection.remove();

    // Remove ref-markers (the [N and ]N parts)
    clone.querySelectorAll('.ref-marker').forEach(function(el) { el.remove(); });

    // Remove .reference wrappers that now only contain deleted-text indicators
    // (whitespace/ellipsis from [N ... ]N patterns where brackets were stripped)
    clone.querySelectorAll('.reference').forEach(function(ref) {
      var text = (ref.textContent || '').trim();
      if (!text || /^[\.…\s]+$/.test(text)) {
        ref.remove();
      }
    });

    // Remove modification markers and domain tags
    clone.querySelectorAll('.modification-marker').forEach(function(el) { el.remove(); });
    clone.querySelectorAll('.domain-tag').forEach(function(el) { el.remove(); });

    // Insert newlines for block elements to preserve structure
    clone.querySelectorAll('br').forEach(function(br) {
      br.insertAdjacentText('beforebegin', '\n');
    });
    clone.querySelectorAll('p, div').forEach(function(el) {
      el.insertAdjacentText('beforebegin', '\n');
      el.insertAdjacentText('afterend', '\n');
    });

    // Extract text and apply regex cleanup
    var rawText = clone.innerText || '';
    return rawText
      .replace(/\[\d+\s*\.{3}\s*\d*\]/g, '')   // Remove [1 ... 1] ASCII markers
      .replace(/\[\d+\s*\u2026\s*\d*\]/g, '')       // Remove [1 … 1] Unicode markers
      .replace(/\[\d+\s/g, '')                   // Remove standalone opening [N markers
      .replace(/\]\d+/g, '')                     // Remove standalone closing ]N markers
      .replace(/\[\d+\]/g, '')                   // Remove [N] markers
      .replace(/(?:^|\s)\.{3}(?:\s|$)/gm, ' ')  // Remove orphaned '...'
      .replace(/(?:^|\s)\u2026(?:\s|$)/gm, ' ')      // Remove orphaned '…'
      .replace(/\t/g, ' ')                       // Tabs to spaces
      .split('\n')
      .map(function(line) { return line.replace(/ +/g, ' ').trim(); })
      .filter(function(line, i, arr) {
        if (line) return true;
        if (i > 0 && arr[i - 1]) return true;
        return false;
      })
      .join('\n')
      .replace(/\n{3,}/g, '\n\n')               // Max 2 consecutive newlines
      .trim();
  }

  document.addEventListener('click', function(e) {
    // Handle clicks on article numbers (e.g., "Art. 5.66.")
    var artNum = e.target.closest('.article-number');
    if (artNum) {
      // Walk up to the article container that holds permalink/source data
      var container = artNum.closest('[data-permalink]');
      if (container) {
        e.preventDefault();
        e.stopPropagation();
        currentPermalink = container.dataset.permalink;
        currentSource = container.dataset.source;
        var rect = artNum.getBoundingClientRect();
        menu.style.top = (rect.bottom + 4) + 'px';
        menu.style.left = rect.left + 'px';
        menu.classList.remove('hidden');
        return;
      }
    }
    var action = e.target.closest('[data-copy-action]');
    if (action && currentPermalink) {
      var act = action.dataset.copyAction;
      if (act === 'link') {
        var url = window.location.origin + window.location.pathname + '#' + currentPermalink;
        navigator.clipboard.writeText(url).catch(function(){});
      } else {
        var el = document.querySelector(currentSource);
        if (el) {
          var text = act === 'clean'
            ? cleanForCitation(el)
            : el.innerText;
          navigator.clipboard.writeText(text).catch(function(){});
        }
      }
      menu.classList.add('hidden');
      return;
    }
    if (!e.target.closest('#shared-copy-menu')) {
      menu.classList.add('hidden');
    }
  });
})();
</script>
<% end %>