                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-300"><%= c['decision_date'] %></span>
                    <span class="text-xs text-gray-500 dark:text-gray-400"><%= c['court'] %></span>
                  </div>
                  <p class="text-xs text-gray-500 dark:text-gray-400 mt-1 line-clamp-2"><%= (c['summary'].presence || c['display_text'].to_s).truncate(120) %></p>
                </div>
                <svg class="w-4 h-4 text-gray-400 group-hover:text-amber-500 transition-colors shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
              </div>
            </a>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-gray-500 dark:text-gray-400 italic">
          <%= case I18n.locale when :fr then 'Aucune jurisprudence récente disponible.' when :de then 'Keine aktuelle Rechtsprechung verfügbar.' when :en then 'No recent case law available.' else 'Geen recente rechtspraak beschikbaar.' end %>
        </p>
      <% end %>
