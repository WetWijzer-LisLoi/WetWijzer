<% collapsed = local_assigns.fetch(:collapsed, false) %>
<div class="bg-white dark:bg-midnight rounded-xl shadow-sm border border-gray-200 dark:border-sky/30 px-6 py-5 mb-6" data-controller="collapse" data-collapse-expanded-value="<%= !collapsed %>">
