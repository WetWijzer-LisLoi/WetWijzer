    <!-- Panel 5: Concordantietabellen -->
    <div data-tabs-target="panel" class="px-6 py-5 hidden">
      <%# WetWijzer original concordance tool — compiled from official Belgisch Staatsblad / Moniteur belge sources.
          Article-to-article mappings are legislative facts (not copyrightable).
          All descriptions, practical notes, and editorial commentary are original WetWijzer content. %>
      <div class="flex items-start gap-3 mb-5 p-3 rounded-lg bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800/50">
        <svg class="w-5 h-5 text-blue-600 dark:text-blue-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <div class="text-xs text-blue-800 dark:text-blue-200">
          <strong><%= case I18n.locale when :fr then 'Outil pratique WetWijzer' when :de then 'WetWijzer-Hilfsmittel' when :en then 'WetWijzer tool' else 'WetWijzer-hulpmiddel' end %></strong> —
          <%= case I18n.locale
              when :fr then "Correspondances entre anciens et nouveaux articles, compilées à partir du Moniteur belge. Les descriptions et notes pratiques sont un contenu original WetWijzer. Vérifiez toujours le texte de loi consolidé officiel."
              when :de then "Zuordnungen zwischen alten und neuen Artikeln, zusammengestellt aus dem Belgischen Staatsblatt. Beschreibungen und Praxisnotizen sind originale WetWijzer-Inhalte. Überprüfen Sie stets den offiziellen konsolidierten Gesetzestext."
              when :en then "Concordance between old and new articles, compiled from the Belgian Official Gazette. Descriptions and practice notes are original WetWijzer content. Always verify against the official consolidated text."
              else "Concordanties tussen oude en nieuwe artikelen, samengesteld op basis van het Belgisch Staatsblad. Beschrijvingen en praktijknota's zijn originele WetWijzer-content. Controleer steeds de officiële geconsolideerde wettekst."
              end %>
        </div>
      </div>

      <div class="space-y-3">

        <%# === 1. Burgerlijk Wetboek: Alle boeken (YAML-driven) === %>
        <%
          bw_concordance = YAML.load_file(Rails.root.join('config', 'data', 'bw_concordance.yml'))
          bw_book_styles = {
            'boek_1' => { badge: 'B1', cls: 'bg-indigo-100 dark:bg-indigo-900/40 text-indigo-700 dark:text-indigo-300' },
            'boek_2' => { badge: 'B2', cls: 'bg-purple-100 dark:bg-purple-900/40 text-purple-700 dark:text-purple-300' },
            'boek_3' => { badge: 'B3', cls: 'bg-emerald-100 dark:bg-emerald-900/40 text-emerald-700 dark:text-emerald-300' },
            'boek_4' => { badge: 'B4', cls: 'bg-amber-100 dark:bg-amber-900/40 text-amber-700 dark:text-amber-300' },
            'boek_5' => { badge: 'B5', cls: 'bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-300' },
            'boek_6' => { badge: 'B6', cls: 'bg-rose-100 dark:bg-rose-900/40 text-rose-700 dark:text-rose-300' },
            'boek_8' => { badge: 'B8', cls: 'bg-teal-100 dark:bg-teal-900/40 text-teal-700 dark:text-teal-300' },
            'boek_9' => { badge: 'B9', cls: 'bg-orange-100 dark:bg-orange-900/40 text-orange-700 dark:text-orange-300' }
          }
          # BW old column: linkify_concordance_article_bw_old routes each article
          # to the correct old BW NUMAC by article-number range
          # BW new column: each book has its own NUMAC stored in YAML
        %>
        <% bw_concordance.each do |book_key, book| %>
          <%
            style = bw_book_styles[book_key] || { badge: 'BW', cls: 'bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-300' }
            label = I18n.locale == :fr ? book['label_fr'] : book['label_nl']
            source = I18n.locale == :fr ? book['source_fr'] : book['source_nl']
            transition = I18n.locale == :fr ? book['transition_fr'] : book['transition_nl']
            total = book['sections'].sum { |s| s['entries'].size }
            col_old = I18n.locale == :fr ? 'Ancien' : 'Oud'
            col_new = I18n.locale == :fr ? 'Nouveau (NBW)' : 'Nieuw (NBW)'
            bw_new_numac = book['new_numac']
          %>
          <details class="group rounded-lg border border-gray-200 dark:border-gray-700 overflow-hidden">
            <summary class="flex items-center justify-between gap-3 px-5 py-3.5 bg-gray-50 dark:bg-gray-800/50 cursor-pointer select-none hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors">
              <div class="flex items-center gap-3 min-w-0">
                <span class="inline-flex items-center justify-center w-8 h-8 rounded-lg <%= style[:cls] %> text-sm font-bold shrink-0"><%= style[:badge] %></span>
                <div class="min-w-0">
                  <div class="font-semibold text-gray-900 dark:text-white text-sm truncate"><%= label %></div>
                  <div class="text-xs text-gray-500 dark:text-gray-400 truncate"><%= source %></div>
                </div>
              </div>
              <div class="flex items-center gap-2 shrink-0">
                <span class="text-[10px] text-gray-400 dark:text-gray-500 font-mono"><%= total %> art.</span>
                <svg class="w-5 h-5 text-gray-400 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </div>
            </summary>
            <div class="px-5 py-4 border-t border-gray-200 dark:border-gray-700">
              <% book['sections'].each_with_index do |section, si| %>
                <% section_heading = I18n.locale == :fr ? section['heading_fr'] : section['heading_nl'] %>
                <% if book['sections'].size > 1 %>
                  <h4 class="text-xs font-bold text-gray-500 dark:text-gray-400 capitalize tracking-wider mb-3 <%= 'mt-6' if si > 0 %>"><%= section_heading %></h4>
                <% end %>
                <div class="overflow-x-auto mb-4">
                  <table class="w-full text-sm">
                    <thead>
                      <tr class="text-left border-b border-gray-200 dark:border-gray-700">
                        <th class="pb-2 pr-3 font-semibold text-gray-700 dark:text-gray-300 whitespace-nowrap w-1/2"><%= col_old %></th>
                        <th class="pb-2 font-semibold text-gray-700 dark:text-gray-300 whitespace-nowrap w-1/2"><%= col_new %></th>
                      </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
                      <% section['entries'].each do |entry| %>
                        <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50">
                          <td class="py-1.5 pr-3 font-mono text-xs text-gray-600 dark:text-gray-400"><%= linkify_concordance_article_bw_old(entry[0]) %></td>
                          <td class="py-1.5 font-mono text-xs font-semibold text-(--accent-600) dark:text-(--accent-400)"><%= linkify_concordance_article(entry[1], bw_new_numac) %></td>
                        </tr>
                      <% end %>
                    </tbody>
                  </table>
                </div>
              <% end %>

              <div class="p-2.5 rounded bg-amber-50 dark:bg-amber-900/15 border border-amber-200 dark:border-amber-800/40 text-xs text-amber-800 dark:text-amber-200">
                <strong><%= I18n.locale == :fr ? 'Droit transitoire:' : 'Overgangsrecht:' %></strong>
                <%= transition %>
              </div>
            </div>
          </details>
        <% end %>

        <%# === 2. Strafwetboek (YAML-driven) === %>
        <%
          sw_concordance = YAML.load_file(Rails.root.join('config', 'data', 'sw_concordance.yml'))
          sw_label = I18n.locale == :fr ? sw_concordance['label_fr'] : sw_concordance['label_nl']
          sw_source = I18n.locale == :fr ? sw_concordance['source_fr'] : sw_concordance['source_nl']
          sw_transition = I18n.locale == :fr ? sw_concordance['transition_fr'] : sw_concordance['transition_nl']
          sw_total = sw_concordance['sections'].sum { |s| s['entries'].size }
          sw_old_numac = sw_concordance['old_numac']
          sw_new_numac = sw_concordance['new_numac']
          sw_col_old = I18n.locale == :fr ? 'Ancien' : 'Oud'
          sw_col_new = I18n.locale == :fr ? 'Nouveau (+ niveau)' : 'Nieuw (+ niveau)'
        %>
        <details class="group rounded-lg border border-gray-200 dark:border-gray-700 overflow-hidden">
          <summary class="flex items-center justify-between gap-3 px-5 py-3.5 bg-gray-50 dark:bg-gray-800/50 cursor-pointer select-none hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors">
            <div class="flex items-center gap-3 min-w-0">
              <span class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-red-100 dark:bg-red-900/40 text-red-700 dark:text-red-300 text-sm font-bold shrink-0">Sw</span>
              <div class="min-w-0">
                <div class="font-semibold text-gray-900 dark:text-white text-sm truncate"><%= sw_label %></div>
                <div class="text-xs text-gray-500 dark:text-gray-400 truncate"><%= sw_source %></div>
              </div>
            </div>
            <div class="flex items-center gap-2 shrink-0">
              <span class="text-[10px] text-gray-400 dark:text-gray-500 font-mono"><%= sw_total %> art.</span>
              <svg class="w-5 h-5 text-gray-400 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </div>
          </summary>
          <div class="px-5 py-4 border-t border-gray-200 dark:border-gray-700">
            <%# Strafniveaus — reference table %>
            <% sw_niveaus = sw_concordance['strafniveaus'] %>
            <div class="mb-5 overflow-x-auto">
              <table class="w-full text-xs">
                <thead>
                  <tr class="text-left border-b border-red-200 dark:border-red-700">
                    <th class="pb-2 pr-2 font-semibold text-gray-700 dark:text-gray-300 w-12">N</th>
                    <th class="pb-2 pr-3 font-semibold text-gray-700 dark:text-gray-300 whitespace-nowrap"><%= I18n.locale == :fr ? 'Emprisonnement' : 'Gevangenisstraf' %></th>
                    <th class="pb-2 font-semibold text-gray-700 dark:text-gray-300"><%= I18n.locale == :fr ? 'Description' : 'Toelichting' %></th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-red-100 dark:divide-red-900/30">
                  <% sw_niveaus['levels'].each do |niv| %>
                    <% is_criminal = niv['level'] >= 7 %>
                    <tr class="<%= is_criminal ? 'bg-red-50/50 dark:bg-red-900/10' : '' %>">
                      <td class="py-1.5 pr-2">
                        <span class="inline-block px-1.5 py-0.5 rounded font-mono font-bold text-[10px] <%= is_criminal ? 'bg-red-200 dark:bg-red-800/50 text-red-800 dark:text-red-200' : 'bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-300' %>">N<%= niv['level'] %></span>
                      </td>
                      <td class="py-1.5 pr-3 font-mono text-gray-700 dark:text-gray-300 whitespace-nowrap"><%= I18n.locale == :fr ? niv['gevangenisstraf_fr'] : niv['gevangenisstraf_nl'] %></td>
                      <td class="py-1.5 text-gray-600 dark:text-gray-400"><%= I18n.locale == :fr ? niv['beschrijving_fr'] : niv['beschrijving_nl'] %></td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
              <p class="mt-2.5 text-[10px] text-red-600 dark:text-red-400 italic">
                <%= I18n.locale == :fr ? 'Base légale:' : 'Wettelijke basis:' %>
                <a href="<%= sw_niveaus['legal_basis_url'] %>" target="_blank" rel="noopener noreferrer" class="underline hover:text-red-800 dark:hover:text-red-200 transition-colors"><%= sw_niveaus['legal_basis'] %></a>
              </p>
            </div>

            <% sw_concordance['sections'].each_with_index do |section, si| %>
              <% section_heading = I18n.locale == :fr ? section['heading_fr'] : section['heading_nl'] %>
              <h4 class="text-xs font-bold text-gray-500 dark:text-gray-400 capitalize tracking-wider mb-3 <%= 'mt-6' if si > 0 %>"><%= section_heading %></h4>
              <div class="overflow-x-auto mb-4">
                <table class="w-full text-sm">
                  <thead>
                    <tr class="text-left border-b border-gray-200 dark:border-gray-700">
                      <th class="pb-2 pr-3 font-semibold text-gray-700 dark:text-gray-300 whitespace-nowrap w-1/2"><%= sw_col_old %></th>
                      <th class="pb-2 font-semibold text-gray-700 dark:text-gray-300 whitespace-nowrap w-1/2"><%= sw_col_new %></th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
                    <% section['entries'].each do |entry| %>
                      <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50">
                        <td class="py-1.5 pr-3 font-mono text-xs text-gray-600 dark:text-gray-400"><%= linkify_concordance_article(entry[0], sw_old_numac) %></td>
                        <td class="py-1.5 font-mono text-xs font-semibold text-(--accent-600) dark:text-(--accent-400)"><%= linkify_concordance_article(entry[1], sw_new_numac) %></td>
                      </tr>
                    <% end %>
                  </tbody>
                </table>
              </div>
            <% end %>

            <div class="p-2.5 rounded bg-amber-50 dark:bg-amber-900/15 border border-amber-200 dark:border-amber-800/40 text-xs text-amber-800 dark:text-amber-200">
              <strong><%= I18n.locale == :fr ? 'Droit transitoire:' : 'Overgangsrecht:' %></strong>
              <%= sw_transition %>
            </div>
          </div>
        </details>

        <%# === 3. WVV (YAML-driven) === %>
        <%
          wvv_concordance = YAML.load_file(Rails.root.join('config', 'data', 'wvv_concordance.yml'))
          wvv_label = I18n.locale == :fr ? wvv_concordance['label_fr'] : wvv_concordance['label_nl']
          wvv_source = I18n.locale == :fr ? wvv_concordance['source_fr'] : wvv_concordance['source_nl']
          wvv_transition = I18n.locale == :fr ? wvv_concordance['transition_fr'] : wvv_concordance['transition_nl']
          wvv_total = wvv_concordance['sections'].sum { |s| s['entries'].size }
          wvv_old_numac = wvv_concordance['old_numac']
          wvv_new_numac = wvv_concordance['new_numac']
          wvv_col_old = I18n.locale == :fr ? 'Ancien (C.Soc.)' : 'Oud (W.Venn.)'
          wvv_col_new = I18n.locale == :fr ? 'Nouveau (CSA)' : 'Nieuw (WVV)'
        %>
        <details class="group rounded-lg border border-gray-200 dark:border-gray-700 overflow-hidden">
          <summary class="flex items-center justify-between gap-3 px-5 py-3.5 bg-gray-50 dark:bg-gray-800/50 cursor-pointer select-none hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors">
            <div class="flex items-center gap-3 min-w-0">
              <span class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-amber-100 dark:bg-amber-900/40 text-amber-700 dark:text-amber-300 text-xs font-bold shrink-0">WVV</span>
              <div class="min-w-0">
                <div class="font-semibold text-gray-900 dark:text-white text-sm truncate"><%= wvv_label %></div>
                <div class="text-xs text-gray-500 dark:text-gray-400 truncate"><%= wvv_source %></div>
              </div>
            </div>
            <div class="flex items-center gap-2 shrink-0">
              <span class="text-[10px] text-gray-400 dark:text-gray-500 font-mono"><%= wvv_total %> art.</span>
              <svg class="w-5 h-5 text-gray-400 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </div>
          </summary>
          <div class="px-5 py-4 border-t border-gray-200 dark:border-gray-700">
            <% wvv_concordance['sections'].each_with_index do |section, si| %>
              <% section_heading = I18n.locale == :fr ? section['heading_fr'] : section['heading_nl'] %>
              <h4 class="text-xs font-bold text-gray-500 dark:text-gray-400 capitalize tracking-wider mb-3 <%= 'mt-6' if si > 0 %>"><%= section_heading %></h4>
              <div class="overflow-x-auto mb-4">
                <table class="w-full text-sm">
                  <thead>
                    <tr class="text-left border-b border-gray-200 dark:border-gray-700">
                      <th class="pb-2 pr-3 font-semibold text-gray-700 dark:text-gray-300 whitespace-nowrap w-1/2"><%= wvv_col_old %></th>
                      <th class="pb-2 font-semibold text-gray-700 dark:text-gray-300 whitespace-nowrap w-1/2"><%= wvv_col_new %></th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
                    <% section['entries'].each do |entry| %>
                      <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50">
                        <td class="py-1.5 pr-3 font-mono text-xs text-gray-600 dark:text-gray-400"><%= linkify_concordance_article(entry[0], wvv_old_numac) %></td>
                        <td class="py-1.5 font-mono text-xs font-semibold text-(--accent-600) dark:text-(--accent-400)"><%= linkify_concordance_article(entry[1], wvv_new_numac) %></td>
                      </tr>
                    <% end %>
                  </tbody>
                </table>
              </div>
            <% end %>

            <div class="p-2.5 rounded bg-amber-50 dark:bg-amber-900/15 border border-amber-200 dark:border-amber-800/40 text-xs text-amber-800 dark:text-amber-200">
              <strong><%= I18n.locale == :fr ? 'Droit transitoire:' : 'Overgangsrecht:' %></strong>
              <%= wvv_transition %>
            </div>
          </div>
        </details>

      </div>

      <p class="text-[10px] text-gray-400 dark:text-gray-500 mt-4 italic">
        <%= case I18n.locale
            when :fr then "Compilé par WetWijzer à partir du Moniteur belge. Contenu original — non reproduit d'une publication tierce. Dernière mise à jour: mai 2026."
            when :de then 'Von WetWijzer zusammengestellt auf Basis des Belgischen Staatsblattes. Originaler Inhalt. Letztes Update: Mai 2026.'
            else "Samengesteld door WetWijzer op basis van het Belgisch Staatsblad. Originele content — niet overgenomen uit een publicatie van derden. Laatste update: mei 2026."
            end %>
      </p>
    </div>

  </div>
</div>
<% end %>
