<% collapsed = local_assigns.fetch(:collapsed, false) %>
<% cache ["popular_laws", "v9", I18n.locale, content_lang, collapsed, File.mtime(Rails.root.join('app/views/laws/_popular_laws.html.erb')).to_i], expires_in: 1.day do %>
<%
  # Look up which popular laws are abolished or have empty content
  abolished_numacs = begin
    lang_id = current_language_id
    Legislation.where(is_core: 1, language_id: lang_id)
               .where('is_abolished = 1 OR is_empty_content = 1')
               .pluck(:numac).to_set
  rescue
    Set.new
  end

  # Base CSS for all popular law links
  base_class = "text-sm text-gray-600 dark:text-gray-300 hover:text-(--accent-600) dark:hover:text-(--accent-400) transition-colors"
  # Helper to get the right classes for a given numac
  popular_law_class = ->(numac, extra: "") {
    if abolished_numacs.include?(numac)
      "#{base_class} line-through opacity-60 #{extra}".strip
    else
      "#{base_class} #{extra}".strip
    end
  }
  popular_law_title = ->(numac) {
    if abolished_numacs.include?(numac)
      I18n.locale == :nl ? 'Niet meer van kracht / onbeschikbaar' : 'Plus en vigueur / indisponible'
    else
      nil
    end
  }
%>
<div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg overflow-hidden" data-controller="collapse tabs" data-collapse-expanded-value="<%= !collapsed %>">
  <!-- Header with Sources title -->
  <div class="bg-gray-50 dark:bg-gray-800/50 border-b border-gray-200 dark:border-gray-700 px-6 py-4">
    <div class="flex items-center justify-between">
      <button type="button" class="flex-1 flex items-center justify-between text-left focus:outline-hidden focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-(--accent-500)" data-action="click->collapse#toggle" data-collapse-target="button" aria-label="Toggle sources" aria-expanded="<%= !collapsed %>">
        <h2 class="text-lg font-bold text-gray-900 dark:text-white flex items-center gap-2">
          <svg class="w-5 h-5 text-(--accent-600)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
          </svg>
          <%= case I18n.locale when :fr then 'Sources' when :de then 'Quellen' when :en then 'Sources' else 'Bronnen' end %>
        </h2>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 transition-transform duration-200 ease-in-out motion-reduce:transition-none text-gray-500 dark:text-gray-400" viewBox="0 0 20 20" fill="currentColor" data-collapse-target="icon">
          <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 10.94l3.71-3.71a.75.75 0 111.06 1.06l-4.24 4.24a.75.75 0 01-1.06 0L5.21 8.29a.75.75 0 01.02-1.08z" clip-rule="evenodd" />
        </svg>
      </button>
      <% if I18n.locale == :en %>
        <%# NL/FR content language toggle — LexLibera only %>
        <div class="flex items-center gap-0.5 ml-3 shrink-0 rounded-md border border-gray-200 dark:border-gray-600 overflow-hidden" role="group" aria-label="Legislation language">
          <% nl_active = content_lang == 'nl' %>
          <% fr_active = content_lang == 'fr' %>
          <%= link_to laws_path(request.query_parameters.merge(content_lang: 'nl')),
                class: "px-2.5 py-1 text-xs font-bold transition-colors #{nl_active ? 'bg-(--accent-600-solid) text-white' : 'bg-white dark:bg-gray-800 text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700'}",
                title: "Show legislation in Dutch",
                'aria-pressed': nl_active,
                data: { turbo: false } do %>NL<% end %>
