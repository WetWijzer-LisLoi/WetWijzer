        <p class="text-sm text-gray-600 dark:text-gray-400">
          <%= case I18n.locale when :fr then 'Décisions de justice récentes' when :de then 'Aktuelle Rechtsprechung' when :en then 'Recent court decisions' else 'Recente rechterlijke uitspraken' end %>
        </p>
        <a href="<%= jurisprudence_index_path %>" class="text-sm text-(--accent-600) hover:underline">
          <%= case I18n.locale when :fr then 'Voir tout →' when :de then 'Alle anzeigen →' when :en then 'View all →' else 'Bekijk alle →' end %>
        </a>
      </div>
      <%
        begin
          juris_db_path = ENV.fetch('JURISPRUDENCE_SOURCE_DB') { Rails.root.join('storage', 'jurisprudence.db').to_s }
          if File.exist?(juris_db_path)
            juris_db = SQLite3::Database.new(juris_db_path.to_s)
            juris_db.results_as_hash = true
            has_pseudo = juris_db.execute('PRAGMA table_info(cases)').any? { |col| col[1] == 'pseudonymized_text' }
            text_col = has_pseudo ? 'COALESCE(pseudonymized_text, full_text)' : 'full_text'
            lang_filter = I18n.locale == :fr ? "(language_id = 2 OR case_number LIKE '%-FR')" : "(language_id = 1 OR case_number LIKE '%-NL')"
            recent_cases = juris_db.execute(
              "SELECT case_number, court, decision_date, summary, #{text_col} as display_text FROM cases WHERE decision_date IS NOT NULL AND #{lang_filter} ORDER BY decision_date DESC LIMIT 6"
            )
            juris_db.close
          else
            recent_cases = []
          end
        rescue => e
          Rails.logger.error("Recent jurisprudence error: #{e.class}: #{e.message}")
          recent_cases = []
        end
      %>
      <% if recent_cases.any? %>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <% recent_cases.each do |c| %>
            <a href="<%= jurisprudence_path(c['case_number']) %>"
               class="block p-4 rounded-lg border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 hover:border-amber-400 dark:hover:border-amber-500 hover:shadow-md transition-all duration-200 group">
