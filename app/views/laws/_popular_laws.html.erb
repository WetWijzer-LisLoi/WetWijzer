                class: "px-2.5 py-1 text-xs font-bold transition-colors #{fr_active ? 'bg-(--accent-600-solid) text-white' : 'bg-white dark:bg-gray-800 text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700'}",
