<% if related_jurisprudence.present? %>
<div class="px-4 md:px-6 pb-4 md:pb-6">
  <% if local_assigns[:jurisprudence_total].to_i > related_jurisprudence.size %>
    <p class="text-xs text-gray-400 dark:text-gray-500 mb-2"><%= related_jurisprudence.size %> <%= case I18n.locale when :fr then 'sur' when :de then 'von' when :en then 'of' else 'van' end %> <%= jurisprudence_total %> <%= case I18n.locale when :fr then 'résultats' when :de then 'Ergebnisse' when :en then 'results' else 'resultaten' end %></p>
  <% end %>
  <div class="space-y-1">
    <% related_jurisprudence.each do |case_item| %>
      <a href="<%= jurisprudence_path(case_item[:case_number]) %>" 
         class="block p-2 rounded-lg hover:bg-(--accent-50,#eff6ff) dark:hover:bg-(--accent-900,#1e3a5f)/20 transition-colors group">
        <div class="flex items-center justify-between gap-2">
          <div class="flex-1 min-w-0">
            <span class="text-sm text-gray-900 dark:text-white group-hover:text-(--accent-700) dark:group-hover:text-(--accent-400) font-mono">
              <%= case_item[:case_number]&.truncate(40) %>
            </span>
            <div class="flex items-center gap-2 text-xs text-gray-500 dark:text-gray-400">
              <span><%= case_item[:court]&.truncate(25) %></span>
              <span><%= case_item[:decision_date] %></span>
              <% if case_item[:subject_matter].present? %>
                <span class="truncate max-w-[200px]"><%= case_item[:subject_matter] %></span>
              <% end %>
            </div>
          </div>
          <svg class="w-4 h-4 text-gray-400 group-hover:text-(--accent-500)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </div>
      </a>
    <% end %>
  </div>
  <a href="<%= jurisprudence_index_path %>" 
     class="inline-flex items-center gap-1 mt-2 text-xs text-(--accent-600) dark:text-(--accent-400) hover:underline">
    <%= case I18n.locale when :fr then 'Rechercher dans la jurisprudence' when :de then 'In der Rechtsprechung suchen' when :en then 'Search case law' else 'Zoeken in rechtspraak' end %>
    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
    </svg>
  </a>
</div>
<% else %>
<div class="px-4 md:px-6 pb-4 md:pb-6">
  <p class="text-sm text-gray-500 dark:text-gray-400 italic">
    <%= case I18n.locale when :fr then 'Aucune jurisprudence trouvée.' when :de then 'Keine Rechtsprechung gefunden.' when :en then 'No case law found.' else 'Geen rechtspraak gevonden.' end %>
  </p>
</div>
<% end %>
