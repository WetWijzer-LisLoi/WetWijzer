<%= turbo_frame_tag "law_articles",
      data: { controller: 'frame-status', frame_status_completed_value: t('loading_status.completed') } do %>
  <% if @articles.blank? && @law&.is_abolished == 1 %>
    <%# Abolished law — read modification history from repeal_info DB column %>
    <% raw_info = @law.repeal_info.present? ? JSON.parse(@law.repeal_info, symbolize_names: true) : { abolished_by: nil, repeal_detail: nil, entries: [] } rescue { abolished_by: nil, repeal_detail: nil, entries: [] } %>
    <% repeal_detail = raw_info[:repeal_detail] ? OpenStruct.new(raw_info[:repeal_detail]) : nil %>
    <% history = { abolished_by: raw_info[:abolished_by], repeal_detail: repeal_detail, entries: (raw_info[:entries] || []).map { |e| OpenStruct.new(e) } } %>
    <%# Build lookup map: document_number → { numac:, language_id:, title: } %>
    <% all_doc_nums = [] %>
    <% all_doc_nums << history[:repeal_detail].doc_num if history[:repeal_detail]&.doc_num.present? %>
    <% history[:entries].each { |e| e.text.scan(%r{\d{4}-\d{2}-\d{2}/[A-Za-z0-9]+}).each { |dn| all_doc_nums << dn } } if history[:entries].any? %>
    <% doc_lookups = {} %>
    <% if all_doc_nums.any?
         DocumentNumberLookup.where(document_number: all_doc_nums.uniq).each do |rec|
           law = Legislation.find_by(numac: rec.numac, language_id: rec.language_id)
           doc_lookups[rec.document_number] = { numac: rec.numac, language_id: rec.language_id, title: law&.title }
         end
       end %>
    <%# Fallback: for timeline entries, match via date + law type + publication date %>
    <% entry_law_cache = {} %>
    <% type_map = { 'wet' => 2, 'loi' => 7, 'decreet' => 3, 'décret' => 8, 'decret' => 8,
                    'ordonnantie' => 4, 'ordonnance' => 9,
                    'koninklijk besluit' => 5, 'arrêté royal' => 10, 'arrete royal' => 10,
                    'ministerieel besluit' => 5, 'arrêté ministériel' => 10 } %>
    <% history[:entries].each do |e|
         dm = e.text.match(/(?:van|du)\s+(\d{2})-(\d{2})-(\d{4})/)
         next unless dm
         iso_date = "#{dm[3]}-#{dm[2]}-#{dm[1]}"
         # Extract law type from entry text (first 1-2 words before a separator)
         type_text = e.text.match(/\A(\S+(?:\s+\S+)?)\s+(?:Vlaamse|Waalse|Brusselse|van|du|de\s+la|Sénat|Chambre|Conseil|Parlement)/i)&.[](1)&.downcase&.strip
         type_id = type_text ? type_map[type_text] : nil
         # Also extract publication date from the Moniteur Belge href for disambiguation
         pub_match = e.href.to_s.match(%r{/mopdf/(\d{4})/(\d{2})/(\d{2})})
         scope = Legislation.where(date: iso_date, language_id: @language_id)
         scope = scope.where(law_type_id: type_id) if type_id
         # If we have a publication date from the Moniteur href, use it to match mon_pdf
         if pub_match
           pub_pattern = "mopdf/#{pub_match[1]}/#{pub_match[2]}/#{pub_match[3]}"
           law = scope.find_by("mon_pdf LIKE ?", "%#{pub_pattern}%") || scope.first
         else
           law = scope.first
         end
         entry_law_cache[e.object_id] = { numac: law.numac, language_id: law.language_id, title: law.title } if law
       end if history[:entries].any? %>
    <%# Normalize labels: Justel sometimes returns French labels on NL pages %>
    <% normalize_label = ->(lbl) {
      map_nl = { 'MODIFIE PAR' => 'GEWIJZIGD DOOR', 'MODIFIÉ PAR' => 'GEWIJZIGD DOOR',
                 'ABROGE PAR' => 'OPGEHEVEN DOOR', 'ABROGÉ PAR' => 'OPGEHEVEN DOOR',
                 'HEFT OP' => 'HEFT OP', 'WIJZIGT' => 'WIJZIGT' }
      map_fr = { 'GEWIJZIGD DOOR' => 'MODIFIÉ PAR', 'OPGEHEVEN DOOR' => 'ABROGÉ PAR',
                 'HEFT OP' => 'ABROGE', 'WIJZIGT' => 'MODIFIE' }
      if I18n.locale == :nl
        map_nl[lbl.strip.upcase] || lbl
      else
        map_fr[lbl.strip.upcase] || lbl
      end
    } %>
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg">
      <div class="p-6">
        <h2 class="text-xl font-bold text-gray-800 dark:text-(--accent-500) mb-4">
          <%= case I18n.locale when :fr then 'Texte abrogé' when :de then 'Aufgehobener Text' when :en then 'Repealed text' else 'Opgeheven tekst' end %>
        </h2>

        <%# "Abolished by" banner with specific article detail %>
        <% repeal = history[:repeal_detail] %>
        <% if history[:abolished_by].present? || repeal.present? %>
          <div class="rounded-lg border border-red-200 dark:border-red-800/50 bg-red-50 dark:bg-red-900/20 p-4 mb-4">
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-red-500 dark:text-red-400 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 6a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 6zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"/>
              </svg>
              <div class="flex-1">
                <p class="text-sm font-semibold text-red-800 dark:text-red-300">
                  <%= case I18n.locale when :fr then 'Abrogé par' when :de then 'Aufgehoben durch' when :en then 'Repealed by' else 'Opgeheven door' end %>
                </p>

                <%# Structured repeal detail: article + doc number + effective date %>
                <% if repeal %>
                  <div class="mt-2 space-y-1.5">
                    <%# Article reference — the key piece users want %>
                    <% if repeal.article.present? %>
                      <p class="text-sm font-medium text-red-800 dark:text-red-200">
                        <%= repeal.abbreviation %> <%= repeal.doc_num %>, <span class="font-bold"><%= repeal.article %></span>
                      </p>
                    <% end %>

                    <%# Effective date %>
                    <% if repeal.effective_date.present? %>
                      <p class="text-xs text-red-600 dark:text-red-400">
                        <%= case I18n.locale when :fr then 'Entrée en vigueur' when :de then 'Inkrafttreten' when :en then 'Entry into force' else 'Inwerkingtreding' end %>: <span class="font-semibold"><%= repeal.effective_date %></span>
                      </p>
                    <% end %>

                    <%# Link to the repealing document — prefer WetWijzer page, fallback to Justel %>
                    <% repeal_lookup = repeal.doc_num.present? ? doc_lookups[repeal.doc_num] : nil %>
                    <% if repeal_lookup %>
                      <% repeal_url = "/laws/#{repeal_lookup[:numac]}?language_id=#{repeal_lookup[:language_id]}" %>
                      <a href="<%= repeal_url %>"
                         class="inline-flex items-center gap-1 text-xs text-red-700 dark:text-red-300 underline hover:text-red-900 dark:hover:text-red-100 mt-0.5"
                         title="<%= repeal_lookup[:title] %>">
                        <%= case I18n.locale when :fr then 'Voir la loi' when :de then 'Gesetz anzeigen' when :en then 'View law' else 'Bekijk wet' end %> <%= repeal.doc_num %>
                      </a>
                    <% elsif repeal.doc_href.present? %>
                      <a href="<%= repeal.doc_href %>" target="_blank" rel="noopener noreferrer"
                         class="inline-flex items-center gap-1 text-xs text-red-700 dark:text-red-300 underline hover:text-red-900 dark:hover:text-red-100 mt-0.5">
                        <%= case I18n.locale when :fr then 'Voir le document' when :de then 'Dokument anzeigen' when :en then 'View document' else 'Bekijk document' end %> <%= repeal.doc_num %>
                        <svg class="w-3 h-3 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                        </svg>
                      </a>
                    <% end %>
                  </div>
                <% end %>

                <%# Fallback: link to repealing law from modification history %>
                <% abolished_entry = history[:entries].find { |e| e.label.match?(/OPGEHEVEN|ABROG/i) } %>
                <% if abolished_entry %>
                  <% entry_doc_num = abolished_entry.text.match(%r{\d{4}-\d{2}-\d{2}/[A-Za-z0-9]+})&.[](0) %>
                  <% entry_lookup = entry_doc_num ? doc_lookups[entry_doc_num] : nil %>
                  <% entry_lookup ||= entry_law_cache[abolished_entry.object_id] %>
                  <p class="text-sm text-red-700 dark:text-red-400 <%= repeal ? 'mt-2 pt-2 border-t border-red-200 dark:border-red-800/50' : 'mt-1' %>">
                    <% if entry_lookup %>
                      <a href="/laws/<%= entry_lookup[:numac] %>?language_id=<%= entry_lookup[:language_id] %>"
                         class="text-red-700 dark:text-red-300 underline hover:text-red-900 dark:hover:text-red-100"
                         title="<%= entry_lookup[:title] %>">
                        <%= abolished_entry.text %>
                      </a>
                    <% else %>
                      <a href="<%= abolished_entry.href %>" target="_blank" rel="noopener noreferrer"
                         class="text-red-700 dark:text-red-300 underline hover:text-red-900 dark:hover:text-red-100">
                        <%= abolished_entry.text %>
                        <svg class="inline-block w-3 h-3 ml-0.5 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                        </svg>
                      </a>
                    <% end %>
                  </p>
                <% elsif history[:abolished_by].present? && repeal.nil? %>
                  <p class="text-sm text-red-700 dark:text-red-400 mt-1">
                    <%= history[:abolished_by] %>
                  </p>
                <% end %>
              </div>
            </div>
          </div>
        <% else %>
          <div class="rounded-lg border border-red-200 dark:border-red-800/50 bg-red-50 dark:bg-red-900/20 p-4 mb-4">
            <p class="text-sm text-red-700 dark:text-red-400">
              <%= case I18n.locale when :fr then 'Cette législation a été abrogée.' when :de then 'Diese Gesetzgebung wurde aufgehoben.' when :en then 'This legislation has been repealed.' else 'Deze wetgeving werd opgeheven.' end %>
            </p>
          </div>
        <% end %>

        <%# Justel archive link — always show when Justel URL is available %>
        <% if @law&.justel.present? && @law.justel != 'N/A' %>
          <div class="mb-4">
            <a href="<%= @law.justel %>" target="_blank" rel="noopener noreferrer"
               class="inline-flex items-center gap-2 px-3 py-2 text-sm font-medium rounded-lg
                      border border-red-300 dark:border-red-700
                      text-red-700 dark:text-red-300
                      bg-red-50 dark:bg-red-900/20
                      hover:bg-red-100 dark:hover:bg-red-900/40
                      transition-colors no-print"
               title="<%= case I18n.locale when :fr then "Voir l'historique des versions sur Justel" when :de then 'Versionshistorie auf Justel anzeigen' when :en then 'View version history on Justel' else 'Bekijk de versiegeschiedenis op Justel' end %>">
              <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-4.5 0V6.75A.75.75 0 0114.25 6h1.5a.75.75 0 01.75.75v1.5m-4.5 0h4.5m-4.5 0l6-6"/>
              </svg>
              <%= case I18n.locale when :fr then "Voir l'historique des versions sur Justel" when :de then 'Versionshistorie auf Justel anzeigen' when :en then 'View version history on Justel' else 'Bekijk versiegeschiedenis op Justel' end %>
              <svg class="w-3 h-3 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
            </a>
          </div>
        <% end %>


        <%# Full modification history timeline %>
        <% if history[:entries].any? %>
          <h3 class="text-sm font-semibold text-gray-600 dark:text-gray-400 capitalize tracking-wide mb-3">
            <%= case I18n.locale when :fr then 'Historique des modifications' when :de then 'Änderungshistorie' when :en then 'Modification history' else 'Wijzigingshistoriek' end %>
          </h3>
          <div class="relative">
            <%# Timeline line %>
            <div class="absolute left-3 top-0 bottom-0 w-px bg-gray-200 dark:bg-gray-700"></div>
            <div class="space-y-3">
              <% history[:entries].each do |entry| %>
                <div class="relative pl-8">
                  <%# Timeline dot — red for abolition, amber for modifications %>
                  <% is_abolition = entry.label.match?(/OPGEHEVEN|ABROG/i) %>
                  <div class="absolute left-1.5 top-1.5 w-3 h-3 rounded-full border-2 <%= is_abolition ? 'bg-red-500 border-red-300 dark:border-red-700' : 'bg-amber-400 border-amber-200 dark:border-amber-700' %>"></div>

                  <div class="text-sm">
                    <%# Label badge %>
                    <span class="inline-block px-1.5 py-0.5 text-xs font-medium rounded
                      <%= is_abolition ?
                        'bg-red-100 text-red-700 dark:bg-red-900/40 dark:text-red-300' :
                        'bg-amber-100 text-amber-700 dark:bg-amber-900/40 dark:text-amber-300' %>">
                      <%= normalize_label.call(entry.label) %>
                    </span>

                    <%# Link to the modifying law — prefer WetWijzer page, fallback to Moniteur Belge %>
                    <% timeline_doc_num = entry.text.match(%r{\d{4}-\d{2}-\d{2}/[A-Za-z0-9]+})&.[](0) %>
                    <% timeline_lookup = timeline_doc_num ? doc_lookups[timeline_doc_num] : nil %>
                    <% timeline_lookup ||= entry_law_cache[entry.object_id] %>
                    <% if timeline_lookup %>
                      <a href="/laws/<%= timeline_lookup[:numac] %>?language_id=<%= timeline_lookup[:language_id] %>"
                         class="block mt-1 text-gray-800 dark:text-gray-300 hover:text-(--accent-600) dark:hover:text-(--accent-400) hover:underline"
                         title="<%= timeline_lookup[:title] %>">
                        <%= entry.text %>
                      </a>
                    <% else %>
                      <a href="<%= entry.href %>" target="_blank" rel="noopener noreferrer"
                         class="block mt-1 text-gray-800 dark:text-gray-300 hover:text-(--accent-600) dark:hover:text-(--accent-400) hover:underline">
                        <%= entry.text %>
                        <svg class="inline-block w-3 h-3 ml-0.5 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                        </svg>
                      </a>
                    <% end %>

                    <%# Modified articles %>
                    <% if entry.articles.present? %>
                      <p class="mt-0.5 text-xs text-gray-500 dark:text-gray-500">
                        <%= case I18n.locale when :fr then 'Articles modifiés' when :de then 'Geänderte Artikel' when :en then 'Modified articles' else 'Gewijzigde artikelen' end %>: <%= entry.articles %>
                      </p>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% else %>
    <%# Fragment cache: the articles partial is the single most expensive render in the app
        (4600+ articles = 50s). Cache key includes article count so it auto-busts on monthly updates. %>
    <% cache ["law_articles_v2", params[:numac], @language_id, @articles.size, @show_colors, @show_exdecs], expires_in: 7.days do %>
      <%= render partial: "laws/articles", locals: { articles: @articles, content: @content } %>
    <% end %>
  <% end %>
<% end %>
