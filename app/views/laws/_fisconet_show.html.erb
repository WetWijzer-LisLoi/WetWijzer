    <script nonce="<%= content_security_policy_nonce %>">
      function loadRelatedSource(type, btn) {
        var container = document.getElementById(type + '-content');
        if (!container) return;
        if (container.dataset.loaded === 'true') {
          container.classList.toggle('hidden');
          return;
        }
        btn.disabled = true;
        var origHTML = btn.innerHTML;
        btn.innerHTML = '<svg class="animate-spin h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> <%= case I18n.locale when :fr then "Chargement…" when :de then "Laden…" else "Laden…" end %>';
        fetch('<%= related_sources_law_path(@law.numac, language_id: @language_id) %>&type=' + type, {
          headers: { 'Accept': 'text/html' }
        })
        .then(function(r) { if (!r.ok) throw new Error('HTTP ' + r.status); return r.text(); })
        .then(function(html) {
          container.innerHTML = html;
          container.dataset.loaded = 'true';
          container.classList.remove('hidden');
          btn.innerHTML = origHTML;
          btn.disabled = false;
        })
        .catch(function() {
          container.innerHTML = '<div class="px-4 pb-4 text-sm text-red-600 dark:text-red-400"><%= case I18n.locale when :fr then "Échec du chargement" when :de then "Laden fehlgeschlagen" else "Laden mislukt" end %></div>';
          container.classList.remove('hidden');
          btn.innerHTML = origHTML;
          btn.disabled = false;
        });
      }

      // Bind buttons via event listeners (CSP-compliant)
      document.querySelectorAll('[data-source-type]').forEach(function(btn) {
        btn.addEventListener('click', function() {
          loadRelatedSource(this.dataset.sourceType, this);
        });
      });
    </script>

