<% lang_prefix = @language_id == 2 ? 'fr' : 'nl' %>
<% info = @fisconet_info %>
<%# Build TOC structure from section_path data %>
<%
  fisconet_toc_sections = []
  seen_sections = Set.new
  # Build set of valid article numbers for cross-reference linking (Story 1.3)
  fisconet_valid_art_nums = Set.new
  @fisconet_articles.each do |article|
    section = article[:section_path]
    if section.present? && !seen_sections.include?(section)
      seen_sections.add(section)
      fisconet_toc_sections << { type: :section, text: section, id: "fisconet-section-#{section.parameterize}" }
    end
    fisconet_toc_sections << { type: :article, number: article[:article_number], id: "art_#{article[:article_number]}", section: section }
    fisconet_valid_art_nums << article[:article_number].to_s
  end
  has_toc = fisconet_toc_sections.any? { |e| e[:type] == :section }
%>
<!-- Page Header (matches Justel show.html.erb) -->
<div class="mb-6" data-controller="articles-loading" data-articles-loading-frame-value="law_articles">
  <div class="bg-linear-to-r from-(--accent-500)/5 to-(--accent-500)/10 dark:from-(--accent-500)/10 dark:to-(--accent-500)/20 rounded-xl p-4 md:p-6">
    <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between md:gap-4">
      <div class="flex items-center gap-3">
        <h1 class="text-xl md:text-2xl font-bold text-gray-900 dark:text-(--accent-500)"><%= t(:details).capitalize() %></h1>
      </div>
      <div class="flex flex-wrap items-center gap-2 no-print">
        <%# Language switch %>
        <% other_language_id = @language_id == 1 ? 2 : 1 %>
        <%= link_to law_path(@law.numac, language_id: other_language_id),
                    class: "inline-flex items-center gap-1.5 px-2 py-1.5 md:px-3 text-xs md:text-sm font-medium rounded-lg text-(--accent-700) dark:text-(--accent-300) hover:bg-(--accent-500)/10 border border-(--accent-500)/20 transition-colors duration-150",
                    title: case I18n.locale when :fr then (@language_id == 1 ? "Voir la version française" : "Voir la version néerlandaise") when :de then (@language_id == 1 ? "Französische Version anzeigen" : "Niederländische Version anzeigen") when :en then (@language_id == 1 ? "View French version" : "View Dutch version") else (@language_id == 1 ? "Bekijk de Franstalige versie" : "Bekijk de Nederlandstalige versie") end do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129" /></svg>
          <span class="hidden sm:inline"><%= @language_id == 1 ? "FR" : "NL" %></span>
        <% end %>
        <%# Print %>
        <button type="button" data-controller="print" data-action="click->print#fire" class="inline-flex items-center gap-1.5 px-2 py-1.5 md:px-3 text-xs md:text-sm font-medium rounded-lg text-(--accent-700) dark:text-(--accent-300) hover:bg-(--accent-500)/10 border border-(--accent-500)/20 transition-colors duration-150" title="<%= case I18n.locale when :fr then 'Imprimer' when :de then 'Drucken' when :en then 'Print' else 'Afdrukken' end %>">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5 4v3H4a2 2 0 00-2 2v3a2 2 0 002 2h1v2a2 2 0 002 2h6a2 2 0 002-2v-2h1a2 2 0 002-2V9a2 2 0 00-2-2h-1V4a2 2 0 00-2-2H7a2 2 0 00-2 2zm8 0H7v3h6V4zm0 8H7v4h6v-4z" clip-rule="evenodd"/></svg>
        </button>
        <%# Bookmark %>
        <button type="button" class="bookmark-btn inline-flex items-center gap-1.5 px-2 py-1.5 md:px-3 text-xs md:text-sm font-medium rounded-lg text-(--accent-700) dark:text-(--accent-300) hover:bg-(--accent-500)/10 border border-(--accent-500)/20 transition-colors duration-150" data-controller="bookmark" data-bookmark-numac-value="<%= @law.numac %>" data-bookmark-title-value="<%= escape_once(@law.title.to_s.truncate(200)) %>" data-action="click->bookmark#toggle" title="<%= t('bookmarks.add') %>">
          <svg data-bookmark-target="icon" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z" /></svg>
        </button>
        <%# Copy reference dropdown %>
        <div class="relative" data-controller="copy-reference" data-copy-reference-numac-value="<%= @law.numac %>" data-copy-reference-title-value="<%= escape_once(@law.title.to_s) %>" data-copy-reference-date-value="<%= @law.date %>">
          <button type="button" class="inline-flex items-center gap-1.5 px-2 py-1.5 md:px-3 text-xs md:text-sm font-medium rounded-lg text-(--accent-700) dark:text-(--accent-300) hover:bg-(--accent-500)/10 border border-(--accent-500)/20 transition-colors duration-150" data-copy-reference-target="button" data-action="click->copy-reference#toggle" aria-haspopup="true" aria-expanded="false" title="<%= t('copy_reference.title') %>">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" /></svg>
          </button>
          <div data-copy-reference-target="menu" class="hidden absolute right-0 mt-1 w-48 rounded-md shadow-lg bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 z-50">
            <div class="py-1">
              <button type="button" class="w-full text-left px-4 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-(--accent-active-bg)" data-action="click->copy-reference#copyFull"><%= t('copy_reference.full') %></button>
              <button type="button" class="w-full text-left px-4 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-(--accent-active-bg)" data-action="click->copy-reference#copyNumac"><%= t('copy_reference.numac') %></button>
              <button type="button" class="w-full text-left px-4 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-(--accent-active-bg)" data-action="click->copy-reference#copyUrl"><%= t('copy_reference.url') %></button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Main Content Layout (matches Justel show.html.erb) -->
<div data-controller="sidebar-toggle toc-anchor" class="w-full pb-24 md:pb-0">
  <div data-sidebar-toggle-target="backdrop" class="hidden fixed inset-0 bg-black/30 z-30 md:hidden"></div>

  <% if has_toc %>
  <!-- Mobile-only fixed bottom bar with 3 equal buttons [Go to, Inhoud, Chat] -->
  <div class="md:hidden fixed bottom-0 inset-x-0 z-50 no-print" id="mobile-bottom-bar">
    <div class="flex items-stretch bg-white/95 dark:bg-gray-900/95 backdrop-blur border-t border-gray-200 dark:border-gray-700 shadow-[0_-2px_10px_rgba(0,0,0,0.08)]">
      <!-- Go to… jump menu -->
      <div id="fisconet-mobile-jump" data-controller="jump-select" data-jump-select-fallback-value="true" class="relative flex-1 overflow-visible">
        <button type="button"
                class="w-full flex flex-col items-center justify-center gap-1 py-2.5 text-gray-600 dark:text-gray-400 hover:text-(--accent-600) dark:hover:text-(--accent-400) transition-colors duration-150"
                data-action="jump-select#toggle"
                data-jump-select-target="button"
                aria-haspopup="true" aria-expanded="false"
                aria-label="<%= t(:go_to, default: 'Ga naar…') %>">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5">
            <path fill-rule="evenodd" d="M10 3a1 1 0 01.894.553l2 4A1 1 0 0112 9H8a1 1 0 01-.894-1.447l2-4A1 1 0 0110 3zm-3 8a1 1 0 000 2h6a1 1 0 100-2H7zm-2 4a1 1 0 000 2h10a1 1 0 100-2H5z" clip-rule="evenodd" />
          </svg>
          <span class="text-[10px] font-medium leading-none"><%= t(:go_to, default: 'Ga naar') %></span>
        </button>
        <div data-jump-select-target="menu" class="hidden absolute bottom-full left-0 mb-2 z-999 w-56 rounded-md shadow-lg ring-1 ring-black/10 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700" role="menu">
          <div class="py-1">
            <button type="button" role="menuitem" class="w-full text-left px-4 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-(--accent-active-bg)" data-action="jump-select#go" data-target="#external-links-card"><%= t(:external_links).capitalize %></button>
            <button type="button" role="menuitem" class="w-full text-left px-4 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-(--accent-active-bg)" data-action="jump-select#go" data-target="#document-info-card"><%= t(:document_info) %></button>
            <button type="button" role="menuitem" class="w-full text-left px-4 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-(--accent-active-bg)" data-action="jump-select#go" data-target="#title-card"><%= t(:title_details).capitalize %></button>
            <button type="button" role="menuitem" class="w-full text-left px-4 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-(--accent-active-bg)" data-action="jump-select#go" data-target="#main-toc-card"><%= t(:toc).capitalize %></button>
            <button type="button" role="menuitem" class="w-full text-left px-4 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-(--accent-active-bg)" data-action="jump-select#go" data-target="#tekst"><%= t(:articles_text).capitalize %></button>
          </div>
        </div>
      </div>

      <!-- TOC / Inhoud toggle -->
      <button type="button"
              class="flex-1 flex flex-col items-center justify-center gap-1 py-2.5 text-gray-600 dark:text-gray-400 hover:text-(--accent-600) dark:hover:text-(--accent-400) border-x border-gray-200 dark:border-gray-700 transition-colors duration-150"
              data-sidebar-toggle-target="button"
              data-sidebar-toggle-floating
              data-action="sidebar-toggle#toggle"
              aria-controls="toc-sidebar-panel"
              aria-label="<%= t('aria.open_sidebar') %>">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
          <path fill-rule="evenodd" d="M3.75 6.75a.75.75 0 01.75-.75h15a.75.75 0 010 1.5H4.5a.75.75 0 01-.75-.75zm0 5.25a.75.75 0 01.75-.75h15a.75.75 0 010 1.5H4.5a.75.75 0 01-.75-.75z" clip-rule="evenodd" />
        </svg>
        <span class="text-[10px] font-medium leading-none"><%= t(:toc, default: 'Inhoud') %></span>
      </button>

      <!-- Chatbot trigger -->
      <% if Rails.application.config.chatbot_enabled %>
        <button type="button" id="mobile-chat-btn"
                class="flex-1 flex flex-col items-center justify-center gap-1 py-2.5 text-(--accent-600) dark:text-(--accent-400) hover:text-(--accent-700) dark:hover:text-(--accent-300) transition-colors duration-150"
                data-chatbot-toggle
                aria-label="<%= case I18n.locale when :fr then 'Ouvrir le chatbot' when :de then 'Chatbot öffnen' else 'Chatbot openen' end %>">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/>
          </svg>
          <span class="text-[10px] font-medium leading-none">Chat</span>
        </button>
      <% end %>
    </div>
  </div>
  <% end %>

  <div class="flex flex-col md:flex-row gap-8 w-full">
  <!-- Sidebar TOC (matches Justel _toc.html.erb in sidebar mode) -->
  <% if has_toc %>
    <div id="toc-sidebar-panel" data-sidebar-toggle-target="panel" class="hidden fixed inset-y-0 left-0 z-40 w-80 max-w-[85vw] transform -translate-x-full transition-transform duration-300 ease-in-out p-2 md:p-0 order-2 md:order-1 md:static md:inset-auto md:z-auto md:w-80 md:min-w-80 md:max-w-80 md:shrink-0 md:sticky md:top-0 md:self-start pr-2 md:pr-0 space-y-6">
      <div id="toc-card-sidebar" class="relative bg-white dark:bg-gray-800 rounded-xl shadow-lg" data-controller="sidebar-auto-open">
        <button type="button" class="hidden md:flex items-center justify-center absolute top-0 right-0 z-1002 w-8 h-full rounded-none rounded-r-xl border-0 shadow-none bg-transparent text-gray-500 hover:text-gray-700 dark:text-(--accent-500)/60 dark:hover:text-(--accent-500) transition-colors duration-200 cursor-pointer" data-sidebar-toggle-target="button" data-action="sidebar-toggle#toggle" aria-controls="toc-sidebar-panel" aria-label="<%= t('aria.toggle_sidebar') %>">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 transition-transform duration-300" viewBox="0 0 24 24" fill="currentColor" data-sidebar-toggle-arrow><rect x="9" y="6" width="2" height="12" rx="1"></rect><rect x="13" y="6" width="2" height="12" rx="1"></rect></svg>
        </button>
        <div class="p-6 pr-3 md:pr-12" data-controller="toc-search">
          <div class="flex items-center justify-between mb-3">
            <h3 class="text-sm font-semibold text-gray-800 dark:text-(--accent-500) flex items-center">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 6.75h12M8.25 12h12m-12 5.25h12M3.75 6.75h.007v.008H3.75V6.75zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zM3.75 12h.007v.008H3.75V12zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zM3.75 17.25h.007v.008H3.75v-.008zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" /></svg>
              <%= t(:toc).capitalize() %>
            </h3>
            <div class="hidden md:flex items-center gap-2">
              <button type="button" class="inline-flex items-center justify-center w-6 h-6 rounded-full border bg-white/90 text-gray-700 shadow-sm hover:bg-white border-gray-200 dark:bg-gray-800/80 dark:text-gray-300 dark:border-gray-700 transition-all duration-150 active:scale-95" data-controller="scroll-top" data-action="click->scroll-top#fire" title="<%= t(:to_top, default: 'Naar boven') %>">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3.5 h-3.5"><path fill-rule="evenodd" d="M10 17a.75.75 0 0 1-.75-.75V5.612L5.29 9.77a.75.75 0 0 1-1.08-1.04l5.25-5.5a.75.75 0 0 1 1.08 0l5.25 5.5a.75.75 0 1 1-1.08 1.04l-3.96-4.158V16.25A.75.75 0 0 1 10 17Z" clip-rule="evenodd" /></svg>
              </button>
            </div>
          </div>
          <div class="mt-2 mb-2 relative">
            <input type="text" placeholder="<%= t(:filter_articles, default: 'Zoek artikel…') %>" class="w-full text-xs px-3 py-1.5 rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800/60 text-gray-700 dark:text-gray-300 placeholder-gray-400 dark:placeholder-gray-500 focus:outline-hidden focus:ring-1 focus:ring-(--accent-500)" data-toc-search-target="input" data-action="input->toc-search#filter" autocomplete="off">
            <button type="button" class="absolute right-2 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 hidden" data-action="click->toc-search#clear" data-toc-search-target="clearBtn" aria-label="Wissen">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3.5 h-3.5"><path d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 101.06 1.06L10 11.06l3.72 3.72a.75.75 0 101.06-1.06L11.06 10l3.72-3.72a.75.75 0 00-1.06-1.06L10 8.94 6.28 5.22z" /></svg>
            </button>
          </div>
          <nav class="toc-navigation max-h-[calc(100vh-200px)] overflow-y-auto overflow-x-hidden pr-2" style="scrollbar-width:thin;scrollbar-color:rgb(156 163 175) transparent" data-controller="toc-tracker" data-toc-search-target="list">
            <style nonce="<%= content_security_policy_nonce %>">.toc-navigation::-webkit-scrollbar{width:6px}.toc-navigation::-webkit-scrollbar-track{background:transparent}.toc-navigation::-webkit-scrollbar-thumb{background-color:rgb(156 163 175);border-radius:3px}.dark .toc-navigation::-webkit-scrollbar-thumb{background-color:rgb(75 85 99)}.toc-link.active{color:rgb(17 24 39)!important;background-color:rgb(243 244 246)!important;font-weight:500!important}.dark .toc-link.active{color:rgb(243 244 246)!important;background-color:rgb(31 41 55)!important}</style>
            <ul class="space-y-0.5 text-xs pr-3">
              <% fisconet_toc_sections.each do |entry| %>
                <% if entry[:type] == :section %>
                  <% is_top = entry[:text].match?(/^(HOOFDSTUK|TITEL|DEEL|CHAPITRE|TITRE|PART)/i) %>
                  <li class="<%= is_top ? 'pl-0' : 'pl-3' %> pt-1 first:pt-0">
                    <a href="#<%= entry[:id] %>" class="toc-link block <%= is_top ? 'font-semibold' : 'font-medium' %> text-gray-800 dark:text-gray-200 text-xs py-1.5 hover:text-gray-900 dark:hover:text-white hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors duration-150" data-toc-tracker-target="link" data-target="<%= entry[:id] %>" data-action="click->toc-anchor#handleClick"><%= entry[:text] %></a>
                  </li>
                <% else %>
                  <li class="pl-6">
                    <a href="#<%= entry[:id] %>" class="toc-link block py-1 px-2 text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors duration-150" data-toc-tracker-target="link" data-target="<%= entry[:id] %>" data-action="click->toc-anchor#handleClick"><span class="text-xs wrap-break-word">Art. <%= entry[:number] %></span></a>
                  </li>
                <% end %>
              <% end %>
            </ul>
          </nav>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Main Content Area -->
  <div class="flex-1 min-w-0 space-y-6 order-1 md:order-2">
    <div class="print-only-header hidden print:block text-sm text-gray-600 mb-4"><%= case I18n.locale when :fr then 'Consulté le' when :de then 'Abgerufen am' when :en then 'Accessed on' else 'Geraadpleegd op' end %>: <%= Date.today.strftime('%d-%m-%Y') %></div>

    <!-- External Links (matches _external_links.html.erb) -->
    <div id="external-links-card" class="no-print bg-white dark:bg-gray-800 rounded-xl shadow-lg scroll-mt-24">
      <div class="p-6" data-controller="collapse" data-collapse-expanded-value="true">
        <button type="button" class="w-full flex items-center justify-between text-left focus:outline-hidden focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-(--accent-500)" data-action="click->collapse#toggle" data-collapse-target="button" aria-expanded="true">
          <h2 class="text-xl font-bold text-gray-800 dark:text-(--accent-500)"><%= t(:external_links).capitalize() %></h2>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 transition-transform text-gray-500 dark:text-gray-400" viewBox="0 0 20 20" fill="currentColor" data-collapse-target="icon"><path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 10.94l3.71-3.71a.75.75 0 111.06 1.06l-4.24 4.24a.75.75 0 01-1.06 0L5.21 8.29a.75.75 0 01.02-1.08z" clip-rule="evenodd" /></svg>
        </button>
        <% justel_law = @law.numac_real.present? ? Legislation.find_by(numac: @law.numac_real, language_id: @language_id) : nil %>
        <ul class="space-y-2 mt-4" data-collapse-target="content">
          <% if @law.source_url.present? %>
            <li><%= link_to @law.source_url, class: "text-(--link-color) hover:text-(--link-hover-color) hover:underline", target: "_blank", rel: "nofollow" do %>Fisconet Plus <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 inline-block ml-1"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-4.5 0V6.75A.75.75 0 0114.25 6h1.5a.75.75 0 01.75.75v1.5m-4.5 0h4.5m-4.5 0l6-6" /></svg><% end %></li>
          <% end %>
          <% if justel_law&.justel.present? && justel_law.justel != "N/A" %>
            <li><%= link_to justel_law.justel, class: "text-(--link-color) hover:text-(--link-hover-color) hover:underline", target: "_blank", rel: "nofollow" do %><%= t(:justel).capitalize() %> <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 inline-block ml-1"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-4.5 0V6.75A.75.75 0 0114.25 6h1.5a.75.75 0 01.75.75v1.5m-4.5 0h4.5m-4.5 0l6-6" /></svg><% end %></li>
          <% end %>
          <% if justel_law %>
            <li><%= link_to law_path(justel_law.numac, language_id: @language_id), class: "text-(--link-color) hover:text-(--link-hover-color) hover:underline" do %>WetWijzer – <%= justel_law.title.to_s.truncate(80) %><% end %></li>
          <% end %>
        </ul>
      </div>
    </div>

    <!-- Related Sources (Parliamentary Work, Jurisprudence) - lazy-loaded on button click -->
    <div id="related-sources-card" class="no-print bg-white dark:bg-gray-800 rounded-xl shadow-lg scroll-mt-24">
      <div class="p-4 md:p-6">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-(--accent-500) mb-3">
          <%= case I18n.locale when :fr then 'Sources connexes' when :de then 'Verwandte Quellen' else 'Gerelateerde bronnen' end %>
