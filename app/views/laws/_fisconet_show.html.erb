                  <path fill-rule="evenodd" d="M3 17a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm3.293-7.707a1 1 0 011.414 0L9 10.586V3a1 1 0 112 0v7.586l1.293-1.293a1 1 0 111.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z" clip-rule="evenodd"/>
                </svg>
                <svg class="animate-spin h-4 w-4 hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" data-export-feedback-target="spinner">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
                <span data-export-feedback-target="label"><%= t('articles.export_odt') %></span>
              </button>
              <%# Export to ODT (citation) %>
              <button type="button"
                    class="btn-toggle-inactive"
                    data-controller="export-feedback"
                    data-action="click->export-feedback#download"
                    data-export-feedback-url-value="<%= export_odt_law_path(@law.numac, language_id: @language_id, citation: true) %>"
                    data-export-feedback-filename-value="<%= @law.title.to_s.parameterize.presence || @law.numac %>-citaat.odt"
                    title="<%= t('articles.export_odt_citation_tooltip') %>">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor" data-export-feedback-target="icon">
                  <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4zm2 6a1 1 0 011-1h6a1 1 0 110 2H7a1 1 0 01-1-1zm1 3a1 1 0 100 2h6a1 1 0 100-2H7z" clip-rule="evenodd"/>
                </svg>
                <svg class="animate-spin h-4 w-4 hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" data-export-feedback-target="spinner">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
                <span data-export-feedback-target="label"><%= t('articles.export_odt_citation') %></span>
              </button>
            </div>
            <% current_section = nil %>
            <% section_stack = [] %>
            <% prev_was_heading = false %>
            <% @fisconet_articles.each_with_index do |article, index| %>
              <% if article[:section_path].present? && article[:section_path] != current_section %>
                <% current_section = article[:section_path] %>
                <% section_id = "fisconet-section-#{current_section.parameterize}" %>
                <% is_top = current_section.match?(/^(HOOFDSTUK|TITEL|DEEL|CHAPITRE|TITRE|PART)/i) %>
                <% current_level = is_top ? 1 : 4 %>
                <% while section_stack.any? && section_stack.last >= current_level %><% section_stack.pop %></div></div><% end %>
                <div data-controller="collapse" data-collapse-expanded-value="true" class="collapsible-section">
                  <section class="section-heading group mt-2 md:mt-3 mb-2 md:mb-3" data-article-scope>
                    <h2 id="<%= section_id %>" class="scroll-mt-24 not-prose text-sm font-bold capitalize tracking-wide text-gray-700 dark:text-gray-200 flex items-start gap-2 flex-nowrap rounded-md px-2 py-1 transition-colors group hover:bg-gray-50 dark:hover:bg-gray-800">
                      <button type="button" class="flex items-start gap-2 flex-1 min-w-0 text-left focus:outline-hidden focus-visible:ring-2 focus-visible:ring-(--accent-500) focus-visible:ring-offset-2" data-action="click->collapse#toggle" data-collapse-target="button" aria-expanded="true">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 mt-0.5 shrink-0 transition-transform text-gray-500 dark:text-gray-400" viewBox="0 0 20 20" fill="currentColor" data-collapse-target="icon"><path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 10.94l3.71-3.71a.75.75 0 111.06 1.06l-4.24 4.24a.75.75 0 01-1.06 0L5.21 8.29a.75.75 0 01.02-1.08z" clip-rule="evenodd" /></svg>
                        <span><%= current_section %></span>
                      </button>
                    </h2>
                  </section>
                  <div data-collapse-target="content" class="section-content">
                  <% section_stack.push(current_level) %>
                  <% prev_was_heading = true %>
              <% end %>
              <% text = article[:text].to_s.strip %>
              <% html_content = article[:html].to_s.strip %>
              <% next if text.length <= 10 && html_content.length <= 10 %>
              <article id="art_<%= article[:article_number] %>" data-article-scope class="group relative scroll-mt-24 <%= (index.zero? || prev_was_heading) ? '' : 'border-t border-gray-200 dark:border-(--accent-500)/40' %>">
                <span id="section-art_<%= article[:article_number] %>" class="block h-0 overflow-hidden scroll-mt-24 mt-0!" aria-hidden="true"></span>
                <% top_pad = prev_was_heading ? 'pt-2' : 'pt-4' %>
                <div class="<%= top_pad %> pb-4 flex items-start">
                  <div class="flex-1 min-w-0" id="article-text-art_<%= article[:article_number] %>">
                    <div class="max-w-none article-content overflow-x-auto [&_table]:w-full [&_table]:max-w-full [&_table]:table-auto [&_td]:wrap-break-word [&_th]:wrap-break-word [&_p:last-child]:mb-0">
                      <% if article[:end_date].present? %>
                        <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-300 float-right ml-2"><%= @language_id == 2 ? 'Abrogé' : 'Opgeheven' %></span>
                      <% end %>
                      <% if html_content.present? && html_content.length > 10 %>
                        <% sanitized_html = sanitize(html_content, tags: %w[p br em strong b i u a ul ol li table tr td th thead tbody h1 h2 h3 h4 h5 h6 div span sup sub blockquote], attributes: %w[href title class style border cellpadding cellspacing width height align valign rowspan colspan]) %>
                        <p><span class="article-number not-prose font-bold text-gray-900 dark:text-white">Art. <%= article[:article_number] %>.</span> <%= linkify_tax_article_refs(sanitized_html, fisconet_valid_art_nums).html_safe %></p>
                      <% elsif text.present? && text.length > 10 %>
                        <%
                          # Clean text for rendering
                          clean_lines = text.strip.split("\n")

                          # Strip trailing section heading leftovers (HOOFDSTUK, TITEL, AFDELING, GEWESTELIJKE, VLAAMSE, etc.)
                          heading_pattern = /\A\s*(HOOFDSTUK|TITEL|DEEL|AFDELING|ONDERAFDELING|CHAPITRE|TITRE|SECTION|SOUS-SECTION|PART|GEWESTELIJKE|VLAAMSE|WAALSE|BRUSSELS|Tekst\s*:\s*WIB)/i
                          while clean_lines.any? && clean_lines.last.strip.match?(heading_pattern)
                            clean_lines.pop
                          end
                          # Also strip trailing lines that look like sub-section labels (single-letter headings like "J.- Diverse inkomsten...")
                          while clean_lines.any? && clean_lines.last.strip.match?(/\A[A-Z][a-z]?\.\s*-\s*.+/)
                            clean_lines.pop
                          end

                          # Build HTML with proper structure (matching Justel style)
                          rendered_parts = []
                          clean_lines.each do |line|
                            stripped = line.strip
                            if stripped.empty?
                              # Empty line = paragraph break (from \n\n in DB)
                              # Use same style as Justel: simple </p><p> with natural spacing
                              rendered_parts << '</p><p>'
                              next
                            end

                            if stripped.match?(/\A-{5,}\s*\(\d+\)/)
                              # Footnote reference line: ----- (1) art. 18, KB/WIB 92.
                              ref_text = stripped.sub(/\A-+\s*/, '')
                              rendered_parts << "<br><small class=\"text-gray-500 dark:text-gray-400\">#{ERB::Util.html_escape(ref_text)}</small>"
                            elsif stripped.match?(/\A-{5,}\z/)
                              # Pure separator line: ----------
                              rendered_parts << '<br><hr class="my-2 border-gray-300 dark:border-gray-600">'
                            elsif stripped.match?(/\A-{5,}\s*\S/)
                              # Separator with text: ---------- Vanaf 25 november...
                              after_dashes = stripped.sub(/\A-+\s*/, '')
                              rendered_parts << '<br><hr class="my-2 border-gray-300 dark:border-gray-600"><em class="text-gray-500 dark:text-gray-400 text-xs">' + ERB::Util.html_escape(after_dashes)
                            elsif stripped.start_with?('§') || stripped.match?(/\A\d+°/)
                              # Paragraph marker (§ 1., 1° etc.) - new paragraph like Justel
                              rendered_parts << '</p><p>' + ERB::Util.html_escape(stripped)
                            else
                              rendered_parts << '<br>' + ERB::Util.html_escape(stripped)
                            end
                          end
                          # Join and clean up: remove leading <br>
                          article_html = rendered_parts.join.sub(/\A<br>/, '')
                        %>
                        <p><span class="article-number not-prose font-bold text-gray-900 dark:text-white">Art. <%= article[:article_number] %>.</span> <%= linkify_tax_article_refs(article_html, fisconet_valid_art_nums).html_safe %></p>
                      <% else %>
                        <p><span class="article-number not-prose font-bold text-gray-900 dark:text-white">Art. <%= article[:article_number] %>.</span> <span class="text-gray-400">…</span></p>
                      <% end %>
                    </div>
                  </div>
                  <!-- Copy dropdown -->
                  <div class="relative shrink-0 ml-2 hidden sm:block md:opacity-0 md:group-hover:opacity-100 transition-opacity" data-controller="dropdown">
                    <button type="button" data-dropdown-target="button" data-action="click->dropdown#toggle" class="p-1 text-gray-400 hover:text-(--accent-600) transition-colors duration-200 rounded" title="<%= t(:copy_options, default: 'Kopieeropties') %>">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
                    </button>
                    <div data-dropdown-target="menu" class="hidden absolute right-0 top-full mt-1 w-48 bg-white dark:bg-gray-800 rounded-lg shadow-lg border border-gray-200 dark:border-gray-700 py-1 z-50">
                      <button type="button" data-controller="clipboard" data-action="click->clipboard#copy click->dropdown#close" data-clipboard-fragment-value="art_<%= article[:article_number] %>" data-clipboard-copied-label-value="<%= t(:link_copied) %>" class="w-full px-3 py-2 text-left text-sm text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700 flex items-center gap-2"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244" /></svg><%= t(:copy_article_link) %></button>
                      <button type="button" data-controller="clipboard" data-action="click->clipboard#copyText click->dropdown#close" data-clipboard-source-selector-value="#article-text-art_<%= article[:article_number] %>" data-clipboard-copied-label-value="<%= t(:text_copied) %>" class="w-full px-3 py-2 text-left text-sm text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700 flex items-center gap-2"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6M9.5 4.5A1.5 1.5 0 0111 3h2a1.5 1.5 0 011.5 1.5V6H17a2 2 0 012 2v9a2 2 0 01-2 2H7a2 2 0 01-2-2V8a2 2 0 012-2h2.5V4.5z" /></svg><%= t(:copy_article_text) %></button>
                      <button type="button" data-controller="clipboard" data-action="click->clipboard#copyCleanText click->dropdown#close" data-clipboard-source-selector-value="#article-text-art_<%= article[:article_number] %>" data-clipboard-copied-label-value="<%= t(:clean_text_copied) %>" class="w-full px-3 py-2 text-left text-sm text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700 flex items-center gap-2"><svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4zm2 6a1 1 0 011-1h6a1 1 0 110 2H7a1 1 0 01-1-1zm1 3a1 1 0 100 2h6a1 1 0 100-2H7z" clip-rule="evenodd"/></svg><%= t(:copy_clean_text) %></button>
                    </div>
                  </div>
                </div>
              </article>
              <% prev_was_heading = false %>
            <% end %>
            <% while section_stack.any? %><% section_stack.pop %></div></div><% end %>
            <% end %> <%# end cache block %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
</div>
