          <div class="flex flex-col"><dt class="font-medium text-gray-500 dark:text-gray-400 capitalize tracking-wide">Status</dt><dd class="mt-1"><% if @law.is_abolished %><span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-300"><%= @language_id == 2 ? 'Abrogé' : 'Opgeheven' %></span><% else %><span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-300"><%= @language_id == 2 ? 'En vigueur' : 'Van kracht' %></span><% end %></dd></div>
