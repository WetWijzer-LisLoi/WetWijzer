<%= content_for :title, t('account.invoices', default: 'Invoices') %>

<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-8 px-4 sm:px-6 lg:px-8">
  <div class="max-w-6xl mx-auto flex flex-col lg:flex-row gap-8">
    <%= render 'layouts/account_sidebar' %>

    <main class="flex-1 min-w-0">
      <!-- Header -->
      <div class="flex items-center justify-between mb-6">
        <div>
          <h1 class="text-2xl font-bold text-gray-900 dark:text-white">
            🧾 <%= t('account.invoices', default: 'Invoices') %>
          </h1>
          <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">
            <%= t('account.invoices_subtitle', default: 'Your invoices and credit notes') %>
          </p>
        </div>
      </div>

      <% if @invoices.any? %>
        <!-- Invoice Table -->
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg border border-gray-100 dark:border-gray-700 overflow-hidden">
          <div class="overflow-x-auto">
            <table class="w-full">
              <thead>
                <tr class="border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900/50">
                  <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 dark:text-gray-400 capitalize tracking-wider">
                    <%= t('invoices.number', default: 'Number') %>
                  </th>
                  <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 dark:text-gray-400 capitalize tracking-wider">
                    <%= t('invoices.date', default: 'Date') %>
                  </th>
                  <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 dark:text-gray-400 capitalize tracking-wider">
                    <%= t('invoices.type', default: 'Type') %>
                  </th>
                  <th class="text-right px-4 py-3 text-xs font-semibold text-gray-500 dark:text-gray-400 capitalize tracking-wider">
                    <%= t('invoices.total', default: 'Total') %>
                  </th>
                  <th class="text-center px-4 py-3 text-xs font-semibold text-gray-500 dark:text-gray-400 capitalize tracking-wider">
                    <%= t('invoices.status', default: 'Status') %>
                  </th>
                  <th class="text-right px-4 py-3 text-xs font-semibold text-gray-500 dark:text-gray-400 capitalize tracking-wider">
                    <%= t('invoices.download', default: 'Download') %>
                  </th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
                <% @invoices.each do |invoice| %>
                  <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors">
                    <td class="px-4 py-3">
                      <span class="font-mono text-sm font-medium text-gray-900 dark:text-white">
                        <%= invoice.invoice_number %>
                      </span>
                    </td>
                    <td class="px-4 py-3 text-sm text-gray-600 dark:text-gray-300">
                      <%= l(invoice.created_at.to_date, format: :long) rescue invoice.created_at.strftime('%d/%m/%Y') %>
                    </td>
                    <td class="px-4 py-3">
                      <% case invoice.invoice_type %>
                      <% when 'subscription' %>
                        <span class="inline-flex items-center gap-1 px-2 py-0.5 text-xs font-medium rounded-full bg-blue-100 dark:bg-blue-900/50 text-blue-700 dark:text-blue-300">
                          <%= t('invoices.type_subscription', default: 'Subscription') %>
                        </span>
                      <% when 'credit_purchase' %>
                        <span class="inline-flex items-center gap-1 px-2 py-0.5 text-xs font-medium rounded-full bg-green-100 dark:bg-green-900/50 text-green-700 dark:text-green-300">
                          🪙 <%= t('invoices.type_credits', default: 'Credits') %>
                        </span>
                      <% when 'credit_note' %>
                        <span class="inline-flex items-center gap-1 px-2 py-0.5 text-xs font-medium rounded-full bg-red-100 dark:bg-red-900/50 text-red-700 dark:text-red-300">
                          ↩️ <%= t('invoices.type_credit_note', default: 'Credit Note') %>
                        </span>
                      <% else %>
                        <span class="inline-flex items-center px-2 py-0.5 text-xs font-medium rounded-full bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300">
                          <%= invoice.invoice_type.humanize %>
                        </span>
                      <% end %>
                    </td>
                    <td class="px-4 py-3 text-right">
                      <span class="font-semibold text-gray-900 dark:text-white">
                        €<%= number_with_precision(invoice.total_euros, precision: 2) %>
                      </span>
                      <% if invoice.vat_cents > 0 %>
                        <div class="text-xs text-gray-500 dark:text-gray-400">
                          (<%= t('invoices.excl_vat', default: 'excl. VAT') %> €<%= number_with_precision(invoice.subtotal_euros, precision: 2) %>)
                        </div>
                      <% end %>
                    </td>
                    <td class="px-4 py-3 text-center">
                      <% case invoice.status %>
                      <% when 'sent', 'peppol_sent' %>
                        <span class="inline-flex items-center px-2 py-0.5 text-xs font-medium rounded-full bg-green-100 dark:bg-green-900/50 text-green-700 dark:text-green-300">
                          ✅ <%= t('invoices.status_sent', default: 'Sent') %>
                        </span>
                      <% when 'generated' %>
                        <span class="inline-flex items-center px-2 py-0.5 text-xs font-medium rounded-full bg-yellow-100 dark:bg-yellow-900/50 text-yellow-700 dark:text-yellow-300">
                          ⏳ <%= t('invoices.status_processing', default: 'Processing') %>
                        </span>
                      <% when 'failed' %>
                        <span class="inline-flex items-center px-2 py-0.5 text-xs font-medium rounded-full bg-red-100 dark:bg-red-900/50 text-red-700 dark:text-red-300">
                          ❌ <%= t('invoices.status_failed', default: 'Failed') %>
                        </span>
                      <% end %>
                    </td>
                    <td class="px-4 py-3 text-right">
                      <div class="flex items-center justify-end gap-2">
                        <% if invoice.pdf_exists? %>
                          <%= link_to download_invoice_path(invoice), class: "inline-flex items-center gap-1 px-2.5 py-1.5 text-xs font-medium rounded-lg bg-blue-50 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 hover:bg-blue-100 dark:hover:bg-blue-900/50 transition-colors" do %>
                            📄 PDF
                          <% end %>
                        <% end %>
                        <% if invoice.xml_exists? %>
                          <%= link_to download_invoice_xml_path(invoice), class: "inline-flex items-center gap-1 px-2.5 py-1.5 text-xs font-medium rounded-lg bg-gray-50 dark:bg-gray-700 text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-600 transition-colors" do %>
                            🔗 XML
                          <% end %>
                        <% end %>
                      </div>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      <% else %>
        <!-- Empty State -->
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg border border-gray-100 dark:border-gray-700 p-12 text-center">
          <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-gray-100 dark:bg-gray-700 flex items-center justify-center text-3xl">
            🧾
          </div>
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">
            <%= t('invoices.empty_title', default: 'No invoices yet') %>
          </h3>
          <p class="text-sm text-gray-500 dark:text-gray-400 max-w-md mx-auto">
            <%= t('invoices.empty_description', default: 'Invoices for subscriptions and credit purchases will appear here.') %>
          </p>
        </div>
      <% end %>
    </main>
  </div>
</div>
