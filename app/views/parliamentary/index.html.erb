<% @title = case I18n.locale when :fr then 'Travaux Préparatoires Belges' when :de then 'Belgische Gesetzgebungsvorarbeiten' when :en then 'Belgian Parliamentary Preparatory Works' else 'Belgische Parlementaire Voorbereidingen' end %>
<% parl_labels = { 'chamber' => 'Kamer', 'senate' => 'Senaat', 'vlaams' => 'Vlaams Parlement', 'brussels' => 'Brussels Parlement', 'waals' => 'Waals Parlement' } %>

<div class="max-w-6xl mx-auto px-4">
  <!-- Header with count -->
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-blue-400 mb-2 flex items-center gap-3">
      <span class="text-4xl">🏛️</span>
      <% case I18n.locale when :fr %>Travaux Préparatoires<% when :de %>Gesetzgebungsvorarbeiten<% when :en %>Parliamentary Works<% else %>Parlementaire Voorbereidingen<% end %>
    </h1>
    <p class="text-lg text-gray-600 dark:text-gray-300">
      <% case I18n.locale
         when :fr %><span class="font-semibold text-(--accent-600) dark:text-(--accent-400)"><%= number_with_delimiter(@total_count) %></span> documents disponibles<%
         when :de %><span class="font-semibold text-(--accent-600) dark:text-(--accent-400)"><%= number_with_delimiter(@total_count) %></span> Dokumente verfügbar<%
         when :en %><span class="font-semibold text-(--accent-600) dark:text-(--accent-400)"><%= number_with_delimiter(@total_count) %></span> documents available<%
         else %><span class="font-semibold text-(--accent-600) dark:text-(--accent-400)"><%= number_with_delimiter(@total_count) %></span> documenten beschikbaar<%
      end %>
    </p>
  </div>

  <!-- Recent Documents (shown when no search is active) -->
  <% unless @query.present? || @parliament.present? || @year.present? || @legislature.present? || @numac.present? %>
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg p-4 sm:p-6 mb-8">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-bold text-gray-900 dark:text-white flex items-center gap-2">
          <svg class="w-5 h-5 text-(--accent-600)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <% case I18n.locale when :fr %>Documents récents<% when :de %>Aktuelle Dokumente<% when :en %>Recent documents<% else %>Recente documenten<% end %>
        </h2>
      </div>

      <% if @documents.any? %>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          <% @documents.first(6).each do |doc| %>
            <a href="<%= parliamentary_path(id: doc[:id]) %>"
               class="block p-4 rounded-xl hover:bg-gray-50 dark:hover:bg-sky/10 transition-all duration-200 group">
              <div class="font-medium text-gray-900 dark:text-blue-400 text-sm mb-2 group-hover:text-(--accent-600) dark:group-hover:text-(--accent-400) transition-colors line-clamp-2">
                <%= clean_parliamentary_title_display(doc[:title], doc[:dossier_number], doc: doc) %>
              </div>
              <div class="flex items-center gap-2 mb-2">
                <span class="px-2 py-0.5 text-xs bg-green-100 text-green-700 dark:bg-green-900/40 dark:text-green-300 rounded"><%= parl_labels[doc[:parliament]] || doc[:parliament] %></span>
                <span class="text-xs text-gray-500 dark:text-gray-300/70 font-mono"><%= doc[:dossier_number] %></span>
                <% if doc[:dossier_vote_result].present? %>
                  <% vr = doc[:dossier_vote_result] %>
                  <% if vr.match?(/AANGENOMEN|ADOPTÉE/i) %>
                    <span class="px-1.5 py-0.5 rounded text-xs font-semibold bg-emerald-100 text-emerald-700 dark:bg-emerald-900/40 dark:text-emerald-300" title="<%= vr %>">✅</span>
                  <% elsif vr.match?(/VERWORPEN|REJETÉE/i) %>
                    <span class="px-1.5 py-0.5 rounded text-xs font-semibold bg-red-100 text-red-700 dark:bg-red-900/40 dark:text-red-300" title="<%= vr %>">❌</span>
                  <% end %>
                <% elsif doc[:dossier_status].present? %>
                  <% st = doc[:dossier_status] %>
                  <% if st.include?('AANGENOMEN') || st.include?('BEKRACHTIGD') %>
                    <span class="px-1.5 py-0.5 rounded text-xs font-semibold bg-emerald-100 text-emerald-700 dark:bg-emerald-900/40 dark:text-emerald-300">✅</span>
                  <% elsif st.include?('VERWORPEN') %>
                    <span class="px-1.5 py-0.5 rounded text-xs font-semibold bg-red-100 text-red-700 dark:bg-red-900/40 dark:text-red-300">❌</span>
                  <% elsif st.include?('HANGEND') %>
                    <span class="px-1.5 py-0.5 rounded text-xs font-semibold bg-yellow-100 text-yellow-700 dark:bg-yellow-900/40 dark:text-yellow-300">⏳</span>
                  <% end %>
                <% end %>
              </div>
              <div class="flex items-center text-xs text-gray-500 dark:text-gray-300/70 gap-1">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
                <%= doc[:date] %>
              </div>
            </a>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>

  <!-- Search Form -->
  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg p-6 mb-8" data-controller="collapsible-filters">
    <%= form_with url: parliamentary_work_path, method: :get, local: true do %>
      <% if @numac.present? %>
        <input type="hidden" name="numac" value="<%= @numac %>">
      <% end %>
      <!-- Main search bar -->
      <div class="flex flex-col sm:flex-row gap-4 mb-6">
        <div class="flex-1 relative">
          <input type="text" name="q" value="<%= @query %>" 
                 class="w-full pl-4 pr-4 py-3 rounded-xl border border-gray-300 dark:border-gray-600/50 dark:bg-gray-800 dark:text-gray-300 focus:border-(--accent-400) focus:ring-2 focus:ring-(--accent-200) dark:focus:ring-(--accent-500)/30 transition-all"
                 placeholder="<%= case I18n.locale when :fr then 'Titre, numéro de dossier...' when :de then 'Titel, Dossiernummer...' when :en then 'Title, dossier number...' else 'Titel, dossiernummer...' end %>">
        </div>
        <button type="submit" class="px-8 py-3 bg-(--accent-600-solid) hover:bg-(--accent-700-solid) text-white font-semibold rounded-xl text-sm shadow-lg transition-all">
          <% case I18n.locale when :fr %>Rechercher<% when :de %>Suchen<% when :en %>Search<% else %>Zoeken<% end %>
        </button>
      </div>

      <!-- Filters -->
      <div class="space-y-4" data-collapsible-filters-target="content">
        <!-- Row 1: Main filters -->
        <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
          <!-- Parliament -->
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
              <% case I18n.locale when :de %>Parlament<% when :en %>Parliament<% else %>Parlement<% end %>
            </label>
            <select name="parliament" class="w-full py-2 px-3 rounded-lg border border-gray-300 dark:border-gray-600/50 dark:bg-gray-800 dark:text-gray-300 text-sm focus:ring-2 focus:ring-(--accent-500)">
              <option value=""><%= case I18n.locale when :fr then 'Tous' when :de then 'Alle' when :en then 'All' else 'Alle' end %></option>

              <% @parliaments.each do |parl| %>
                <option value="<%= parl %>" <%= 'selected' if @parliament == parl %>><%= parl_labels[parl] || parl.capitalize %></option>
              <% end %>
            </select>
          </div>

          <!-- Legislature -->
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
              <% case I18n.locale when :fr %>Législature<% when :de %>Legislaturperiode<% when :en %>Legislature<% else %>Legislatuur<% end %>
            </label>
            <select name="legislature" class="w-full py-2 px-3 rounded-lg border border-gray-300 dark:border-gray-600/50 dark:bg-gray-800 dark:text-gray-300 text-sm focus:ring-2 focus:ring-(--accent-500)">
              <option value=""><%= case I18n.locale when :fr then 'Toutes' when :de then 'Alle' when :en then 'All' else 'Alle' end %></option>
              <% (@legislatures || []).each do |leg| %>
                <option value="<%= leg %>" <%= 'selected' if @legislature.to_i == leg %>><%= leg %></option>
              <% end %>
            </select>
          </div>

          <!-- Year -->
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
              <% case I18n.locale when :fr %>Année<% when :de %>Jahr<% when :en %>Year<% else %>Jaar<% end %>
            </label>
            <select name="year" class="w-full py-2 px-3 rounded-lg border border-gray-300 dark:border-gray-600/50 dark:bg-gray-800 dark:text-gray-300 text-sm focus:ring-2 focus:ring-(--accent-500)">
              <option value=""><%= case I18n.locale when :fr then 'Toutes' when :de then 'Alle' when :en then 'All' else 'Alle' end %></option>
              <% @years.each do |y| %>
                <option value="<%= y %>" <%= 'selected' if @year.to_i == y %>><%= y %></option>
              <% end %>
            </select>
          </div>

          <!-- Sorting -->
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
              <% case I18n.locale when :fr %>Trier<% when :de %>Sortieren<% when :en %>Sort<% else %>Sorteren<% end %>
            </label>
            <select name="sort" class="w-full py-2 px-3 rounded-lg border border-gray-300 dark:border-gray-600/50 dark:bg-gray-800 dark:text-gray-300 text-sm focus:ring-2 focus:ring-(--accent-500)">
              <option value="date_desc" <%= 'selected' if @sort == 'date_desc' %>><%= case I18n.locale when :fr then 'Plus récent' when :de then 'Neueste zuerst' when :en then 'Newest first' else 'Nieuwste eerst' end %></option>
              <option value="date_asc" <%= 'selected' if @sort == 'date_asc' %>><%= case I18n.locale when :fr then 'Plus ancien' when :de then 'Älteste zuerst' when :en then 'Oldest first' else 'Oudste eerst' end %></option>
            </select>
          </div>

          <!-- Clear filters -->
          <div class="flex items-end">
            <% if @query.present? || @parliament.present? || @year.present? || @legislature.present? || @numac.present? %>
              <a href="<%= parliamentary_work_path %>" 
                 class="inline-flex items-center gap-1 text-sm text-gray-500 dark:text-gray-300 hover:text-red-500 dark:hover:text-red-400 transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
                <% case I18n.locale when :fr %>Effacer<% when :de %>Löschen<% when :en %>Clear<% else %>Wissen<% end %>
              </a>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Results -->
  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg overflow-hidden">
    <% if @documents.empty? %>
      <div class="p-12 text-center">
        <svg class="mx-auto h-16 w-16 text-gray-300 dark:text-gray-600 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
        </svg>
        <% if @db_unavailable %>
          <p class="text-gray-500 dark:text-gray-300 text-lg font-medium mb-2">
             <% case I18n.locale
                when :fr %>Bientôt disponible<%
                when :de %>Demnächst verfügbar<%
                when :en %>Coming soon<%
                else %>Binnenkort beschikbaar<%
             end %>
          </p>
          <p class="text-gray-400 dark:text-gray-300/70 text-sm">
            <% case I18n.locale
               when :fr %>La base de données parlementaire est en cours de préparation.<%
               when :de %>Die parlamentarische Datenbank wird derzeit vorbereitet.<%
               when :en %>The parliamentary database is currently being prepared.<%
               else %>De parlementaire databank wordt momenteel voorbereid.<%
            end %>
          </p>
        <% else %>
          <p class="text-gray-500 dark:text-gray-300 text-lg font-medium mb-2">
            <% case I18n.locale
               when :fr %>Aucun document trouvé<%
               when :de %>Keine Dokumente gefunden<%
               when :en %>No documents found<%
               else %>Geen documenten gevonden<%
            end %>
          </p>
          <p class="text-gray-400 dark:text-gray-300/70 text-sm">
            <% case I18n.locale
               when :fr %>Essayez d'élargir vos critères de recherche<%
               when :de %>Versuchen Sie, Ihre Suchkriterien zu erweitern<%
               when :en %>Try broadening your search criteria<%
               else %>Probeer uw zoekcriteria te verruimen<%
            end %>
          </p>
        <% end %>
      </div>
    <% else %>
      <div class="space-y-4 p-4">
        <% @documents.each do |doc| %>
          <a href="<%= parliamentary_path(doc[:id]) %>" 
             class="block p-5 bg-white dark:bg-gray-800 rounded-xl shadow-md hover:border-(--accent-400) dark:hover:border-(--accent-400) hover:shadow-xl transition-all duration-200 group overflow-hidden">
            
            <!-- Top row: Parliament badge + Document type + Date -->
            <div class="flex items-center justify-between mb-2">
              <div class="flex items-center gap-2 text-sm flex-wrap">
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-(--accent-100) text-(--accent-700) dark:bg-(--accent-500)/20 dark:text-(--accent-300)">
                  <%= parl_labels[doc[:parliament]] || doc[:parliament]&.capitalize %>
                </span>
                <% if doc[:document_type].present? %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-300">
                    <%= doc[:document_type].gsub('_', ' ').capitalize %>
                  </span>
                <% end %>
                <% if doc[:dossier_status].present? %>
                  <% st = doc[:dossier_status] %>
                  <% if st.include?('AANGENOMEN') || st.include?('BEKRACHTIGD') %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold bg-green-100 text-green-800 dark:bg-green-900/40 dark:text-green-300">✅</span>
                  <% elsif st.include?('VERWORPEN') %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold bg-red-100 text-red-800 dark:bg-red-900/40 dark:text-red-300">❌</span>
                  <% elsif st.include?('HANGEND') %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold bg-yellow-100 text-yellow-800 dark:bg-yellow-900/40 dark:text-yellow-300">⏳</span>
                  <% elsif st.include?('VERVALLEN') || st.include?('INGETROKKEN') %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold bg-gray-100 text-gray-600 dark:bg-gray-800 dark:text-gray-400">⊘</span>
                  <% end %>
                <% end %>
                <% if doc[:date].present? %>
                  <span class="text-gray-400 dark:text-gray-300/50 text-xs"><%= doc[:date] %></span>
                <% end %>
              </div>
              
              <!-- Arrow -->
              <svg class="w-5 h-5 text-gray-300 group-hover:text-(--accent-500) dark:group-hover:text-(--accent-400) transition-colors shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </div>
            
            <%# Document title – pass full doc for content-based extraction when title is generic %>
            <% cleaned_title = clean_parliamentary_title_display(doc[:title], doc[:dossier_number], doc: doc) %>
            <h3 class="font-semibold text-gray-900 dark:text-blue-400 text-base group-hover:text-(--accent-600) dark:group-hover:text-(--accent-400) transition-colors mb-1.5 line-clamp-2">
              <%= cleaned_title %>
            </h3>

            <%# 2-line content description (cleaned of OCR artifacts) %>
            <% cleaned_desc = doc[:description].present? ? clean_parliamentary_description(doc[:description]) : '' %>
            <% if cleaned_desc.present? %>
              <p class="text-sm text-gray-500 dark:text-gray-300/70 mb-2 leading-relaxed line-clamp-2">
                <%= cleaned_desc %>
              </p>
            <% end %>
            
            <!-- Bottom row: dossier number -->
            <div class="flex items-center gap-2 text-xs text-gray-400 dark:text-gray-300/50">
              <% if doc[:dossier_number].present? %>
                <span class="font-mono">📁 <%= doc[:dossier_number] %></span>
              <% end %>
              <% if doc[:document_number].present? && doc[:document_number] != doc[:dossier_number] %>
                <span class="text-gray-300 dark:text-blue-400/20">|</span>
                <span class="font-mono">📄 <%= doc[:document_number] %></span>
              <% end %>
            </div>
          </a>
        <% end %>
      </div>
    <% end %>

    <!-- Pagination -->
    <% if @total_pages > 1 %>
      <% filter_params = { q: @query, parliament: @parliament, legislature: @legislature, year: @year, sort: @sort, numac: @numac }.compact %>
      <div class="px-6 py-4 bg-gray-50 dark:bg-gray-800/50">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
          <div class="text-sm text-gray-600 dark:text-gray-300">
            <% case I18n.locale
               when :fr %>Page <span class="font-semibold"><%= @page %></span> sur <span class="font-semibold"><%= @total_pages %></span><%
               when :de %>Seite <span class="font-semibold"><%= @page %></span> von <span class="font-semibold"><%= @total_pages %></span><%
               when :en %>Page <span class="font-semibold"><%= @page %></span> of <span class="font-semibold"><%= @total_pages %></span><%
               else %>Pagina <span class="font-semibold"><%= @page %></span> van <span class="font-semibold"><%= @total_pages %></span><%
            end %>
          </div>
          <div class="flex items-center gap-1">
            <% if @page > 1 %>
              <a href="<%= parliamentary_work_path(filter_params.merge(page: 1)) %>"
                 class="px-3 py-1.5 text-sm text-gray-500 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-sky/10 rounded transition-colors">«</a>
              <a href="<%= parliamentary_work_path(filter_params.merge(page: @page - 1)) %>"
                 class="px-3 py-1.5 text-sm text-gray-500 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-sky/10 rounded transition-colors">‹</a>
            <% end %>
            <% 
              pages_to_show = [1]
              ([@page - 2, 2].max..[@page + 2, @total_pages - 1].min).each { |p| pages_to_show << p }
              pages_to_show << @total_pages if @total_pages > 1
              pages_to_show = pages_to_show.uniq.sort
              prev_page = 0
            %>
            <% pages_to_show.each do |p| %>
              <% if p > prev_page + 1 %>
                <span class="px-2 text-gray-400">…</span>
              <% end %>
              <% if p == @page %>
                <span class="px-3 py-1.5 bg-(--accent-600-solid) text-white text-sm rounded-lg font-medium"><%= p %></span>
              <% else %>
                <a href="<%= parliamentary_work_path(filter_params.merge(page: p)) %>"
                   class="px-3 py-1.5 text-sm text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-sky/10 rounded-lg transition-colors"><%= p %></a>
              <% end %>
              <% prev_page = p %>
            <% end %>
            <% if @page < @total_pages %>
              <a href="<%= parliamentary_work_path(filter_params.merge(page: @page + 1)) %>"
                 class="px-3 py-1.5 text-sm text-gray-500 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-sky/10 rounded transition-colors">›</a>
              <a href="<%= parliamentary_work_path(filter_params.merge(page: @total_pages)) %>"
                 class="px-3 py-1.5 text-sm text-gray-500 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-sky/10 rounded transition-colors">»</a>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Link to chatbot -->
  <% if Rails.application.config.chatbot_enabled %>
  <div class="mt-8 text-center">
    <a href="<%= chatbot_path(source: 'parliamentary') %>" 
       class="inline-flex items-center gap-2 px-6 py-3 text-white font-medium rounded-xl shadow-lg hover:shadow-xl transition-all"
       style="background: linear-gradient(135deg, var(--accent-600-solid, #2563eb), var(--accent-700-solid, #4f46e5));">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/>
      </svg>
      <% case I18n.locale
         when :fr %>Poser une question à l'assistant IA<%
         when :de %>Stellen Sie eine Frage an den KI-Assistenten<%
         when :en %>Ask the AI assistant a question<%
         else %>Stel een vraag aan de AI-assistent<%
      end %>
    </a>
  </div>
  <% end %>

</div>
