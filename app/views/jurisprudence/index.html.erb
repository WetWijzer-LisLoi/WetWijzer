<% @title = case I18n.locale when :fr then 'Jurisprudence Belge' when :de then 'Belgische Rechtsprechung' when :en then 'Belgian Case Law' else 'Belgische Rechtspraak' end %>

<div class="max-w-6xl mx-auto px-4">
  <!-- Header with count -->
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-blue-400 mb-2 flex items-center gap-3">
      <span class="text-4xl">⚖️</span>
      <%= case I18n.locale when :fr then 'Jurisprudence Belge' when :de then 'Belgische Rechtsprechung' when :en then 'Belgian Case Law' else 'Belgische Rechtspraak' end %>
    </h1>
    <p class="text-lg text-gray-600 dark:text-gray-300">
      <span class="font-semibold text-(--accent-600) dark:text-(--accent-400)"><%= number_with_delimiter(@total_count) %></span> <%= case I18n.locale when :fr then 'arrêts disponibles' when :de then 'verfügbare Urteile' when :en then 'cases available' else 'arresten beschikbaar' end %>
    </p>
  </div>

  <!-- Search Form -->
  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg p-6 mb-8" data-controller="collapsible-filters">
    <%= form_with url: jurisprudence_index_path, method: :get, local: true, data: { turbo_frame: "jurisprudence_results" } do %>
      <!-- Main search bar -->
      <div class="flex flex-col sm:flex-row gap-4 mb-6">
        <div class="flex-1 relative">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
          <input type="text" name="q" value="<%= @query %>" 
                 class="w-full pl-10 pr-4 py-3 rounded-xl border border-gray-300 dark:border-gray-600/50 dark:bg-gray-800 dark:text-gray-300 text-base focus:ring-2 focus:ring-(--accent-500) focus:border-transparent"
                 placeholder="<%= case I18n.locale when :fr then 'Rechercher: ECLI, mots-clés...' when :de then 'Suchen: ECLI, Stichwörter...' when :en then 'Search: ECLI, keywords...' else 'Zoeken: ECLI, trefwoorden...' end %>">
        </div>
        <button type="submit" class="px-6 py-3 bg-(--accent-600-solid) hover:bg-(--accent-700-solid) text-white font-semibold rounded-xl text-base transition-colors shadow-lg shadow-(--accent-600)/25 hover:shadow-(--accent-600)/40">
          <%= case I18n.locale when :fr then 'Rechercher' when :de then 'Suchen' when :en then 'Search' else 'Zoeken' end %>
        </button>
      </div>

      <!-- Filters -->
      <div class="space-y-4" data-collapsible-filters-target="content">
        <!-- Row 1: Main filters -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <!-- Court -->
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
              <%= case I18n.locale when :fr then 'Cour' when :de then 'Gericht' when :en then 'Court' else 'Hof' end %>
            </label>
            <select name="court" class="w-full py-2.5 rounded-lg border-gray-300 dark:border-gray-600/50 dark:bg-gray-800 dark:text-gray-300 text-sm focus:ring-2 focus:ring-(--accent-500)">
              <option value=""><%= case I18n.locale when :fr then 'Toutes les cours' when :de then 'Alle Gerichte' when :en then 'All courts' else 'Alle hoven' end %></option>
              <% @grouped_courts.each do |level_label, courts| %>
                <optgroup label="<%= level_label %>">
                  <% courts.each do |display_name, value| %>
                    <option value="<%= value %>" <%= 'selected' if @court == value %>><%= display_name %></option>
                  <% end %>
                </optgroup>
              <% end %>
            </select>
          </div>

          <!-- Subject Matter -->
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
              <%= case I18n.locale when :fr then 'Matière' when :de then 'Rechtsgebiet' when :en then 'Subject' else 'Rechtsgebied' end %>
            </label>
            <select name="subject" class="w-full py-2.5 rounded-lg border-gray-300 dark:border-gray-600/50 dark:bg-gray-800 dark:text-gray-300 text-sm focus:ring-2 focus:ring-(--accent-500)">
              <option value=""><%= case I18n.locale when :fr then 'Toutes les matières' when :de then 'Alle Rechtsgebiete' when :en then 'All subjects' else 'Alle rechtsgebieden' end %></option>
              <% @subject_matters.each do |label, value| %>
                <option value="<%= value %>" <%= 'selected' if @subject == value %>><%= label %></option>
              <% end %>
            </select>
          </div>

          <!-- Year -->
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
              <%= case I18n.locale when :fr then 'Année' when :de then 'Jahr' when :en then 'Year' else 'Jaar' end %>
            </label>
            <select name="year" class="w-full py-2.5 rounded-lg border-gray-300 dark:border-gray-600/50 dark:bg-gray-800 dark:text-gray-300 text-sm focus:ring-2 focus:ring-(--accent-500)">
              <option value=""><%= case I18n.locale when :fr then 'Toutes' when :de then 'Alle' when :en then 'All' else 'Alle' end %></option>
              <% (Date.current.year).downto(1985).each do |y| %>
                <option value="<%= y %>" <%= 'selected' if @year.to_i == y %>><%= y %></option>
              <% end %>
            </select>
          </div>

          <!-- Language -->
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
              <%= case I18n.locale when :fr then 'Langue' when :de then 'Sprache' when :en then 'Language' else 'Taal' end %>
            </label>
            <select name="lang" class="w-full py-2.5 rounded-lg border-gray-300 dark:border-gray-600/50 dark:bg-gray-800 dark:text-gray-300 text-sm focus:ring-2 focus:ring-(--accent-500)">
              <option value=""><%= case I18n.locale when :fr then 'Toutes' when :de then 'Alle' when :en then 'All' else 'Alle' end %></option>
              <option value="NL" <%= 'selected' if @lang == 'NL' %>>Nederlands</option>
              <option value="FR" <%= 'selected' if @lang == 'FR' %>>Français</option>
            </select>
          </div>
        </div>

        <!-- Row 2: Date range + per page + sort + clear -->
        <div class="flex flex-wrap items-end gap-4 pt-4">
          <div class="flex items-end gap-2">
            <div>
              <label class="block text-xs font-medium text-gray-500 dark:text-gray-300 mb-1">
                <%= case I18n.locale when :fr then 'Du' when :de then 'Von' when :en then 'From' else 'Van' end %>
              </label>
              <input type="date" name="date_from" value="<%= @date_from %>"
                     class="py-2 px-2 rounded-lg border border-gray-300 dark:border-gray-600/50 dark:bg-gray-800 dark:text-gray-300 text-sm focus:ring-2 focus:ring-(--accent-500)">
            </div>
            <span class="text-gray-400 pb-2">–</span>
            <div>
              <label class="block text-xs font-medium text-gray-500 dark:text-gray-300 mb-1">
                <%= case I18n.locale when :fr then 'Au' when :de then 'Bis' when :en then 'To' else 'Tot' end %>
              </label>
              <input type="date" name="date_to" value="<%= @date_to %>"
                     class="py-2 px-2 rounded-lg border border-gray-300 dark:border-gray-600/50 dark:bg-gray-800 dark:text-gray-300 text-sm focus:ring-2 focus:ring-(--accent-500)">
            </div>
          </div>

          <!-- Results per page -->
          <div class="flex items-center gap-2">
            <label class="text-sm text-gray-500 dark:text-gray-300 whitespace-nowrap"><%= case I18n.locale when :fr then 'Par page:' when :de then 'Pro Seite:' when :en then 'Per page:' else 'Per pagina:' end %></label>
            <select name="per_page" class="py-2 px-3 rounded-lg border-gray-300 dark:border-gray-600/50 dark:bg-gray-800 dark:text-gray-300 text-sm focus:ring-2 focus:ring-(--accent-500)">
              <option value="20" <%= 'selected' if @per_page == 20 %>>20</option>
              <option value="50" <%= 'selected' if @per_page == 50 %>>50</option>
              <option value="100" <%= 'selected' if @per_page == 100 %>>100</option>
            </select>
          </div>

          <div class="flex items-center gap-2 ml-auto">
            <label class="text-sm text-gray-500 dark:text-gray-300"><%= case I18n.locale when :fr then 'Trier:' when :de then 'Sortieren:' when :en then 'Sort:' else 'Sorteren:' end %></label>
            <select name="sort" class="py-2 px-3 rounded-lg border-gray-300 dark:border-gray-600/50 dark:bg-gray-800 dark:text-gray-300 text-sm focus:ring-2 focus:ring-(--accent-500)">
              <option value="date_desc" <%= 'selected' if @sort == 'date_desc' || @sort.blank? %>><%= case I18n.locale when :fr then 'Plus récent' when :de then 'Neueste zuerst' when :en then 'Newest first' else 'Nieuwste eerst' end %></option>
              <option value="date_asc" <%= 'selected' if @sort == 'date_asc' %>><%= case I18n.locale when :fr then 'Plus ancien' when :de then 'Älteste zuerst' when :en then 'Oldest first' else 'Oudste eerst' end %></option>
            </select>
          </div>

          <% if @query.present? || @court.present? || @year.present? || @date_from.present? || @date_to.present? || @lang.present? || @subject.present? %>
            <a href="<%= jurisprudence_index_path %>" class="text-sm text-red-500 hover:text-red-600 dark:text-red-400 dark:hover:text-red-300 flex items-center gap-1 transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
              </svg>
              <%= case I18n.locale when :fr then 'Effacer' when :de then 'Löschen' when :en then 'Clear' else 'Wissen' end %>
            </a>
          <% end %>
        </div>
      </div>

      <!-- Hidden field to signal frame request -->
      <input type="hidden" name="frame" value="1">
    <% end %>
  </div>

  <!-- Results (Turbo Frame — lazy loaded) -->
  <div aria-live="polite" aria-relevant="additions removals" role="region" aria-label="<%= case I18n.locale when :fr then 'Résultats' when :de then 'Ergebnisse' when :en then 'Results' else 'Resultaten' end %>">
    <% has_search = @query.present? || @court.present? || @year.present? || @date_from.present? || @date_to.present? || @subject.present?
       frame_src = if has_search || params[:commit].present?
         jurisprudence_index_path(q: @query, court: @court, year: @year, date_from: @date_from, date_to: @date_to,
                                  lang: @lang, subject: @subject, sort: @sort, per_page: @per_page, page: @page, frame: 1)
       else
         # On initial visit, also load default results lazily
         jurisprudence_index_path(lang: @lang, sort: @sort, per_page: @per_page, page: @page, frame: 1)
       end
    %>
    <%= turbo_frame_tag 'jurisprudence_results', src: frame_src, loading: :lazy do %>
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg">
        <!-- Skeleton loader while Turbo Frame loads -->
        <div class="divide-y divide-gray-100 dark:divide-sky/20 animate-pulse">
          <% 5.times do %>
            <div class="px-5 py-4">
              <div class="flex items-start justify-between gap-3 mb-2">
                <div class="flex items-center gap-2.5">
                  <div class="w-5 h-5 rounded-full bg-gray-200 dark:bg-sky/20"></div>
                  <div class="h-4 w-48 bg-gray-200 dark:bg-sky/20 rounded"></div>
                </div>
                <div class="h-4 w-24 bg-gray-200 dark:bg-sky/20 rounded"></div>
              </div>
              <div class="pl-7 space-y-2">
                <div class="h-3 w-64 bg-gray-100 dark:bg-sky/10 rounded"></div>
                <div class="flex gap-1.5">
                  <div class="h-5 w-20 bg-gray-100 dark:bg-sky/10 rounded-full"></div>
                  <div class="h-5 w-16 bg-gray-100 dark:bg-sky/10 rounded-full"></div>
                </div>
                <div class="h-3 w-full bg-gray-100 dark:bg-sky/10 rounded"></div>
                <div class="h-3 w-3/4 bg-gray-100 dark:bg-sky/10 rounded"></div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Link to chatbot -->
  <% if Rails.application.config.chatbot_enabled %>
  <div class="mt-8 text-center">
    <a href="<%= chatbot_path(source: 'jurisprudence') %>" 
       class="inline-flex items-center gap-3 px-6 py-3 text-white font-medium rounded-xl shadow-lg hover:shadow-xl transition-all"
       style="background: linear-gradient(135deg, #2563eb, #4f46e5);">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/>
      </svg>
      <%= case I18n.locale when :fr then "Poser une question à l'assistant IA" when :de then 'Stellen Sie dem KI-Assistenten eine Frage' when :en then 'Ask the AI assistant a question' else 'Stel een vraag aan de AI-assistent' end %>
    </a>
  </div>
  <% end %>
</div>
