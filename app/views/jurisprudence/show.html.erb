<% @title = "#{@case[:court]} - #{@case[:case_number]}" %>

<div class="max-w-4xl mx-auto">
  <!-- Back link -->
  <div class="mb-4">
    <a href="<%= jurisprudence_index_path(pass: params[:pass]) %>" 
       class="inline-flex items-center text-blue-600 dark:text-blue-400 hover:underline">
      <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      <% if I18n.locale == :fr %>Retour à la liste<% else %>Terug naar overzicht<% end %>
    </a>
  </div>

  <!-- Case header -->
  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg overflow-hidden mb-6">
    <div class="p-6">
      <div class="flex items-start justify-between gap-4 mb-4">
        <div>
          <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-2">
            <%= @case[:case_number] %>
          </h1>
          <div class="flex flex-wrap gap-2">
            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-blue-100 dark:bg-blue-900 text-blue-800 dark:text-blue-200">
              🏛️ <%= @case[:court] %>
            </span>
            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-gray-100 dark:bg-gray-700 text-gray-800 dark:text-gray-200">
              📅 <%= @case[:decision_date] %>
            </span>
            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-gray-100 dark:bg-gray-700 text-gray-800 dark:text-gray-200">
              🌐 <%= @case[:language_id] == 1 ? 'Nederlands' : 'Français' %>
            </span>
          </div>
        </div>
        <% if @case[:url].present? %>
          <a href="<%= @case[:url] %>" target="_blank" rel="noopener"
             class="flex-shrink-0 px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg inline-flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
            <% if I18n.locale == :fr %>Source<% else %>Bron<% end %>
          </a>
        <% end %>
      </div>

      <% if @case[:summary].present? %>
        <div class="mb-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">
            <% if I18n.locale == :fr %>Résumé<% else %>Samenvatting<% end %>
          </h2>
          <div class="p-4 bg-gray-50 dark:bg-gray-700 rounded-lg text-gray-700 dark:text-gray-300">
            <%= @case[:summary] %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Full text -->
  <% if @case[:full_text].present? %>
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg overflow-hidden">
      <div class="p-6">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">
          <% if I18n.locale == :fr %>Texte intégral<% else %>Volledige tekst<% end %>
        </h2>
        <div class="prose dark:prose-invert max-w-none">
          <div class="whitespace-pre-wrap text-sm text-gray-700 dark:text-gray-300 leading-relaxed">
<%= @case[:full_text] %>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Ask chatbot -->
  <div class="mt-6 p-4 bg-blue-50 dark:bg-blue-900/30 rounded-xl">
    <div class="flex items-center gap-4">
      <div class="flex-shrink-0">
        <svg class="w-8 h-8 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/>
        </svg>
      </div>
      <div class="flex-1">
        <h3 class="font-medium text-gray-900 dark:text-white">
          <% if I18n.locale == :fr %>
            Questions sur cet arrêt?
          <% else %>
            Vragen over dit arrest?
          <% end %>
        </h3>
        <p class="text-sm text-gray-600 dark:text-gray-400">
          <% if I18n.locale == :fr %>
            Posez vos questions à notre assistant IA juridique
          <% else %>
            Stel uw vragen aan onze juridische AI-assistent
          <% end %>
        </p>
      </div>
      <a href="<%= chatbot_path(pass: params[:pass], source: 'jurisprudence') %>"
         class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg">
        <% if I18n.locale == :fr %>Ouvrir le chatbot<% else %>Open chatbot<% end %>
      </a>
    </div>
  </div>
</div>
