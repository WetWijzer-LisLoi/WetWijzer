<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>WetWijzer Admin</title>
    <meta name="robots" content="noindex, nofollow" />

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= turbo_refreshes_with method: :morph, scroll: :preserve %>
    <%= favicon_link_tag "#{t(:favicon)}?v=20251112" %>
    <%= vite_client_tag nonce: true %>
    <%= vite_javascript_tag 'application', 'data-turbo-track': 'reload', nonce: true %>
    <script nonce="<%= content_security_policy_nonce %>">
      // FOUC prevention: OS preference only. No localStorage.
      if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
        document.documentElement.classList.add('dark')
      }
    </script>

    <%= yield :head %>
  </head>
  <body class="overflow-x-hidden bg-gray-100 dark:bg-gray-950">
    <div class="min-h-screen flex flex-col overflow-x-hidden">
      <main id="main-content" class="container mx-auto p-4 flex-1" tabindex="-1">
        <% if admin_flash['notice'].present? %>
          <div class="mb-4 px-4 py-3 rounded-lg bg-green-100 dark:bg-green-900/30 border border-green-200 dark:border-green-800 text-green-800 dark:text-green-300 text-sm font-medium" role="status">
            <%= admin_flash['notice'] %>
          </div>
        <% end %>
        <% if admin_flash['alert'].present? %>
          <div class="mb-4 px-4 py-3 rounded-lg bg-red-100 dark:bg-red-900/30 border border-red-200 dark:border-red-800 text-red-800 dark:text-red-300 text-sm font-medium" role="alert">
            <%= admin_flash['alert'] %>
          </div>
        <% end %>
        <%= yield %>
      </main>
    </div>
  </body>
</html>
