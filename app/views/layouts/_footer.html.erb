<%# Footer with contact info, Ko-fi donation button, and legal links %>
<footer class="bg-(--surface-header-bg) mt-auto border-t border-gray-200 dark:border-gray-700/50">
  <div class="container mx-auto px-4 py-6">
    <%# ── Tagline ── %>
    <div class="mb-4">
      <span class="text-gray-500 dark:text-gray-400 text-xs sm:text-sm"><%= t('footer.tagline') %></span>
    </div>

    <%# ── Navigation links + Contact + Support icons ── %>
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
      <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-xs sm:text-sm text-gray-500 dark:text-gray-400">
        <%= link_to t('footer.about'), about_path,
                    class: "hover:text-(--accent-600) dark:hover:text-(--accent-500) transition-colors" %>
        <span class="text-gray-300 dark:text-gray-600">|</span>
        <%= link_to t('footer.imprint'), imprint_path,
                    class: "hover:text-(--accent-600) dark:hover:text-(--accent-500) transition-colors" %>
        <span class="text-gray-300 dark:text-gray-600">|</span>
        <%= link_to t('footer.terms'), terms_of_service_path,
                    class: "hover:text-(--accent-600) dark:hover:text-(--accent-500) transition-colors" %>
        <span class="text-gray-300 dark:text-gray-600">|</span>
        <%= link_to t('footer.privacy'), privacy_policy_path,
                    class: "hover:text-(--accent-600) dark:hover:text-(--accent-500) transition-colors" %>
        <span class="text-gray-300 dark:text-gray-600">|</span>
        <%= link_to t('footer.ai_security'), ai_security_path,
                    class: "hover:text-(--accent-600) dark:hover:text-(--accent-500) transition-colors" %>
        <span class="text-gray-300 dark:text-gray-600">|</span>
        <% if Rails.application.config.chatbot_enabled %>
        <%= link_to t('footer.faq'), faq_path,
                    class: "hover:text-(--accent-600) dark:hover:text-(--accent-500) transition-colors" %>
        <span class="text-gray-300 dark:text-gray-600">|</span>
        <% end %>
        <% if respond_to?(:pricing_path) %>
        <%= link_to t('footer.pricing'), pricing_path,
                    class: "hover:text-(--accent-600) dark:hover:text-(--accent-500) transition-colors" %>
        <span class="text-gray-300 dark:text-gray-600">|</span>
        <% end %>
        <%= link_to t('footer.accessibility'), accessibility_statement_path,
                    class: "hover:text-(--accent-600) dark:hover:text-(--accent-500) transition-colors" %>
        <span class="text-gray-300 dark:text-gray-600">|</span>
        <a href="<%= "https://classic.#{request.host.sub('staging.', '')}#{request.fullpath}" %>"
           class="hover:text-(--accent-600) dark:hover:text-(--accent-500) transition-colors"
           title="<%= case I18n.locale when :fr then 'Version classique (sans JavaScript)' when :de then 'Klassische Version (ohne JavaScript)' when :en then 'Classic version (no JavaScript)' else 'Klassieke versie (zonder JavaScript)' end %>"><%= case I18n.locale when :fr then 'Classic (sans JavaScript)' when :de then 'Classic (ohne JavaScript)' when :en then 'Classic (No Javascript)' else 'Classic (zonder JavaScript)' end %></a>
        <span class="text-gray-300 dark:text-gray-600">|</span>
        <span>
          <%= t('footer.contact_us') %>
          <a href="mailto:<%= contact_email %>" class="hover:text-(--accent-600) dark:hover:text-(--accent-500) transition-colors">
            <%= contact_email %>
          </a>
        </span>
      </div>

      <div class="flex items-center gap-3 shrink-0">
        <%# Support page button %>
        <%= link_to support_page_path,
                    class: "inline-flex items-center px-3 py-1.5 bg-[#FF5E5B] hover:bg-[#e54542] text-white rounded-md transition-colors duration-150 ease-out motion-reduce:transition-none text-sm font-medium",
                    title: t('footer.support_tooltip') do %>
          <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
          <span><%= t('footer.support_us') %></span>
        <% end %>

        <%# GitHub link %>
        <%= link_to "https://github.com/WetWijzer-LisLoi/WetWijzer",
                    target: "_blank",
                    rel: "noopener noreferrer",
                    class: "text-gray-600 dark:text-gray-300 hover:text-(--accent-600) dark:hover:text-(--accent-500) transition-colors duration-150 ease-out motion-reduce:transition-none",
                    title: t('footer.github_tooltip') do %>
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        <% end %>
      </div>
    </div>
  </div>
</footer>

