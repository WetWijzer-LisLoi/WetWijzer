<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>WetWijzer Admin</title>
    <meta name="robots" content="noindex, nofollow" />

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= turbo_refreshes_with method: :morph, scroll: :preserve %>
    <%= favicon_link_tag "#{t(:favicon)}?v=20251112" %>
    <%= vite_client_tag nonce: true %>
    <%= vite_javascript_tag 'application', 'data-turbo-track': 'reload', nonce: true %>
    <script nonce="<%= content_security_policy_nonce %>">
      // FOUC prevention: OS preference only. No localStorage.
      if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
        document.documentElement.classList.add('dark')
      }
    </script>
  </head>
  <body class="overflow-x-hidden bg-gray-100 dark:bg-gray-950">
    <div class="min-h-screen flex flex-col overflow-x-hidden">
      <main id="main-content" class="container mx-auto p-4 flex-1 flex items-center justify-center" tabindex="-1">
        <%= yield %>
      </main>
    </div>
  </body>
</html>
