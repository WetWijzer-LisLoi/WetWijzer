<%= render 'legal_pages/legal_page_styles' %>
<div class="legal-page">
<h1>About Me</h1>

    <div class="flex gap-4 items-start mb-8">
        <%# Circular photo with gold ring - matching chatbot about section %>
        <div class="flex-shrink-0">
            <div class="w-16 h-16 sm:w-20 sm:h-20 rounded-full p-[2px]" style="background: linear-gradient(135deg, #c9a962, #e8d5a3, #c9a962);">
                <img src="/images/gauthier-berth.jpg"
                     alt="Gauthier Berth"
                     class="w-full h-full rounded-full object-cover border-2 border-white dark:border-gray-800"
                     loading="lazy">
            </div>
        </div>
        <div>
            <h2 class="mt-0 mb-1">Mr. Gauthier Berth</h2>
            <p class="text-(--accent-600) dark:text-(--accent-400) font-semibold text-sm mb-0.5">Founder of WetWijzer, LisLoi, GesetzGuide and LexLibera</p>
            <p class="text-sm text-gray-500 dark:text-gray-400">Attorney at the Dutch-speaking Bar of Brussels &mdash; <a href="https://www.advocaat.be/nl/zoek-een-advocaat/advocaat/63fee2a5-637a-4839-a5a6-c833482f1e3a" target="_blank" rel="noopener" class="underline hover:text-gray-600 dark:hover:text-gray-300">profile on advocaat.be</a> · <a href="https://www.linkedin.com/in/gauthier-b-017447138/" target="_blank" rel="noopener" class="underline hover:text-gray-600 dark:hover:text-gray-300">LinkedIn</a></p>
        </div>
