                    <td>3</td>
                    <td>o4-mini / Claude 4.5 Haiku</td>
                    <td>Analyse juridique approfondie</td>
                    <td>Pro uniquement Recommand&eacute;</td>
                </tr>
                <tr>
                    <td>Maître</td>
