# Normalize line endings to LF on commit
* text=auto eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.sqlite3 binary

# Shell scripts must be LF
*.sh text eol=lf

# Windows batch files must be CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
