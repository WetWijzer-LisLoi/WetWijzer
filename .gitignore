# BMad agent framework (local tooling, not shipped)
.agent/
_bmad/

# Windows NUL device artifact
NUL

# Python bytecode
__pycache__/
**/__pycache__/
*.pyc

# Editor / OS artifacts
rerun.txt
*.swp
*.swo
*.DS_Store
.bundle
.byebug_history
.idea
.vs/
.vscode/

# Database files
db/*.sqlite3*
*.db
*.db.gz
*.db-shm
*.db-wal
*.sqlite3
*.sqlite3-shm
*.sqlite3-wal

# Embedding generation artifacts (large files)
embedding_output.log
article_embeddings.db*

# FAISS indexes and metadata (large binary files - deployed on server only)
*.faiss
*.npy
*.xz

# Large generated data (backed up on storage box: repo-archive/)
test/results/
corpus/
scripts/archive/chatbot-quality/

# Large test/temp files
*.zip
justel_search_*.html

# Logs
/log/
log/*.log
log/*.log.*
*.log

# Cache and temp
.sass-cache/
tmp/*
public/tmp/*
public/uploads
dump.rdb

# Build outputs
/public/packs/
/public/packs-test/
/public/assets
/app/assets/builds/*
!/app/assets/builds/.keep

# Node
/node_modules
yarn-error.log
yarn-debug.log*
.yarn-integrity
yarn.lock

# Vite Ruby
# Commit production build outputs so server doesn't need Node.
# Keep development/test outputs ignored.
/public/vite-dev/
/public/vite-test/
# Source maps are large and unnecessary in the repo
public/vite/**/*.map

# Python virtual environment
.venv/
venv/
# Vite dotenv local-only files
*.local

# Secrets and credentials
.env
.env.*
!.env.example
faiss.env
*.env.local
/config/master.key
config/credentials.yml.enc
docs/STAGING_TEST_CREDENTIALS.md
docs/CHATBOT_ACCESS.md

# Storage
storage/**/*
!storage/.keep
/coverage
/vendor/

# Exclude root-level scripts (contain server IPs, test data)
/*.sh
/*.ps1
!deploy.ps1
/*.py
/*.bat

# Markdown: ignore by default, allow specific files
*.md
!README.md
!CONTRIBUTING.md
!LICENSE.md
!DEPLOYMENT.md
!.github/**/*.md

# Re-allow tracked dirs for scripts
!bin/**
!lib/**
!test/**
!scripts/**
!.github/**

# Re-ignore pycache, credentials, database files, and results inside allowed dirs
lib/**/__pycache__/
lib/**/*.pyc
lib/**/*.db
lib/**/*.db-shm
lib/**/*.db-wal
lib/**/*.sqlite3
lib/**/*.sqlite3-shm
lib/**/*.sqlite3-wal
scripts/**/__pycache__/
scripts/**/*.pyc
test/**/*.md
test/**/*.json.bak
lib/wetwijzer_updater/gdrive_token.json
lib/wetwijzer_updater/gdrive_credentials.json

# Docs: ignore everything except allowed subtrees
docs/**
!docs/wetwijzer-python/
docs/wetwijzer-python/**
!docs/wetwijzer-python/*.py
!docs/wetwijzer-python/requirements.txt
!docs/wetwijzer-python/*.sh
!docs/wetwijzer-python/WetWijzer N-gram Backfill Runbook.md
!docs/wetwijzer-python/tests/
!docs/wetwijzer-python/tests/**/*.py
docs/wetwijzer-python/tests/**/__pycache__/
docs/wetwijzer-python/tests/**/.pytest_cache/
docs/wetwijzer-python/tests/**/*.pyc

# Allow ops docs subtree
!docs/ops/
!docs/ops/**

# Allow specific docs
!docs/README.md
!docs/SERVER_SECURITY.md
!docs/FAIL2BAN_SETUP.md
!docs/SSH_PORT_CHANGE.md
!docs/SECURITY_AUDIT*.md
!docs/scraper_version_history.md
!docs/v087_*.md
!docs/v0871_*.md
!docs/CRYPTO_PAYMENTS.md
!docs/walkthrough.md
!docs/index.md
!docs/archive/
!docs/archive/CRYPTO_PAYMENTS_BTCPAY_PLAN.md

# FAISS service: track configs, ignore runtime artifacts
faiss_service/__pycache__/
faiss_service/*.pyc
faiss_service/*.py
!faiss_service/faiss.env.example

# Database backup/copy artifacts
db/.backup*/
db/*Copy*

# Legal pages containing personal company data (KBO address, VAT, etc.)
app/views/legal_pages/privacy_*.html.erb
app/views/legal_pages/terms_*.html.erb
app/views/legal_pages/imprint_*.html.erb

# Security scan artifacts (contain staging URLs, vulnerability data)
tools/sqlmap
tools/sqlmap-results/
tools/sqlmap_results.log
