# Vite Ruby
# Commit production build outputs so server doesn't need Node.
# Keep development/test outputs ignored.
/public/vite-dev/
/public/vite-test/
# Source maps are large and unnecessary in the repo
public/vite/**/*.map

/config/master.key

node_modules
# Python virtual environment
.venv/
venv/
# Vite uses dotenv and suggests to ignore local-only env files. See
# https://vitejs.dev/guide/env-and-mode.html#env-files
*.local

# Docs: ignore everything except WetWijzer Python download scripts
docs/**
!docs/wetwijzer-python/
docs/wetwijzer-python/**
!docs/wetwijzer-python/*.py
!docs/wetwijzer-python/requirements.txt
!docs/wetwijzer-python/*.sh

# Allow tracking the n-gram backfill runbook
!docs/wetwijzer-python/WetWijzer N-gram Backfill Runbook.md

# Allow test files but not test results
!docs/wetwijzer-python/tests/
!docs/wetwijzer-python/tests/**/*.py
docs/wetwijzer-python/tests/**/__pycache__/
docs/wetwijzer-python/tests/**/.pytest_cache/
docs/wetwijzer-python/tests/**/*.pyc
# Allow ops docs subtree (schedules, installers, runbooks)
!docs/ops/
!docs/ops/**

# Allow security documentation
!docs/SERVER_SECURITY.md
!docs/FAIL2BAN_SETUP.md
!docs/SSH_PORT_CHANGE.md
!docs/SECURITY_AUDIT*.md

# Allow scraper documentation
!docs/scraper_version_history.md
!docs/v087_*.md
!docs/v0871_*.md

# Allow payment & billing docs
!docs/CRYPTO_PAYMENTS.md
!docs/walkthrough.md
!docs/index.md
!docs/archive/
!docs/archive/CRYPTO_PAYMENTS_BTCPAY_PLAN.md
/vendor/
.vscode/

# Exclude development/comparison scripts from root (contain server IPs, test data)
*.sh
*.ps1
!deploy.ps1
*.py
*.bat
!bin/**
!lib/**
!test/**
!.github/**
